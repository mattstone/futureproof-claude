<%= render 'shared/header' %>

<%
  # Determine market from params or default to US
  market = params[:market]&.downcase || 'us'

  # Market-specific default values
  if market == 'au'
    default_home_value = 2500000
  else
    default_home_value = 2450000
  end
%>

<div class="demo-page">
  <div class="demo-container" data-controller="demo-funding"
       data-demo-funding-market-value="<%= market %>"
       data-demo-funding-default-home-value-value="<%= default_home_value %>">
    <!-- Step Indicator -->
    <div class="demo-step-indicator">
      <span class="demo-step-text">Step 3 of 3</span>
      <div class="demo-step-circles">
        <div class="demo-step-circle">1</div>
        <div class="demo-step-circle">2</div>
        <div class="demo-step-circle active">3</div>
      </div>
    </div>

    <!-- Section Header with numbering -->
    <div class="demo-section-header-numbered">
      <h1 class="demo-section-title-numbered">3. Funding details</h1>
      <p class="demo-section-subtitle">Review your loan summary and confirm</p>
    </div>

    <!-- Mortgage Summary - matching Webapp mortgage-summary.tsx -->
    <div class="demo-mortgage-summary">
      <div class="demo-summary-card">
        <!-- EPM Logo -->
        <div class="demo-summary-logo">
          <%= image_tag "home-picture.png", alt: "EPM", class: "demo-summary-logo-icon" %>
          <div>
            <span class="demo-summary-logo-text">With the</span>
            <span class="demo-summary-logo-title">Equity Preservation Mortgage®</span>
          </div>
        </div>

        <!-- Loan Summary Section -->
        <div class="demo-summary-section">
          <div class="demo-summary-section-header">
            <h5 class="demo-summary-section-title">Loan summary</h5>
            <svg class="demo-summary-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Mortgage type</span>
            <span class="demo-summary-row-value" data-demo-funding-target="mortgageType">Interest-only</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">LVR</span>
            <span class="demo-summary-row-value">80%</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Interest rate</span>
            <span class="demo-summary-row-value"><%= EpmModelConfig.indicative_borrower_rate_pct %>%</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Loan term</span>
            <span class="demo-summary-row-value" data-demo-funding-target="loanTerm">30 years</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Loan amount</span>
            <span class="demo-summary-row-value" data-demo-funding-target="loanAmount">$2,000,000</span>
          </div>
        </div>

        <!-- Property Summary Section -->
        <div class="demo-summary-section">
          <div class="demo-summary-section-header">
            <h5 class="demo-summary-section-title">Property summary</h5>
            <svg class="demo-summary-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            </svg>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Current home value</span>
            <span class="demo-summary-row-value" data-demo-funding-target="homeValue">$2,500,000</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Your projected annual growth</span>
            <span class="demo-summary-row-value" data-demo-funding-target="growthRate">4%</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Home value at end of loan term</span>
            <span class="demo-summary-row-value" data-demo-funding-target="futureValue">$10,804,820</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Home equity preserved</span>
            <span class="demo-summary-row-value success" data-demo-funding-target="equityPreserved">$10,804,820</span>
          </div>
        </div>

        <!-- Payment Summary Section -->
        <div class="demo-summary-section">
          <div class="demo-summary-section-header">
            <h5 class="demo-summary-section-title">Payment summary</h5>
            <svg class="demo-summary-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Interest paid on your behalf</span>
            <span class="demo-summary-row-value success" data-demo-funding-target="interestPaid">$5,947,740</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Repayment at end of the loan term</span>
            <span class="demo-summary-row-value" data-demo-funding-target="repaymentAmount">$2,660,000</span>
          </div>
        </div>

        <!-- Annuity Income Summary Section -->
        <div class="demo-summary-section">
          <div class="demo-summary-section-header">
            <h5 class="demo-summary-section-title">Annuity income summary</h5>
            <svg class="demo-summary-section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Total income amount</span>
            <span class="demo-summary-row-value success" data-demo-funding-target="totalIncome">$408,670</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Monthly income</span>
            <span class="demo-summary-row-value success" data-demo-funding-target="monthlyIncome">$3,405.59</span>
          </div>
          <div class="demo-summary-row">
            <span class="demo-summary-row-label">Annuity duration</span>
            <span class="demo-summary-row-value" data-demo-funding-target="annuityDuration">10 years</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Use of Annuity Income - matching Webapp use-of-annuity-income.tsx -->
    <div class="demo-use-of-income">
      <div class="demo-use-of-income-header">
        <h2 class="demo-use-of-income-title">How will you use your annuity income?</h2>
        <p class="demo-use-of-income-subtitle">Select all that apply</p>
      </div>
      <div class="demo-checkbox-group">
        <div class="demo-checkbox-item checked" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Day-to-day living expenses</p>
        </div>
        <div class="demo-checkbox-item" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Home renovations and improvements</p>
        </div>
        <div class="demo-checkbox-item" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Travel and leisure</p>
        </div>
        <div class="demo-checkbox-item" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Healthcare and medical expenses</p>
        </div>
        <div class="demo-checkbox-item" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Helping family members</p>
        </div>
        <div class="demo-checkbox-item" data-action="click->demo-funding#toggleCheckbox">
          <div class="demo-checkbox-box">
            <svg class="demo-checkbox-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="demo-checkbox-label">Other</p>
        </div>
      </div>
    </div>

    <!-- Apply Button -->
    <%= link_to demo_preapproved_applications_path, class: "demo-apply-btn" do %>
      Apply for loan pre-approval
    <% end %>
  </div>
</div>

<%= render 'shared/footer' %>
