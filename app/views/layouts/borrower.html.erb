<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "My EPM Loan - Futureproof" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="background: #f8f9fa;">
    <nav class="borrower-header">
      <div class="borrower-header-container">
        <%= link_to borrower_root_path, class: "borrower-logo" do %>
          <%= image_tag "futureproof-logo.png", alt: "FutureProof", style: "height: 32px;" %>
        <% end %>
        
        <div class="borrower-nav">
          <%= link_to "My Loans", borrower_applications_path, class: "borrower-nav-link #{'active' if controller_name == 'applications' && action_name == 'index'}" %>
          <%= link_to current_user.email, "#", class: "borrower-nav-user" %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "borrower-nav-link" %>
        </div>
      </div>
    </nav>

    <main class="borrower-main">
      <% if notice %>
        <div class="alert alert-success" style="margin: 20px; padding: 12px; border-radius: 4px; background: #d4edda; color: #155724; border: 1px solid #c3e6cb;">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger" style="margin: 20px; padding: 12px; border-radius: 4px; background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <style>
      .borrower-header {
        background: white;
        border-bottom: 1px solid #e0e0e0;
        padding: 0;
      }

      .borrower-header-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .borrower-logo {
        text-decoration: none;
        display: flex;
        align-items: center;
      }

      .borrower-nav {
        display: flex;
        gap: 16px;
        align-items: center;
      }

      .borrower-nav-link {
        text-decoration: none;
        color: #666;
        font-size: 14px;
        padding: 6px 12px;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .borrower-nav-link:hover {
        color: #333;
        background: #f0f0f0;
      }

      .borrower-nav-link.active {
        color: #2196F3;
        font-weight: 500;
      }

      .borrower-nav-user {
        color: #666;
        font-size: 14px;
      }

      .borrower-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      .alert {
        margin: 0 0 20px 0;
        padding: 16px;
        border-radius: 6px;
        font-size: 14px;
      }

      .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
      }

      .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
      }
    </style>
  </body>
</html>
