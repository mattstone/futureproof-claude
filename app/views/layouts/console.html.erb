<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "FutureProof Console" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "design_system", "console", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="console-body">
    <%# The sidebar is data-turbo-permanent: a nav click swaps only the
        #console_main frame, and a full-page visit (e.g. a row drill-in)
        preserves the sidebar element instead of repainting it. The
        console--nav controller re-highlights the active link on every frame
        load, since the permanent sidebar is never re-rendered server-side. %>
    <div class="console-shell" data-controller="console--nav"
         data-action="turbo:frame-load@document->console--nav#updateActive turbo:load@document->console--nav#updateActive">
      <aside id="console-sidebar" class="console-sidebar" data-console--nav-target="sidebar" data-turbo-permanent>
        <%= render "console/shared/nav" %>
      </aside>

      <div class="console-main">
        <header class="console-topbar">
          <button type="button"
                  class="console-nav-toggle"
                  data-action="console--nav#toggle"
                  aria-label="Toggle navigation">&#9776;</button>

          <div class="console-topbar-spacer"></div>

          <%= render "console/shared/jurisdiction_switcher" %>

          <div class="console-user">
            <span class="console-user-email"><%= current_user.email %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "console-signout", form_class: "console-signout-form" %>
          </div>
        </header>

        <main class="console-content">
          <%= turbo_frame_tag "console_main", data: { turbo_action: "advance" } do %>
            <div id="console-flash">
              <%= render Console::FlashMessagesComponent.new(flash: flash) %>
            </div>
            <%= yield %>
          <% end %>
        </main>
      </div>
    </div>
  </body>
</html>
