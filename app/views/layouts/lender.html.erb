<!DOCTYPE html>
<html>
  <head>
    <title>Lender Portal — FutureProof EPM</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f5f5f5;
        color: #333;
      }

      .lender-container {
        display: grid;
        grid-template-columns: 250px 1fr;
        min-height: 100vh;
      }

      .lender-sidebar {
        background: linear-gradient(180deg, #1f2937 0%, #111827 100%);
        color: white;
        padding: 0;
        position: fixed;
        left: 0;
        top: 0;
        width: 250px;
        height: 100vh;
        overflow-y: auto;
        border-right: 1px solid #374151;
      }

      .lender-logo {
        padding: 20px;
        border-bottom: 1px solid #374151;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .lender-logo-icon {
        width: 32px;
        height: 32px;
        background: #10B981;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
      }

      .lender-logo-text {
        font-weight: bold;
        font-size: 14px;
      }

      .lender-nav {
        padding: 20px 0;
      }

      .lender-nav-item {
        padding: 12px 20px;
        color: #d1d5db;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        transition: all 0.2s;
        border-left: 3px solid transparent;
      }

      .lender-nav-item:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
      }

      .lender-nav-item.active {
        background: rgba(16, 185, 129, 0.1);
        color: #10B981;
        border-left-color: #10B981;
      }

      .lender-nav-section {
        padding: 0 0 20px 0;
      }

      .lender-nav-label {
        padding: 12px 20px;
        font-size: 12px;
        font-weight: bold;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .lender-header {
        background: white;
        border-bottom: 1px solid #e5e7eb;
        padding: 16px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .lender-header-title {
        font-size: 20px;
        font-weight: bold;
        color: #1f2937;
      }

      .lender-user-menu {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .lender-user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #10B981;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
      }

      .lender-user-name {
        font-size: 13px;
        color: #666;
      }

      .lender-content {
        grid-column: 2;
        padding: 30px;
        overflow-y: auto;
      }

      .lender-main {
        max-width: 1400px;
        margin: 0 auto;
      }

      .lender-breadcrumb {
        font-size: 13px;
        color: #999;
        margin-bottom: 16px;
      }

      .lender-breadcrumb a {
        color: #10B981;
        text-decoration: none;
      }

      .lender-page-header {
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .lender-page-header h1 {
        font-size: 28px;
        color: #1f2937;
      }

      .lender-page-actions {
        display: flex;
        gap: 10px;
      }

      .btn {
        padding: 10px 20px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
      }

      .btn-primary {
        background: #10B981;
        color: white;
      }

      .btn-primary:hover {
        background: #059669;
      }

      .btn-secondary {
        background: #f3f4f6;
        color: #333;
      }

      .btn-secondary:hover {
        background: #e5e7eb;
      }

      /* Alert/Notice styles */
      .alert {
        padding: 12px 16px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-size: 14px;
      }

      .alert-notice {
        background: #D1FAE5;
        color: #065F46;
        border: 1px solid #6EE7B7;
      }

      .alert-alert {
        background: #FEE2E2;
        color: #991B1B;
        border: 1px solid #FCA5A5;
      }

      @media (max-width: 768px) {
        .lender-container {
          grid-template-columns: 1fr;
        }

        .lender-sidebar {
          position: relative;
          width: 100%;
          height: auto;
          border-right: none;
          border-bottom: 1px solid #374151;
        }

        .lender-content {
          grid-column: 1;
          padding: 16px;
        }
      }
    </style>
  </head>

  <body>
    <div class="lender-container">
      <!-- Sidebar Navigation -->
      <aside class="lender-sidebar">
        <div class="lender-logo">
          <div class="lender-logo-icon">📊</div>
          <div class="lender-logo-text">FutureProof</div>
        </div>

        <nav class="lender-nav">
          <!-- Main Navigation -->
          <div class="lender-nav-section">
            <%= link_to lender_dashboard_index_path, class: "lender-nav-item #{current_page?(lender_dashboard_index_path) ? 'active' : ''}" do %>
              📈 Dashboard
            <% end %>
            <%= link_to lender_dashboard_applications_path, class: "lender-nav-item #{current_page?(lender_dashboard_applications_path) ? 'active' : ''}" do %>
              📋 Applications
            <% end %>
            <%= link_to lender_dashboard_payments_path, class: "lender-nav-item #{current_page?(lender_dashboard_payments_path) ? 'active' : ''}" do %>
              💰 Payments
            <% end %>
            <%= link_to lender_dashboard_reports_path, class: "lender-nav-item #{current_page?(lender_dashboard_reports_path) ? 'active' : ''}" do %>
              📊 Reports
            <% end %>
          </div>

          <!-- Settings -->
          <div class="lender-nav-section">
            <div class="lender-nav-label">Account</div>
            <%= link_to lender_dashboard_account_path, class: "lender-nav-item #{current_page?(lender_dashboard_account_path) ? 'active' : ''}" do %>
              ⚙️ Settings
            <% end %>
            <%= link_to destroy_user_session_path, method: :delete, class: "lender-nav-item" do %>
              🚪 Logout
            <% end %>
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <div class="lender-content">
        <!-- Header -->
        <header class="lender-header">
          <div class="lender-header-title">
            <%= yield(:page_title) || "Lender Portal" %>
          </div>
          <div class="lender-user-menu">
            <div>
              <div class="lender-user-name"><%= current_user.company_name || current_user.full_name %></div>
              <div style="font-size: 12px; color: #999;">Lender</div>
            </div>
            <div class="lender-user-avatar">
              <%= current_user.first_name[0].upcase %>
            </div>
          </div>
        </header>

        <!-- Alerts/Notices -->
        <% if notice.present? %>
          <div class="alert alert-notice"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-alert"><%= alert %></div>
        <% end %>

        <!-- Main Content -->
        <div class="lender-main">
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
