<!DOCTYPE html>
<html data-theme="light" lang="en" class="admin-html">
  <head>
    <title>Admin - <%= content_for(:title) || "Futureproof" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "admin", "lexxy-variables", "lexxy", "lexxy-content", "lexxy-editor", "admin/dashboard", "admin/dashboard_v2", "admin/business_dashboard", "admin/legal_documents", "admin/faqs", "admin/support_tickets", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin-body">
    <div class="admin-container">
      <!-- Admin Sidebar -->
      <aside id="admin-sidebar" class="admin-sidebar" data-turbo-permanent data-controller="admin-nav" data-action="turbo:frame-load@document->admin-nav#updateActive turbo:load@document->admin-nav#updateActive">
        <div class="admin-brand">
          <%= link_to admin_root_path, class: "admin-brand-link", data: { turbo_frame: "admin_main" } do %>
            <%= image_tag "futureproof-logo.png", class: "admin-logo" %>
          <% end %>
        </div>

        <nav class="admin-nav" role="navigation" aria-label="Admin sections" data-turbo-frame="admin_main">
          <%= link_to admin_root_path, class: "admin-nav-link #{'active' if controller_name == 'dashboard'}", data: { admin_nav_target: "link" } do %>
            <span>📊 Dashboard</span>
          <% end %>

          <details class="admin-nav-group" <%= 'open' if controller_name == 'support_tickets' %>>
            <summary class="admin-nav-group-header">Support</summary>
            <div class="admin-nav-group-items">
              <%= link_to admin_support_tickets_path, class: "admin-nav-link #{'active' if controller_name == 'support_tickets'}", data: { admin_nav_target: "link" } do %>
                <span>Support Tickets</span><% if admin_attention_counts[:tickets].positive? %><span class="nav-badge"><%= admin_attention_counts[:tickets] %></span><% end %>
              <% end %>
            </div>
          </details>

          <details class="admin-nav-group" <%= 'open' if controller_name.in?(%w[audit_logs chat_conversations]) %>>
            <summary class="admin-nav-group-header">Compliance</summary>
            <div class="admin-nav-group-items">
              <%= link_to admin_audit_logs_path, class: "admin-nav-link #{'active' if controller_name == 'audit_logs'}", data: { admin_nav_target: "link" } do %>
                <span>📜 Audit Log</span>
              <% end %>
              <%= link_to admin_chat_conversations_path, class: "admin-nav-link #{'active' if controller_name == 'chat_conversations'}", data: { admin_nav_target: "link" } do %>
                <span>💬 AI Conversations</span>
              <% end %>
            </div>
          </details>

          <details class="admin-nav-group" <%= 'open' if controller_name.in?(%w[customer_service applications contracts users]) %>>
            <summary class="admin-nav-group-header">Operations</summary>
            <div class="admin-nav-group-items">
              <%= link_to admin_customer_service_path, class: "admin-nav-link #{'active' if controller_name == 'customer_service'}", data: { admin_nav_target: "link" } do %>
                <span>🛟 Customer Service</span>
              <% end %>
              <%= link_to admin_applications_path, class: "admin-nav-link #{'active' if controller_name == 'applications'}", data: { admin_nav_target: "link" } do %>
                <span>📋 Applications</span><% if admin_attention_counts[:applications].positive? %><span class="nav-badge"><%= admin_attention_counts[:applications] %></span><% end %>
              <% end %>
              <%= link_to admin_contracts_path, class: "admin-nav-link #{'active' if controller_name == 'contracts'}", data: { admin_nav_target: "link" } do %>
                <span>📄 Contracts</span>
              <% end %>
              <%= link_to admin_users_path, class: "admin-nav-link #{'active' if controller_name == 'users'}", data: { admin_nav_target: "link" } do %>
                <span>👥 Users</span>
              <% end %>
            </div>
          </details>

          <details class="admin-nav-group" <%= 'open' if controller_name.in?(%w[agent_dashboard agent_lifecycle email_templates prompts prompt_change_requests]) %>>
            <summary class="admin-nav-group-header">AI Agents</summary>
            <div class="admin-nav-group-items">
              <% if current_user&.lender&.lender_type_futureproof? %>
                <%= link_to admin_agent_dashboard_index_path, class: "admin-nav-link #{'active' if controller_name.in?(%w[agent_dashboard agent_lifecycle])}", data: { admin_nav_target: "link" } do %>
                  <span>🤖 Agent Overview</span>
                <% end %>
                <%= link_to admin_email_templates_path, class: "admin-nav-link #{'active' if controller_name == 'email_templates'}", data: { admin_nav_target: "link" } do %>
                  <span>📧 Email Templates</span>
                <% end %>
              <% end %>
              <%= link_to admin_prompts_path, class: "admin-nav-link #{'active' if controller_name == 'prompts'}", data: { admin_nav_target: "link" } do %>
                <span>🧠 Prompts</span>
              <% end %>
              <%= link_to admin_prompt_change_requests_path, class: "admin-nav-link #{'active' if controller_name == 'prompt_change_requests'}", data: { admin_nav_target: "link" } do %>
                <span>📝 Change Requests</span><% if admin_attention_counts[:change_requests].positive? %><span class="nav-badge"><%= admin_attention_counts[:change_requests] %></span><% end %>
              <% end %>
            </div>
          </details>

          <% if current_user&.lender&.lender_type_futureproof? %>
            <details class="admin-nav-group" <%= 'open' if controller_name.in?(%w[mortgages lenders brokers wholesale_funders calculators]) %>>
              <summary class="admin-nav-group-header">Products</summary>
              <div class="admin-nav-group-items">
                <%= link_to admin_mortgages_path, class: "admin-nav-link #{'active' if controller_name == 'mortgages'}", data: { admin_nav_target: "link" } do %>
                  <span>🏠 Mortgages</span>
                <% end %>
                <%= link_to admin_lenders_path, class: "admin-nav-link #{'active' if controller_name == 'lenders'}", data: { admin_nav_target: "link" } do %>
                  <span>🏢 Lenders</span>
                <% end %>
                <%= link_to admin_brokers_path, class: "admin-nav-link #{'active' if controller_name == 'brokers'}", data: { admin_nav_target: "link" } do %>
                  <span>🤝 Brokers</span>
                <% end %>
                <%= link_to admin_wholesale_funders_path, class: "admin-nav-link #{'active' if controller_name == 'wholesale_funders'}", data: { admin_nav_target: "link" } do %>
                  <span>💰 Wholesale Funders</span>
                <% end %>
                <%= link_to admin_calculators_path, class: "admin-nav-link #{'active' if controller_name == 'calculators'}", data: { admin_nav_target: "link" } do %>
                  <span>🧮 Calculator</span>
                <% end %>
              </div>
            </details>

            <details class="admin-nav-group" <%= 'open' if controller_name.in?(%w[legal_documents agreements faqs core_logic_test]) %>>
              <summary class="admin-nav-group-header">Configuration</summary>
              <div class="admin-nav-group-items">
                <%= link_to admin_legal_documents_path, class: "admin-nav-link #{'active' if controller_name == 'legal_documents'}", data: { admin_nav_target: "link" } do %>
                  <span>Legal Documents</span>
                <% end %>
                <%= link_to admin_agreements_path, class: "admin-nav-link #{'active' if controller_name == 'agreements'}", data: { admin_nav_target: "link" } do %>
                  <span>Agreements</span>
                <% end %>
                <%= link_to admin_faqs_path, class: "admin-nav-link #{'active' if controller_name == 'faqs'}", data: { admin_nav_target: "link" } do %>
                  <span>FAQs</span>
                <% end %>
                <%= link_to admin_core_logic_test_index_path, class: "admin-nav-link #{'active' if controller_name == 'core_logic_test'}", data: { admin_nav_target: "link" } do %>
                  <span>CoreLogic API Test</span>
                <% end %>
              </div>
            </details>
          <% end %>
        </nav>

        <div class="admin-user-info">
          <div class="admin-current-user">
            <strong><%= current_user.display_name %></strong>
            <small><%= current_user.email %></small>
          </div>
          <div class="admin-actions">
            <%= link_to "View Site", root_path, class: "admin-link", target: "_blank" %>
            <%= link_to "🕹️ Arcade", arcade_path, class: "admin-link", target: "_blank" %>
            <%= render 'shared/sign_out_link', css_class: "admin-link" %>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <%= turbo_frame_tag "admin_main", data: { turbo_action: "advance" } do %>
        <main class="admin-main">
          <div class="admin-header">
            <div class="admin-header-title-section">
              <h1><%= yield(:page_title) || "Back Office" %></h1>
            </div>
            <%= render 'admin/shared/jurisdiction_switcher' %>
          </div>

          <div class="admin-content">
            <% if notice %>
              <div class="alert alert-success"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="alert alert-danger"><%= alert %></div>
            <% end %>

            <%= yield %>
          </div>
        </main>
      <% end %>
    </div>
  </body>
</html>
