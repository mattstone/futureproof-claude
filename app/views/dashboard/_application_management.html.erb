<!-- Enhanced Application Management Component -->
<div class="application-management-container">
  <% @submitted_applications.each do |application| %>
    <div class="application-card enhanced" id="application-<%= application.id %>"
         data-controller="application-messages"
         data-application-messages-application-id-value="<%= application.id %>"
         data-application-id="<%= application.id %>">
      
      <!-- Application Header -->
      <div class="application-card-header">
        <div class="application-info">
          <h3 class="application-title">
            Application #<%= application.id.to_s.rjust(6, '0') %>
          </h3>
          <div class="application-meta">
            <span class="status-badge <%= application.status_badge_class %>">
              <%= application.status_display %>
            </span>
            <span class="application-date">
              Submitted <%= application.updated_at.strftime("%B %d, %Y") %>
            </span>
          </div>
        </div>
        
        <div class="application-actions-header">
          <button class="btn btn-outline-primary btn-sm" 
                  data-action="click->application-messages#toggleDetails"
                  data-application-id="<%= application.id %>">
            <i class="fas fa-eye"></i> View
          </button>
          <% if application.application_messages.any? %>
            <button class="btn site-btn-primary btn-sm" 
                    data-action="click->application-messages#toggleMessages"
                    data-application-id="<%= application.id %>">
              <i class="fas fa-comments"></i> Messages 
              <span class="message-count"><%= application.application_messages.admin_messages.unread.count %></span>
            </button>
          <% end %>
        </div>
      </div>

      <!-- Application Summary -->
      <div class="application-summary">
        <div class="summary-grid">
          <div class="summary-item">
            <i class="fas fa-home summary-icon"></i>
            <div class="summary-content">
              <span class="summary-value"><%= truncate(application.address, length: 40) %></span>
              <span class="summary-subvalue"><%= application.formatted_home_value %></span>
            </div>
          </div>
          <div class="summary-item">
            <i class="fas fa-chart-line summary-icon"></i>
            <div class="summary-content">
              <% if application.mortgage.present? %>
                <span class="summary-value"><%= application.mortgage.name %></span>
              <% else %>
                <span class="summary-value no-data">Not selected</span>
              <% end %>
            </div>
          </div>
          <div class="summary-item">
            <i class="fas fa-dollar-sign summary-icon"></i>
            <div class="summary-content">
              <% if application.mortgage.present? && application.respond_to?(:monthly_income_amount) %>
                <span class="summary-value income-amount"><%= application.formatted_monthly_income_amount %> pm</span>
              <% else %>
                <span class="summary-value no-data">—</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Expandable Application Details -->
      <div class="application-details-section" id="details-<%= application.id %>" style="display: none;">
        <h4 class="section-title">
          <i class="fas fa-info-circle"></i>
          Application Details
        </h4>
        
        <div class="details-grid">
          <div class="detail-group">
            <h5>Property Information</h5>
            <div class="detail-items">
              <div class="detail-item">
                <span class="detail-label">Full Address:</span>
                <span class="detail-value"><%= application.address %></span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Property Value:</span>
                <span class="detail-value"><%= application.formatted_home_value %></span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Ownership Type:</span>
                <span class="detail-value"><%= application.ownership_status_display %></span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Property State:</span>
                <span class="detail-value"><%= application.property_state_display %></span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Existing Mortgage:</span>
                <span class="detail-value">
                  <% if application.has_existing_mortgage? %>
                    Yes - <%= application.formatted_existing_mortgage_amount %>
                  <% else %>
                    No existing mortgage
                  <% end %>
                </span>
              </div>
            </div>
          </div>

          <div class="detail-group">
            <h5>Additional Information</h5>
            <div class="detail-items">
              <div class="detail-item">
                <span class="detail-label">Borrower Age:</span>
                <span class="detail-value"><%= application.borrower_age %> years</span>
              </div>
              <% if application.borrower_names.present? %>
                <div class="detail-item">
                  <span class="detail-label">Borrower Names:</span>
                  <span class="detail-value"><%= application.borrower_names %></span>
                </div>
              <% end %>
              <% if application.mortgage.present? %>
                <div class="detail-item">
                  <span class="detail-label">Mortgage Product:</span>
                  <span class="detail-value"><%= application.mortgage.name %></span>
                </div>
              <% end %>
              <% if application.loan_term.present? %>
                <div class="detail-item">
                  <span class="detail-label">Loan Term:</span>
                  <span class="detail-value"><%= application.loan_term %> years</span>
                </div>
              <% end %>
              <% if application.income_payout_term.present? %>
                <div class="detail-item">
                  <span class="detail-label">Income Payout:</span>
                  <span class="detail-value"><%= application.income_payout_term %> years</span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Customer Checklist Section -->
      <%= render 'customer_checklist', application: application %>

      <!-- Messages Section -->
      <div class="application-messages-section" id="messages-<%= application.id %>" style="display: none;">
        <div class="messages-header">
          <h4 class="section-title">
            <i class="fas fa-comments"></i>
            Messages & Communication
          </h4>
          <div class="messages-actions">
            <button class="btn btn-sm btn-outline-secondary" 
                    data-action="click->application-messages#markAllAsRead"
                    data-application-id="<%= application.id %>">
              <i class="fas fa-check-double"></i> Mark All Read
            </button>
          </div>
        </div>

        <div class="messages-container">
          <% messages = application.message_threads %>
          <% if messages.any? %>
            <div class="message-threads">
              <% messages.each do |message| %>
                <div class="message-thread" data-message-id="<%= message.id %>">
                  <div class="message-header">
                    <div class="message-sender-info">
                      <% if message.from_ai_agent? && message.sender_avatar_path.present? %>
                        <div class="agent-avatar">
                          <%= image_tag message.sender_avatar_path, alt: "#{message.sender_name}", class: "avatar-img" %>
                        </div>
                      <% else %>
                        <div class="default-avatar">
                          <i class="fas fa-robot"></i>
                        </div>
                      <% end %>
                      
                      <div class="sender-details">
                        <div class="sender-name">
                          <strong><%= message.sender_name %></strong>
                          <% if message.from_ai_agent? %>
                            <span class="ai-badge">AI Assistant</span>
                          <% end %>
                        </div>
                        <div class="sender-role"><%= message.sender_role %></div>
                      </div>
                    </div>
                    
                    <div class="message-meta">
                      <span class="message-status status-<%= message.status %>">
                        <%= message.status.humanize %>
                      </span>
                      <time class="message-time">
                        <%= message.formatted_created_at %>
                      </time>
                    </div>
                  </div>
                  
                  <div class="message-content">
                    <h5 class="message-subject"><%= message.processed_subject %></h5>
                    <div class="message-body">
                      <%= message.content_html %>
                    </div>
                  </div>
                  
                  <!-- Replies -->
                  <% if message.replies.any? %>
                    <div class="message-replies">
                      <h6>Your Replies:</h6>
                      <% message.replies.each do |reply| %>
                        <div class="message-reply">
                          <div class="reply-header">
                            <strong>You</strong>
                            <time><%= reply.formatted_created_at %></time>
                          </div>
                          <div class="reply-content">
                            <%= reply.content_html %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  
                  <!-- Reply Form -->
                  <div class="reply-form-container" style="display: none;" id="reply-form-<%= message.id %>">
                    <%= form_with(
                      model: [application, ApplicationMessage.new], 
                      url: reply_to_message_application_path(application),
                      class: "reply-form",
                      data: { message_id: message.id }
                    ) do |form| %>
                      
                      <%= form.hidden_field :parent_message_id, value: message.id %>
                      
                      <div class="form-group">
                        <%= form.label :subject, class: "form-label" %>
                        <%= form.text_field :subject, value: "Re: #{message.subject}", required: true, class: "form-input" %>
                      </div>

                      <div class="form-group">
                        <%= form.label :content, "Your Reply", class: "form-label" %>
                        <%= form.text_area :content, rows: 4, required: true, class: "form-textarea", 
                                           placeholder: "Type your reply here..." %>
                      </div>

                      <div class="form-actions">
                        <%= form.submit "Send Reply", class: "btn site-btn-primary" %>
                        <button type="button" class="btn site-btn-secondary" 
                                data-action="click->application-messages#hideReplyForm"
                                data-message-id="<%= message.id %>">
                          Cancel
                        </button>
                      </div>
                    <% end %>
                  </div>
                  
                  <div class="message-actions">
                    <button class="btn btn-sm site-btn-primary" 
                            data-action="click->application-messages#showReplyForm"
                            data-message-id="<%= message.id %>">
                      <i class="fas fa-reply"></i> Reply
                    </button>
                    <% unless message.read? %>
                      <button class="btn btn-sm btn-outline-secondary" 
                              data-action="click->application-messages#markAsRead"
                              data-message-id="<%= message.id %>">
                        <i class="fas fa-check"></i> Mark as Read
                      </button>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="empty-messages-state">
              <div class="empty-icon">📬</div>
              <h5>No messages yet</h5>
              <p>When Futureproof sends you messages about this application, they will appear here.</p>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  <% end %>
</div>

