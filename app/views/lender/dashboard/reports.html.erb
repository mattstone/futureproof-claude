<% content_for :page_title, "Reports" %>

<div class="reports-page">
  <div class="page-header">
    <h1>Portfolio Reports & Analytics</h1>
  </div>

  <!-- Key Performance Indicators -->
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-label">Approval Rate</div>
      <div class="kpi-value"><%= @performance[:approval_rate] %>%</div>
      <div class="kpi-bar">
        <div class="kpi-fill" style="width: <%= @performance[:approval_rate] %>%"></div>
      </div>
      <div class="kpi-detail">
        <% approved = Application.where(lender_id: @current_lender.id).where("status IN (?)", [:accepted, :activated]).count %>
        <%= approved %> of <%= @applications.count %> applications
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-label">Activation Rate</div>
      <div class="kpi-value"><%= @performance[:activation_rate] %>%</div>
      <div class="kpi-bar">
        <div class="kpi-fill" style="width: <%= @performance[:activation_rate] %>%"></div>
      </div>
      <div class="kpi-detail">
        <% activated = Application.where(lender_id: @current_lender.id, status: :activated).count %>
        <%= activated %> of <%= Application.where(lender_id: @current_lender.id, status: :accepted).count %> approved
      </div>
    </div>

    <div class="kpi-card">
      <div class="kpi-label">Avg Time to Approval</div>
      <div class="kpi-value"><%= @performance[:avg_time_to_approval] %> <span class="kpi-unit">days</span></div>
      <div class="kpi-bar">
        <div class="kpi-fill" style="width: <%= [@performance[:avg_time_to_approval] / 30 * 100, 100].min %>%"></div>
      </div>
      <div class="kpi-detail">From submission to approval</div>
    </div>

    <div class="kpi-card">
      <div class="kpi-label">Avg Portfolio Yield</div>
      <div class="kpi-value"><%= @performance[:avg_portfolio_yield] %>%</div>
      <div class="kpi-bar">
        <div class="kpi-fill" style="width: <%= [@performance[:avg_portfolio_yield] / 10 * 100, 100].min %>%"></div>
      </div>
      <div class="kpi-detail">Average annual interest rate</div>
    </div>
  </div>

  <!-- Portfolio Metrics -->
  <div class="metrics-section">
    <h2>Portfolio Overview</h2>
    <div class="metrics-grid">
      <div class="metric-box">
        <div class="metric-icon">💰</div>
        <div class="metric-content">
          <div class="metric-title">Total Loan Amount</div>
          <div class="metric-amount">
            $<%= number_with_precision(@portfolio[:total_loan_amount], precision: 0, delimiter: ',') %>
          </div>
          <div class="metric-subtitle">Outstanding principal</div>
        </div>
      </div>

      <div class="metric-box">
        <div class="metric-icon">📊</div>
        <div class="metric-content">
          <div class="metric-title">Active Loans</div>
          <div class="metric-amount"><%= @portfolio[:total_active_loans] %></div>
          <div class="metric-subtitle">Loans in distribution phase</div>
        </div>
      </div>

      <div class="metric-box">
        <div class="metric-icon">💸</div>
        <div class="metric-content">
          <div class="metric-title">Total Distributed</div>
          <div class="metric-amount">
            $<%= number_with_precision(@portfolio[:total_distributed], precision: 0, delimiter: ',') %>
          </div>
          <div class="metric-subtitle">Income paid to borrowers</div>
        </div>
      </div>

      <div class="metric-box">
        <div class="metric-icon">🏠</div>
        <div class="metric-content">
          <div class="metric-title">Avg Property Value</div>
          <div class="metric-amount">
            $<%= number_with_precision(@portfolio[:average_property_value], precision: 0, delimiter: ',') %>
          </div>
          <div class="metric-subtitle">Across portfolio</div>
        </div>
      </div>

      <div class="metric-box">
        <div class="metric-icon">📈</div>
        <div class="metric-content">
          <div class="metric-title">Average LTV</div>
          <div class="metric-amount"><%= number_with_precision(@portfolio[:average_ltv] * 100, precision: 1) %>%</div>
          <div class="metric-subtitle">Loan-to-value ratio</div>
        </div>
      </div>

      <div class="metric-box">
        <div class="metric-icon">⚖️</div>
        <div class="metric-content">
          <div class="metric-title">Total Applications</div>
          <div class="metric-amount"><%= @applications.count %></div>
          <div class="metric-subtitle">In all statuses</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Portfolio by Status -->
  <div class="section">
    <h2>Applications by Status</h2>
    <div class="status-breakdown">
      <% statuses = [{name: 'Processing', status: 'processing', color: '#F59E0B'}, {name: 'Approved', status: 'accepted', color: '#3B82F6'}, {name: 'Active', status: 'activated', color: '#10B981'}, {name: 'Rejected', status: 'rejected', color: '#EF4444'}] %>
      
      <% statuses.each do |s| %>
        <% count = @applications.where(status: s[:status]).count %>
        <% percentage = @applications.any? ? (count.to_f / @applications.count * 100).round(1) : 0 %>
        <div class="status-item">
          <div class="status-info">
            <div class="status-name"><%= s[:name] %></div>
            <div class="status-count"><%= count %> applications</div>
          </div>
          <div class="status-bar">
            <div class="status-fill" style="width: <%= percentage %>%; background: <%= s[:color] %>;"></div>
          </div>
          <div class="status-percent"><%= percentage %>%</div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Property Distribution by LTV -->
  <div class="section">
    <h2>Portfolio LTV Distribution</h2>
    <div class="ltv-breakdown">
      <% ltv_ranges = [{range: '< 50%', min: 0, max: 0.5}, {range: '50-60%', min: 0.5, max: 0.6}, {range: '60-70%', min: 0.6, max: 0.7}, {range: '> 70%', min: 0.7, max: 1.0}] %>
      
      <% ltv_ranges.each do |range| %>
        <% count = @applications.where(status: :activated).select { |a| a.ltv_ratio >= range[:min] && a.ltv_ratio < range[:max] }.count %>
        <% active_count = @applications.where(status: :activated).count %>
        <% percentage = active_count > 0 ? (count.to_f / active_count * 100).round(1) : 0 %>
        
        <div class="ltv-item">
          <div class="ltv-range"><%= range[:range] %></div>
          <div class="ltv-bar">
            <div class="ltv-fill" style="width: <%= percentage %>%;"></div>
          </div>
          <div class="ltv-stats">
            <span class="ltv-count"><%= count %> loans</span>
            <span class="ltv-percent"><%= percentage %>%</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Export Section -->
  <div class="section export-section">
    <h2>Export Reports</h2>
    <div class="export-buttons">
      <button class="btn btn-secondary" onclick="exportReportCSV()">📥 Download as CSV</button>
      <button class="btn btn-secondary" onclick="exportReportPDF()">📄 Download as PDF</button>
      <button class="btn btn-secondary" onclick="printReport()">🖨️ Print</button>
    </div>
  </div>
</div>

<script>
function exportReportCSV() {
  alert('CSV export coming soon')
}

function exportReportPDF() {
  alert('PDF export coming soon')
}

function printReport() {
  window.print()
}
</script>

<style>
