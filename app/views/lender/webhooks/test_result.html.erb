<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900">Webhook Test</h1>
        <p class="text-slate-600 mt-2 font-mono text-sm"><%= @webhook.url %></p>
      </div>
      <%= link_to "← Back to Webhooks", lender_dashboard_webhooks_path, class: "btn btn-outline" %>
    </div>

    <!-- Status Badge -->
    <div class="mb-8">
      <% if @test_result[:success] %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-green-900">Webhook Test Successful</h3>
              <p class="text-green-800 mt-2">HTTP <%= @test_result[:status_code] %> — Your endpoint received and accepted the test payload</p>
            </div>
          </div>
        </div>
      <% else %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <svg class="w-6 h-6 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-red-900">Webhook Test Failed</h3>
              <p class="text-red-800 mt-2"><%= @test_result[:error] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Request Details -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <!-- Request -->
      <div class="bg-white rounded-lg border border-slate-200 p-6">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Request</h3>
        
        <div class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">URL</label>
            <code class="bg-slate-100 text-slate-900 text-xs p-3 rounded block break-all">
              <%= @test_result[:request_url] %>
            </code>
          </div>

          <div>
            <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">Headers</label>
            <div class="bg-slate-50 p-3 rounded text-xs space-y-2 font-mono">
              <div>Content-Type: <span class="text-blue-600">application/json</span></div>
              <div>X-Webhook-Event: <span class="text-blue-600">test</span></div>
              <div class="break-all">
                X-Webhook-Signature: <span class="text-blue-600"><%= @test_result[:signature][0..40] %>...</span>
              </div>
            </div>
          </div>

          <div>
            <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">Payload</label>
            <pre class="bg-slate-50 p-3 rounded text-xs overflow-auto max-h-48"><%= JSON.pretty_generate(@test_result[:payload]) %></pre>
          </div>
        </div>
      </div>

      <!-- Response -->
      <div class="bg-white rounded-lg border border-slate-200 p-6">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Response</h3>

        <div class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">Status Code</label>
            <div class="text-2xl font-bold <%= @test_result[:success] ? 'text-green-600' : 'text-red-600' %>">
              <%= @test_result[:status_code] || 'Error' %>
            </div>
          </div>

          <% if @test_result[:headers].present? %>
            <div>
              <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">Response Headers</label>
              <div class="bg-slate-50 p-3 rounded text-xs space-y-1 font-mono max-h-24 overflow-auto">
                <% @test_result[:headers].each do |key, value| %>
                  <div><span class="text-slate-600"><%= key %>:</span> <span class="text-blue-600"><%= value.first %></span></div>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @test_result[:body].present? %>
            <div>
              <label class="text-xs font-semibold text-slate-600 uppercase mb-1 block">Response Body</label>
              <pre class="bg-slate-50 p-3 rounded text-xs overflow-auto max-h-48"><%= @test_result[:body] %></pre>
            </div>
          <% elsif @test_result[:error] %>
            <div>
              <label class="text-xs font-semibold text-red-600 uppercase mb-1 block">Error</label>
              <pre class="bg-red-50 p-3 rounded text-xs overflow-auto text-red-700"><%= @test_result[:error] %></pre>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Signature Verification -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h3 class="font-semibold text-blue-900 mb-3">Webhook Signature Verification</h3>
      <p class="text-blue-800 text-sm mb-3">To verify this webhook, check the X-Webhook-Signature header against HMAC-SHA256 of the payload using your webhook secret:</p>
      <div class="bg-white p-3 rounded border border-blue-200 font-mono text-xs mb-3 break-all">
        <span class="text-slate-600">OpenSSL::HMAC.hexdigest('sha256', your_secret, payload) == </span><span class="text-blue-600">'<%= @test_result[:signature] %>'</span>
      </div>
      <p class="text-blue-700 text-xs">
        Your webhook secret: <code class="bg-white px-2 py-1 rounded"><%= @webhook.secret[0..20] %>...</code>
      </p>
    </div>

    <!-- Copy Payload Button -->
    <div class="flex gap-3">
      <button onclick="copyToClipboard('<%= j JSON.generate(@test_result[:payload]) %>')" class="btn btn-primary">
        Copy Payload as JSON
      </button>
      <%= link_to "Test Again", test_lender_dashboard_webhook_path(@webhook), method: :post, class: "btn btn-outline" %>
      <%= link_to "Delivery Logs", delivery_log_lender_dashboard_webhook_path(@webhook), class: "btn btn-outline" %>
    </div>
  </div>
</div>

<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(() => {
    alert('Payload copied to clipboard');
  });
}
</script>
