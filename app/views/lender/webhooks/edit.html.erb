<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Edit Webhook</h1>
      <p class="text-slate-600 mt-2 font-mono text-sm"><%= @webhook.url %></p>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-8 mb-8">
      <%= render "form", webhook: @webhook %>
    </div>

    <!-- Secret Display -->
    <div class="bg-blue-50 rounded-lg border border-blue-200 p-6">
      <h3 class="font-semibold text-blue-900 mb-3">Webhook Secret</h3>
      <p class="text-sm text-blue-800 mb-3">Use this secret to verify webhook signatures on your endpoint</p>
      <div class="bg-white rounded border border-blue-200 p-3 font-mono text-xs text-slate-700 break-all select-all">
        <%= @webhook.secret %>
      </div>
      <p class="text-xs text-blue-700 mt-2">
        <%= button_to "Copy Secret", "#", onclick: "navigator.clipboard.writeText('#{@webhook.secret}')", class: "text-blue-600 hover:underline", form: false %>
      </p>
    </div>
  </div>
</div>
