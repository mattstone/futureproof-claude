<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Create Webhook</h1>
      <p class="text-slate-600 mt-2">Register a new webhook endpoint to receive real-time notifications</p>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-8">
      <%= render "form", webhook: @webhook %>
    </div>
  </div>
</div>
