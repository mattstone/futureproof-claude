<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900">Test Webhook</h1>
        <p class="text-slate-600 mt-2 font-mono text-sm"><%= @webhook.url %></p>
      </div>
      <%= link_to "← Back to Webhooks", lender_dashboard_webhooks_path, class: "btn btn-outline" %>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-8">
      <p class="text-slate-600 mb-6">
        Click below to send a test webhook payload to your endpoint. This will help you verify that your endpoint is correctly configured and can receive webhooks.
      </p>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <p class="text-sm text-blue-800">
          <strong>What happens:</strong>
          <ul class="list-disc list-inside mt-2 space-y-1 text-blue-700">
            <li>A test payload is sent to your webhook URL</li>
            <li>Includes a valid X-Webhook-Signature header</li>
            <li>Your endpoint receives and processes it</li>
            <li>Response details are shown on the next page</li>
          </ul>
        </p>
      </div>

      <div class="space-y-4 mb-6">
        <div>
          <h3 class="font-semibold text-slate-900 mb-2">Webhook Endpoint</h3>
          <code class="bg-slate-100 px-3 py-2 rounded text-sm text-slate-700 block break-all"><%= @webhook.url %></code>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-2">Subscribed Events</h3>
          <div class="flex flex-wrap gap-2">
            <% @webhook.events.each do |event| %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                <%= event %>
              </span>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="font-semibold text-slate-900 mb-2">Status</h3>
          <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium <%= @webhook.active? ? 'bg-green-100 text-green-800' : 'bg-slate-100 text-slate-700' %>">
            <span class="w-2 h-2 rounded-full <%= @webhook.active? ? 'bg-green-600' : 'bg-slate-400' %>"></span>
            <%= @webhook.active? ? 'Active' : 'Inactive' %>
          </span>
        </div>
      </div>

      <div class="flex gap-3">
        <%= button_to "Send Test Webhook", test_lender_dashboard_webhook_path(@webhook), method: :post, class: "btn btn-primary" %>
        <%= link_to "Cancel", lender_dashboard_webhooks_path, class: "btn btn-outline" %>
      </div>
    </div>
  </div>
</div>
