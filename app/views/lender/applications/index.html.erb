<div class="lender-dashboard">
  <div class="dashboard-header">
    <h1>Lender Dashboard</h1>
    <p class="subtitle"><%= current_user.lender.name %></p>
  </div>

  <!-- Broker Filter -->
  <div class="broker-filter-section">
    <%= form_with url: lender_applications_path, method: :get, local: true do |f| %>
      <div class="filter-group">
        <label for="broker_id">Filter by Broker:</label>
        <%= f.select :broker_id, 
            options_for_select([["All Brokers", ""]] + @available_brokers.map { |b| [b.name, b.id] }, @selected_broker&.id),
            { include_blank: false },
            class: "broker-select" %>
        <%= submit_tag "Filter", class: "btn btn-secondary" %>
        <% if @selected_broker %>
          <%= link_to "Clear Filter", lender_applications_path, class: "btn btn-outline" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Stats Cards -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value"><%= @stats[:pending_count] %></div>
      <div class="stat-label">Pending Applications</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= @stats[:approved_count] %></div>
      <div class="stat-label">Approved Loans</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= @stats[:rejected_count] %></div>
      <div class="stat-label">Rejected Applications</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= number_to_currency(@stats[:total_portfolio_value], unit: '$') %></div>
      <div class="stat-label">Total Portfolio Value</div>
    </div>
  </div>

  <!-- Top Broker Performance -->
  <% if @top_brokers.any? %>
    <div class="broker-performance-section">
      <h2>Top Performing Brokers</h2>
      <div class="broker-cards-grid">
        <% @top_brokers.each do |metrics| %>
          <div class="broker-card">
            <div class="broker-name"><%= metrics[:broker_name] %></div>
            <div class="broker-metrics">
              <div class="metric">
                <span class="metric-label">Applications:</span>
                <span class="metric-value"><%= metrics[:applications_sourced] %></span>
              </div>
              <div class="metric">
                <span class="metric-label">Conversion Rate:</span>
                <span class="metric-value"><%= number_to_percentage(metrics[:conversion_rate], precision: 1) %></span>
              </div>
              <div class="metric">
                <span class="metric-label">Total Loan Value:</span>
                <span class="metric-value"><%= number_to_currency(metrics[:total_loan_value], unit: '$') %></span>
              </div>
              <div class="metric">
                <span class="metric-label">Avg Deal:</span>
                <span class="metric-value"><%= number_to_currency(metrics[:average_deal_size], unit: '$') %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Pending Applications Section -->
  <div class="applications-section">
    <h2>
      <span class="badge badge-pending"><%= @stats[:pending_count] %></span>
      Pending Applications
    </h2>

    <% if @pending_applications.any? %>
      <table class="applications-table">
        <thead>
          <tr>
            <th>Applicant</th>
            <th>Broker</th>
            <th>Property Value</th>
            <th>Requested Income</th>
            <th>Loan Term</th>
            <th>Applied</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @pending_applications.each do |app| %>
            <tr class="application-row">
              <td>
                <strong><%= link_to app.user.full_name, lender_application_path(app) %></strong>
                <br>
                <small><%= app.user.email %></small>
              </td>
              <td>
                <% if app.broker %>
                  <span class="broker-badge"><%= app.broker.name %></span>
                <% else %>
                  <span class="text-muted">Direct</span>
                <% end %>
              </td>
              <td><%= number_to_currency(app.home_value) %></td>
              <td>
                <%= number_to_currency(app.income_payout_term.to_f * 12 * 1000) %>
                <span class="text-small">/month</span>
              </td>
              <td><%= app.loan_term %> years</td>
              <td><small><%= time_ago_in_words(app.created_at) %> ago</small></td>
              <td>
                <%= link_to "Review", lender_application_path(app), class: "btn btn-primary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <p>No pending applications</p>
      </div>
    <% end %>
  </div>

  <!-- Recently Approved Section -->
  <div class="applications-section">
    <h2>
      <span class="badge badge-approved"><%= @stats[:approved_count] %></span>
      Recently Approved
    </h2>

    <% if @approved_applications.any? %>
      <table class="applications-table applications-table-compact">
        <thead>
          <tr>
            <th>Applicant</th>
            <th>Loan Amount</th>
            <th>Interest Rate</th>
            <th>Approved</th>
          </tr>
        </thead>
        <tbody>
          <% @approved_applications.each do |app| %>
            <tr class="application-row">
              <td>
                <strong><%= link_to app.user.full_name, lender_application_path(app) %></strong>
              </td>
              <td><%= number_to_currency(app.approved_loan_amount) %></td>
              <td><%= number_to_percentage(app.approved_interest_rate) %></td>
              <td><small><%= time_ago_in_words(app.updated_at) %> ago</small></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <p>No approved applications</p>
      </div>
    <% end %>
  </div>

  <!-- Recently Rejected Section -->
  <% if @rejected_applications.any? %>
    <div class="applications-section">
      <h2>
        <span class="badge badge-rejected"><%= @stats[:rejected_count] %></span>
        Recently Rejected
      </h2>

      <table class="applications-table applications-table-compact">
        <thead>
          <tr>
            <th>Applicant</th>
            <th>Reason</th>
            <th>Rejected</th>
          </tr>
        </thead>
        <tbody>
          <% @rejected_applications.each do |app| %>
            <tr class="application-row">
              <td>
                <strong><%= app.user.full_name %></strong>
              </td>
              <td><span class="text-muted"><%= app.rejected_reason %></span></td>
              <td><small><%= time_ago_in_words(app.updated_at) %> ago</small></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<style>
  .lender-dashboard {
    padding: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .dashboard-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border, #e0e0e0);
    padding-bottom: 1rem;
  }

  .dashboard-header h1 {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
  }

  .subtitle {
    margin: 0.5rem 0 0 0;
    color: var(--color-text-secondary, #666);
  }

  .broker-filter-section {
    background: white;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .filter-group label {
    font-weight: 600;
    color: var(--color-text, #333);
  }

  .broker-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: white;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary, #0066cc);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #666);
  }

  .broker-performance-section {
    margin-bottom: 2rem;
    background: white;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .broker-performance-section h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .broker-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .broker-card {
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 1rem;
    background: var(--color-background, #f9f9f9);
  }

  .broker-name {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary, #0066cc);
  }

  .broker-metrics {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
  }

  .metric-label {
    color: var(--color-text-secondary, #666);
  }

  .metric-value {
    font-weight: 600;
    color: var(--color-text, #333);
  }

  .broker-badge {
    display: inline-block;
    background-color: #e3f2fd;
    color: #1976d2;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .applications-section {
    margin-bottom: 2rem;
    background: white;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .applications-section h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.25rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
  }

  .badge-pending {
    background-color: #ff9800;
  }

  .badge-approved {
    background-color: #4caf50;
  }

  .badge-rejected {
    background-color: #f44336;
  }

  .applications-table {
    width: 100%;
    border-collapse: collapse;
  }

  .applications-table thead {
    background-color: var(--color-background, #f5f5f5);
  }

  .applications-table th {
    text-align: left;
    padding: 0.75rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #666);
    border-bottom: 2px solid var(--color-border, #e0e0e0);
  }

  .applications-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-border, #e0e0e0);
  }

  .application-row:hover {
    background-color: var(--color-background, #f9f9f9);
  }

  .applications-table-compact {
    font-size: 0.9rem;
  }

  .applications-table-compact th,
  .applications-table-compact td {
    padding: 0.5rem 0.75rem;
  }

  .empty-state {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-secondary, #999);
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .btn-primary {
    background-color: var(--color-primary, #0066cc);
    color: white;
  }

  .btn-primary:hover {
    background-color: var(--color-primary-dark, #0052a3);
  }

  .btn-secondary {
    background-color: var(--color-secondary, #6c757d);
    color: white;
  }

  .btn-secondary:hover {
    background-color: var(--color-secondary-dark, #5a6268);
  }

  .btn-outline {
    background-color: transparent;
    color: var(--color-primary, #0066cc);
    border: 1px solid var(--color-primary, #0066cc);
  }

  .btn-outline:hover {
    background-color: var(--color-primary, #0066cc);
    color: white;
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.8rem;
  }

  .text-small {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #666);
  }

  .text-muted {
    color: var(--color-text-secondary, #999);
  }
</style>
