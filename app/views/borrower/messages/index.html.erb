<div class="borrower-detail messages-container">
  <div class="detail-header">
    <%= link_to "← Back to Loan", borrower_application_path(@application), class: "back-link" %>
    <h1>Messages with <%= @application.lender&.company_name || "Lender" %></h1>
    <% if @unread_count > 0 %>
      <div class="unread-badge" data-unread-count><%= @unread_count %> unread</div>
    <% end %>
  </div>

  <!-- Message Thread -->
  <div class="messages-thread">
    <div class="messages-list" id="message-list" data-application-id="<%= @application.id %>">
      <% if @messages.any? %>
        <% @messages.each do |msg| %>
          <div class="message-item message-from-<%= msg.sender_type %>" 
               data-message-id="<%= msg.id %>"
               data-unread="<%= msg.read_at.nil? && msg.from_lender? %>">
            <div class="message-avatar">
              <% if msg.from_borrower? %>
                <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= current_user.full_name %>" 
                     alt="<%= current_user.full_name %>" class="avatar-img">
              <% else %>
                <img src="https://api.dicebear.com/7.x/initials/svg?seed=<%= @application.lender&.company_name %>" 
                     alt="<%= @application.lender&.company_name %>" class="avatar-img">
              <% end %>
            </div>
            <div class="message-content">
              <div class="message-header">
                <span class="sender-name">
                  <% if msg.from_borrower? %>
                    You
                  <% else %>
                    <%= @application.lender&.company_name || "Lender" %>
                  <% end %>
                </span>
                <span class="message-time" title="<%= msg.created_at.strftime('%B %d, %Y at %l:%M %p') %>">
                  <%= msg.created_at.strftime('%H:%M %p') %>
                </span>
              </div>
              <div class="message-text">
                <%= simple_format(msg.message) %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-messages">
          <p>No messages yet. Send a message to start a conversation with your lender.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Message Input -->
  <div class="message-form-section">
    <h2>Send a Message</h2>
    
    <form id="message-form" class="message-form">
      <div class="form-group">
        <label for="message" class="form-label">Your Message</label>
        <textarea id="message" name="message" 
                  rows="4"
                  placeholder="Type your message here... (max 5000 characters)"
                  class="form-textarea"
                  maxlength="5000"
                  required></textarea>
        <div class="char-count"><span id="char-count">0</span> / 5000</div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Send Message</button>
        <%= link_to "Cancel", borrower_application_path(@application), class: "btn btn-secondary" %>
      </div>
    </form>
  </div>

  <!-- Info Box -->
  <div class="info-section">
    <h3>💬 Live Messaging</h3>
    <ul>
      <li>✓ Messages appear instantly in real-time</li>
      <li>✓ Unread messages are automatically marked as read</li>
      <li>✓ Be clear and specific about your question</li>
      <li>✓ Include relevant dates or transaction numbers if applicable</li>
      <li>✓ Typically receive a response within 1 business day</li>
      <li>⚡ For urgent matters, call our support team</li>
    </ul>
  </div>
</div>

<style>
  .borrower-detail.messages-container {
    padding: 0;
  }

  .detail-header {
    margin-bottom: 30px;
    position: relative;
  }

  .back-link {
    color: #2196F3;
    text-decoration: none;
    font-size: 13px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .detail-header h1 {
    font-size: 28px;
    margin: 0 0 8px 0;
    color: #333;
  }

  .unread-badge {
    display: inline-block;
    background: #FF5722;
    color: white;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: bold;
    margin-top: 8px;
  }

  .unread-badge.pulse {
    animation: pulse-badge 0.6s ease-in-out;
  }

  @keyframes pulse-badge {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .messages-thread {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 30px;
    max-height: 500px;
    overflow-y: auto;
    min-height: 300px;
  }

  .messages-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .message-item {
    display: flex;
    gap: 12px;
    animation: slide-in 0.3s ease-out;
  }

  @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .message-from-borrower {
    flex-direction: row-reverse;
  }

  .message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .message-content {
    flex: 1;
    max-width: 70%;
  }

  .message-from-borrower .message-content {
    text-align: right;
  }

  .message-header {
    display: flex;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 13px;
  }

  .message-from-borrower .message-header {
    flex-direction: row-reverse;
  }

  .sender-name {
    font-weight: bold;
    color: #333;
  }

  .message-time {
    color: #999;
    font-size: 12px;
  }

  .message-text {
    background: #f0f0f0;
    padding: 12px 16px;
    border-radius: 12px;
    word-break: break-word;
    line-height: 1.5;
    color: #333;
  }

  .message-from-borrower .message-text {
    background: #2196F3;
    color: white;
  }

  .empty-messages {
    text-align: center;
    padding: 40px 20px;
    color: #999;
  }

  .message-form-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 30px;
  }

  .message-form-section h2 {
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-label {
    display: block;
    font-weight: bold;
    margin-bottom: 8px;
    color: #333;
    font-size: 14px;
  }

  .form-textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    resize: vertical;
    box-sizing: border-box;
  }

  .form-textarea:focus {
    outline: none;
    border-color: #2196F3;
    box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.1);
  }

  .char-count {
    font-size: 12px;
    color: #999;
    margin-top: 6px;
    text-align: right;
  }

  .char-count.warning {
    color: #FF9800;
    font-weight: bold;
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .btn {
    padding: 12px 24px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #2196F3;
    color: white;
  }

  .btn-primary:hover {
    background: #1976D2;
  }

  .btn-secondary {
    background: #f0f0f0;
    color: #333;
  }

  .btn-secondary:hover {
    background: #e0e0e0;
  }

  .info-section {
    background: #E3F2FD;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #BBDEFB;
  }

  .info-section h3 {
    margin: 0 0 12px 0;
    font-size: 16px;
    color: #1F2937;
  }

  .info-section ul {
    margin: 0;
    padding-left: 20px;
    list-style: none;
  }

  .info-section li {
    margin-bottom: 8px;
    font-size: 13px;
    color: #333;
  }
</style>
