<div class="borrower-detail">
  <div class="detail-header">
    <%= link_to "← Back to Loans", borrower_applications_path, class: "back-link" %>
    <h1>EPM Loan Details</h1>
  </div>

  <!-- Status & Quick Info -->
  <div class="detail-cards">
    <div class="detail-card status-card">
      <div class="card-label">Loan Status</div>
      <div class="card-status app-status-<%= @application.status %>">
        <%= @application.status.humanize %>
      </div>
      <div class="card-meta">
        Applied <%= time_ago_in_words(@application.created_at) %> ago
      </div>
    </div>

    <div class="detail-card">
      <div class="card-label">Equity Capital</div>
      <div class="card-value">$<%= number_with_precision(@loan_summary[:equity_amount], precision: 0) %></div>
    </div>

    <div class="detail-card">
      <div class="card-label">Capital Received</div>
      <div class="card-value">$<%= number_with_precision(@loan_summary[:capital_received], precision: 0) %></div>
    </div>

    <div class="detail-card">
      <div class="card-label">Loan Term</div>
      <div class="card-value"><%= @loan_summary[:term_years] %> years</div>
    </div>

    <div class="detail-card">
      <div class="card-label">Property Value</div>
      <div class="card-value">$<%= number_with_precision(@loan_summary[:property_value], precision: 0) %></div>
    </div>

    <div class="detail-card">
      <div class="card-label">Your Equity %</div>
      <div class="card-value"><%= number_with_precision(@loan_summary[:equity_percentage], precision: 1) %>%</div>
    </div>


  </div>

  <!-- Loan Terms Summary -->
  <div class="terms-section">
    <h2>Loan Terms</h2>
    <div class="terms-details">
      <div class="term-item">
        <span class="term-label">Equity Capital</span>
        <span class="term-value">$<%= number_with_precision(@application.equity_investment_amount, precision: 0) %></span>
        <span class="term-desc">One-time capital received on loan activation</span>
      </div>
      <div class="term-item">
        <span class="term-label">Loan Term</span>
        <span class="term-value"><%= @application.participation_term_years %> years</span>
        <span class="term-desc">Duration of the equity partnership</span>
      </div>
      <div class="term-item">
        <span class="term-label">Your Equity %</span>
        <span class="term-value"><%= number_with_precision(@application.equity_percentage, precision: 1) %>%</span>
        <span class="term-desc">Your ownership stake in the property</span>
      </div>
      <div class="term-item">
        <span class="term-label">Property Value</span>
        <span class="term-value">$<%= number_with_precision(@application.home_value, precision: 0) %></span>
        <span class="term-desc">Appraised property value</span>
      </div>
    </div>
  </div>

  <!-- Capital Received -->
  <% if @application.status_activated? %>
    <div class="capital-section">
      <h2>Capital Received</h2>
      <div class="capital-status">
        <div class="status-badge status-completed">✓ Received</div>
        <div class="capital-amount">$<%= number_with_precision(@application.equity_investment_amount, precision: 2) %></div>
        <p class="capital-desc">Your equity capital was disbursed on <%= @application.updated_at&.strftime('%B %d, %Y') %></p>
      </div>
    </div>
  <% else %>
    <div class="capital-section">
      <h2>Capital Pending</h2>
      <div class="capital-status">
        <div class="status-badge status-pending">Pending</div>
        <p class="capital-desc">Your loan must be activated before capital is disbursed. Current status: <strong><%= @application.status.humanize %></strong></p>
      </div>
    </div>
  <% end %>

  <!-- Contract & Documents -->
  <div class="documents-section">
    <h2>Documents</h2>
    <div class="documents-list">
      <% if @contract %>
        <div class="document-item">
          <div class="doc-icon">📄</div>
          <div class="doc-info">
            <div class="doc-name">Loan Contract</div>
            <div class="doc-meta">Created <%= time_ago_in_words(@contract.created_at) %> ago</div>
          </div>
          <div class="doc-actions">
            <%= link_to "View Contract", "#", class: "btn btn-secondary", title: "Download contract PDF" %>
          </div>
        </div>
      <% else %>
        <p>No contract available yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Lender Info -->
  <% if @lender %>
    <div class="lender-section">
      <h2>Lender Information</h2>
      <div class="lender-card">
        <div class="lender-name"><%= @lender.name %></div>
        <div class="lender-details">
          <div class="detail">
            <span class="label">Address:</span>
            <span class="value"><%= @lender.address %> <%= @lender.postcode %></span>
          </div>
          <div class="detail">
            <span class="label">Contact:</span>
            <span class="value"><%= link_to @lender.contact_email, "mailto:#{@lender.contact_email}" %></span>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  .borrower-detail {
    padding: 0;
  }

  .detail-header {
    margin-bottom: 30px;
  }

  .back-link {
    color: #2196F3;
    text-decoration: none;
    font-size: 13px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .detail-header h1 {
    font-size: 28px;
    margin: 0;
    color: #333;
  }

  .detail-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }

  .detail-card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }

  .detail-card.status-card {
    grid-column: span 1;
  }

  /* Loan Terms */
  .terms-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 40px;
  }

  .terms-section h2 {
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .terms-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .term-item {
    padding: 16px;
    background: #f8f9fa;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .term-label {
    font-size: 11px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .term-value {
    font-size: 20px;
    font-weight: 600;
    color: #333;
  }

  .term-desc {
    font-size: 12px;
    color: #999;
    line-height: 1.4;
  }

  /* Capital Received */
  .capital-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 2px solid #d4edda;
    margin-bottom: 40px;
  }

  .capital-section h2 {
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .capital-status {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px;
    background: #f9f9f9;
    border-radius: 6px;
    text-align: center;
  }

  .capital-amount {
    font-size: 32px;
    font-weight: 600;
    color: #2196F3;
  }

  .capital-desc {
    color: #666;
    font-size: 14px;
    margin: 0;
  }

  .card-label {
    font-size: 12px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .card-status {
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 8px;
  }

  .card-value {
    font-size: 24px;
    font-weight: 600;
    color: #333;
  }

  .card-meta {
    font-size: 12px;
    color: #999;
    margin-top: 4px;
  }

  .app-status-submitted,
  .app-status-processing {
    background: #fff3cd;
    color: #856404;
  }

  .app-status-accepted,
  .app-status-activated {
    background: #d4edda;
    color: #155724;
  }

  .app-status-rejected {
    background: #f8d7da;
    color: #721c24;
  }

  /* Payout Summary */
  .payout-summary-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 40px;
  }

  .payout-summary-section h2 {
    font-size: 16px;
    margin: 0 0 16px 0;
  }

  .payout-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .summary-label {
    color: #666;
    font-size: 14px;
  }

  .summary-value {
    font-size: 20px;
    font-weight: 600;
    color: #333;
  }

  /* Schedule Table */
  .schedule-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 40px;
  }

  .schedule-section h2 {
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .schedule-table {
    overflow-x: auto;
  }

  .schedule-table table {
    width: 100%;
    border-collapse: collapse;
  }

  .schedule-table th {
    text-align: left;
    padding: 12px;
    background: #f8f9fa;
    font-weight: 600;
    font-size: 12px;
    color: #666;
    text-transform: uppercase;
    border-bottom: 1px solid #e0e0e0;
  }

  .schedule-table td {
    padding: 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .payout-row.payout-completed {
    background: #f9f9f9;
  }

  .status-badge {
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    display: inline-block;
  }

  .status-completed {
    background: #d4edda;
    color: #155724;
  }

  .status-pending,
  .status-processing {
    background: #fff3cd;
    color: #856404;
  }

  .empty-schedule {
    color: #999;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  .payout-summary-section .summary-label {
    color: #666;
    font-size: 14px;
  }

  .payout-summary-section .summary-value {
    font-size: 20px;
    font-weight: 600;
    color: #333;
  }

  /* Documents */
  .documents-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    margin-bottom: 40px;
  }

  .documents-section h2 {
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .documents-list {
    display: grid;
    gap: 16px;
  }

  .document-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border: 1px solid #f0f0f0;
    border-radius: 6px;
  }

  .doc-icon {
    font-size: 24px;
  }

  .doc-info {
    flex: 1;
  }

  .doc-name {
    font-weight: 600;
    color: #333;
    margin-bottom: 4px;
  }

  .doc-meta {
    font-size: 12px;
    color: #999;
  }

  .doc-actions {
    display: flex;
    gap: 8px;
  }

  .btn {
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-secondary {
    background: #f0f0f0;
    color: #333;
  }

  .btn-secondary:hover {
    background: #e0e0e0;
  }

  /* Lender Info */
  .lender-section {
    background: white;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }

  .lender-section h2 {
    font-size: 16px;
    margin: 0 0 16px 0;
  }

  .lender-card {
    background: #f8f9fa;
    padding: 16px;
    border-radius: 6px;
  }

  .lender-name {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    margin-bottom: 12px;
  }

  .lender-details {
    display: grid;
    gap: 8px;
  }

  .detail {
    display: flex;
    gap: 12px;
    font-size: 14px;
  }

  .detail .label {
    color: #666;
    min-width: 80px;
  }

  .detail .value {
    color: #333;
    flex: 1;
  }

  .detail a {
    color: #2196F3;
    text-decoration: none;
  }

  .detail a:hover {
    text-decoration: underline;
  }
</style>
