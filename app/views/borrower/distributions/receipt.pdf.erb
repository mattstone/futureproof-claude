<html>
  <head>
    <style>
      body { font-family: Arial, sans-serif; color: #333; }
      .header { background: #059669; color: white; padding: 20px; text-align: center; }
      .header h1 { margin: 0; font-size: 24px; }
      .header p { margin: 5px 0 0 0; font-size: 14px; }
      .receipt-container { padding: 30px; }
      .receipt-section { margin-bottom: 25px; }
      .section-title { font-weight: bold; font-size: 14px; color: #1F2937; border-bottom: 2px solid #059669; padding-bottom: 8px; margin-bottom: 12px; }
      .detail-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #E5E7EB; }
      .detail-label { font-weight: bold; }
      .detail-value { text-align: right; }
      .amount { font-size: 18px; color: #059669; font-weight: bold; }
      .status-box { background: #F0FDF4; border-left: 4px solid #059669; padding: 15px; margin: 15px 0; }
      .status-label { font-weight: bold; color: #059669; }
      .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #E5E7EB; font-size: 12px; color: #6B7280; }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>Payment Receipt</h1>
      <p>Equity Partner Mortgage - Monthly Income Payment</p>
    </div>

    <div class="receipt-container">
      <div class="receipt-section">
        <div class="section-title">Receipt Details</div>
        <div class="detail-row">
          <span class="detail-label">Receipt #</span>
          <span class="detail-value">RCP-<%= @distribution.id.to_s.upcase %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Payment Date</span>
          <span class="detail-value"><%= @distribution.processed_at.strftime('%d %B %Y') %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Transaction ID</span>
          <span class="detail-value"><%= @distribution.transaction_id %></span>
        </div>
      </div>

      <div class="receipt-section">
        <div class="section-title">Borrower Information</div>
        <div class="detail-row">
          <span class="detail-label">Name</span>
          <span class="detail-value"><%= @distribution.application.user.full_name %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Property</span>
          <span class="detail-value"><%= @distribution.application.property_address %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Loan Agreement #</span>
          <span class="detail-value"><%= @distribution.application.id %></span>
        </div>
      </div>

      <div class="receipt-section">
        <div class="section-title">Payment Amount</div>
        <div class="detail-row">
          <span class="detail-label" style="font-size: 16px;">Amount Paid</span>
          <span class="detail-value amount">$<%= number_with_precision(@distribution.amount, precision: 2, delimiter: ',') %></span>
        </div>
        <div style="margin-top: 10px; padding: 10px; background: #F9FAFB; border-radius: 4px;">
          <p style="margin: 0; font-size: 12px;">This is a guaranteed monthly income payment from your Equity Partner Mortgage. Income is guaranteed and paid regardless of market conditions.</p>
        </div>
      </div>

      <div class="receipt-section">
        <div class="status-box">
          <div class="status-label">✓ Payment Confirmed</div>
          <p style="margin: 5px 0 0 0; font-size: 13px;">This payment has been successfully processed and deposited to your nominated bank account.</p>
        </div>
      </div>

      <div class="receipt-section">
        <div class="section-title">Payment Summary</div>
        <div class="detail-row">
          <span class="detail-label">Total Payments to Date</span>
          <span class="detail-value">$<%= number_with_precision(@distribution.application.distributions.where('processed_at <= ?', @distribution.processed_at).sum(:amount), precision: 2, delimiter: ',') %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Remaining Loan Balance</span>
          <span class="detail-value">$<%= number_with_precision(@distribution.application.loan_amount, precision: 2, delimiter: ',') %></span>
        </div>
      </div>

      <div class="footer">
        <p><strong>Important Information:</strong></p>
        <ul style="margin: 5px 0; padding-left: 20px;">
          <li>This income payment may be subject to income tax. Consult your accountant for tax treatment.</li>
          <li>Your guaranteed income is provided under your Equity Partner Mortgage Agreement.</li>
          <li>This receipt confirms payment but is not a legal document. Keep for your records.</li>
        </ul>
        
        <p style="margin-top: 15px;">
          <strong>Generated:</strong> <%= Time.current.strftime('%d %B %Y at %H:%M %Z') %><br>
          If you have questions about this payment, contact our support team.
        </p>
      </div>
    </div>
  </body>
</html>
