<!-- Verification Code Content -->
<div style="text-align: center; margin-bottom: 32px;">
  <h1 style="margin: 0; color: #6b7280; font-size: 20px; font-weight: 500;">Enter your 6-digit verification code</h1>
</div>

<!-- Verification Code Display -->
<table role="presentation" style="width: 100%; border-collapse: collapse; border: 0; border-spacing: 0; margin: 48px 0;">
  <tr>
    <td style="text-align: center;">
      <table role="presentation" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border: 2px solid #3b82f6; border-radius: 12px; padding: 40px 48px; margin: 0 auto; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);">
        <tr>
          <td style="text-align: center; padding: 32px 24px;">
            <div style="margin: 0; color: #1e40af; font-size: 48px; font-weight: 700; font-family: 'SF Mono', Consolas, 'Liberation Mono', Menlo, monospace; letter-spacing: 8px; text-align: center;">
              <%= @verification_code %>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Expiration Warning -->
<p style="text-align: center; color: #f59e0b; font-size: 14px; font-weight: 500; margin: 24px 0 0 0;">
  ⏱️ This code expires in 15 minutes
</p>