<div class="container-fluid py-4">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="breadcrumb-nav">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to 'Home', root_path %></li>
      <li class="breadcrumb-item active" aria-current="page">Support</li>
    </ol>
  </nav>

  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <!-- Chat Container -->
      <div class="card border-0 shadow-sm" style="height: 80vh; display: flex; flex-direction: column;">
        <!-- Header -->
        <div class="card-header text-white" style="background: linear-gradient(135deg, #1a5490 0%, #0066cc 100%);">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-0"><i class="bi bi-chat-dots-fill"></i> FutureProof Support</h5>
              <small style="opacity: 0.85;">24/7 AI-powered assistance</small>
            </div>
            <span class="badge bg-success"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> Online</span>
          </div>
        </div>

        <!-- Messages -->
        <div class="card-body" id="chat-messages" style="flex: 1; overflow-y: auto; background: #f8f9fa;">
          <% if @messages.empty? %>
            <!-- Welcome Message -->
            <div class="text-center py-4">
              <div style="font-size: 3rem; opacity: 0.3;"><i class="bi bi-headset"></i></div>
              <h5 class="mt-2">Welcome to FutureProof Support</h5>
              <p class="text-muted">Ask me anything about our Equity Preservation Mortgage.</p>

              <!-- Quick Actions -->
              <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="What is an EPM?">
                  What is an EPM?
                </button>
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="How does it work?">
                  How does it work?
                </button>
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="Am I eligible?">
                  Am I eligible?
                </button>
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="How is EPM different from a reverse mortgage?">
                  EPM vs Reverse Mortgage
                </button>
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="What documents do I need?">
                  Documents needed
                </button>
                <button class="btn btn-outline-primary btn-sm quick-question" data-question="How long does the process take?">
                  Timeline
                </button>
              </div>
            </div>
          <% else %>
            <% @messages.each do |msg| %>
              <div class="d-flex mb-3 <%= msg['role'] == 'user' ? 'justify-content-end' : 'justify-content-start' %>">
                <div style="max-width: 80%;">
                  <% if msg['role'] != 'user' %>
                    <small class="text-muted d-block mb-1"><strong>FutureProof Support</strong></small>
                  <% end %>
                  <div class="p-3 rounded-3 <%= msg['role'] == 'user' ? 'bg-primary text-white' : 'bg-white border' %>" style="word-wrap: break-word;">
                    <%= simple_format(msg['content']) %>
                  </div>
                  <small class="text-muted d-block mt-1 <%= msg['role'] == 'user' ? 'text-end' : '' %>">
                    <%= Time.parse(msg['timestamp']).strftime('%H:%M') rescue '' %>
                  </small>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <!-- Input -->
        <div class="card-footer bg-white border-top">
          <form id="support-chat-form" class="d-flex gap-2">
            <input type="hidden" name="region" value="<%= @region %>">
            <textarea
              id="support-message-input"
              name="message"
              class="form-control"
              placeholder="Type your question..."
              rows="1"
              maxlength="5000"
              required
              style="resize: none; overflow: hidden;"
              aria-label="Type your support question"
            ></textarea>
            <button type="submit" class="btn btn-primary" id="support-send-btn" aria-label="Send message">
              <i class="bi bi-send-fill"></i>
            </button>
          </form>
          <div class="d-flex justify-content-between mt-2">
            <small class="text-muted"><span id="char-count">0</span>/5000</small>
            <div>
              <%= link_to 'Clear Chat', support_clear_path(@region), method: :delete, class: 'btn btn-link btn-sm text-muted p-0', data: { confirm: 'Clear conversation?' } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Help Card -->
      <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
          <div class="row text-center">
            <div class="col-4">
              <i class="bi bi-envelope text-primary" style="font-size: 1.5rem;"></i>
              <p class="small mt-1 mb-0"><a href="mailto:support@futureproof.com.au" class="text-decoration-none">Email Us</a></p>
            </div>
            <div class="col-4">
              <i class="bi bi-telephone text-primary" style="font-size: 1.5rem;"></i>
              <p class="small mt-1 mb-0"><a href="tel:1300388873" class="text-decoration-none">1300 388 873</a></p>
            </div>
            <div class="col-4">
              <i class="bi bi-clock text-primary" style="font-size: 1.5rem;"></i>
              <p class="small mt-1 mb-0">24/7 AI Support</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('support-chat-form');
  const input = document.getElementById('support-message-input');
  const sendBtn = document.getElementById('support-send-btn');
  const messagesDiv = document.getElementById('chat-messages');
  const charCount = document.getElementById('char-count');
  const region = '<%= @region %>';

  // Auto-resize textarea
  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    charCount.textContent = this.value.length;
  });

  // Enter to send (Shift+Enter for newline)
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });

  // Quick question buttons
  document.querySelectorAll('.quick-question').forEach(function(btn) {
    btn.addEventListener('click', function() {
      input.value = this.dataset.question;
      form.dispatchEvent(new Event('submit'));
    });
  });

  // Send message
  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const message = input.value.trim();
    if (!message) return;

    sendBtn.disabled = true;
    sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    // Add user message to UI immediately
    addMessage('user', message);
    input.value = '';
    input.style.height = 'auto';
    charCount.textContent = '0';

    // Add typing indicator
    const typingId = addTypingIndicator();

    try {
      const csrfToken = document.querySelector('meta[name="csrf-token"]');
      const response = await fetch('/' + region + '/support/send_message', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken ? csrfToken.content : ''
        },
        body: JSON.stringify({ message: message, region: region })
      });

      const data = await response.json();

      // Remove typing indicator
      removeTypingIndicator(typingId);

      if (data.success !== false) {
        addMessage('assistant', data.assistant_message.content);

        if (data.escalate) {
          addSystemMessage('This conversation has been flagged for human review. A support team member will follow up within 1 business day.');
        }
      } else {
        addMessage('assistant', data.assistant_message?.content || 'Sorry, something went wrong. Please try again.');
      }
    } catch (error) {
      removeTypingIndicator(typingId);
      addMessage('assistant', 'Sorry, I couldn\'t connect. Please try again or contact support@futureproof.com.au');
    } finally {
      sendBtn.disabled = false;
      sendBtn.innerHTML = '<i class="bi bi-send-fill"></i>';
      input.focus();
    }
  });

  function addMessage(role, content) {
    const isUser = role === 'user';
    const div = document.createElement('div');
    div.className = 'd-flex mb-3 ' + (isUser ? 'justify-content-end' : 'justify-content-start');
    div.innerHTML = `
      <div style="max-width: 80%;">
        ${!isUser ? '<small class="text-muted d-block mb-1"><strong>FutureProof Support</strong></small>' : ''}
        <div class="p-3 rounded-3 ${isUser ? 'bg-primary text-white' : 'bg-white border'}" style="word-wrap: break-word;">
          ${escapeHtml(content)}
        </div>
        <small class="text-muted d-block mt-1 ${isUser ? 'text-end' : ''}">
          ${new Date().toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' })}
        </small>
      </div>
    `;
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
  }

  function addTypingIndicator() {
    const id = 'typing-' + Date.now();
    const div = document.createElement('div');
    div.id = id;
    div.className = 'd-flex mb-3 justify-content-start';
    div.innerHTML = `
      <div>
        <small class="text-muted d-block mb-1"><strong>FutureProof Support</strong></small>
        <div class="p-3 rounded-3 bg-white border">
          <span class="typing-dots">
            <span style="animation: blink 1.4s infinite 0s;">●</span>
            <span style="animation: blink 1.4s infinite 0.2s;">●</span>
            <span style="animation: blink 1.4s infinite 0.4s;">●</span>
          </span>
        </div>
      </div>
    `;
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
    return id;
  }

  function removeTypingIndicator(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  function addSystemMessage(content) {
    const div = document.createElement('div');
    div.className = 'text-center mb-3';
    div.innerHTML = `<small class="badge bg-warning text-dark">${escapeHtml(content)}</small>`;
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML.replace(/\n/g, '<br>');
  }

  // Scroll to bottom on load
  messagesDiv.scrollTop = messagesDiv.scrollHeight;
  input.focus();
});
</script>

<style>
  @keyframes blink {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }
  .typing-dots span {
    color: #999;
    font-size: 1.2rem;
  }
</style>
