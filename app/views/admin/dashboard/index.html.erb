<div class="admin-dashboard">
  <div class="dashboard-header">
    <h1>FutureProof Admin Dashboard</h1>
    <p class="subtitle">System health, portfolio metrics, lender analytics</p>
  </div>

  <!-- System Alerts -->
  <% if @alerts.any? %>
    <div class="alerts-section">
      <% @alerts.each do |alert| %>
        <div class="alert alert-<%= alert[:type] %>">
          <strong><%= alert[:type].to_s.titleize %>:</strong> <%= alert[:message] %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- System Health Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-label">Total Applications</div>
      <div class="metric-value"><%= @health[:total_applications] %></div>
      <div class="metric-detail">
        <span class="pending stat-count--warning"><%= @health[:pending_applications] %> pending</span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-label">Active Loans</div>
      <div class="metric-value stat-count--success"><%= @health[:active_loans] %></div>
      <div class="metric-detail">
        <span><strong>Portfolio Value:</strong> <%= number_to_currency(@portfolio[:total_active_portfolio_value], precision: 0) %></span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-label">Lenders</div>
      <div class="metric-value stat-count--info"><%= @health[:total_lenders] %></div>
      <div class="metric-detail">
        <span><strong>Webhooks:</strong> <%= @health[:active_webhooks] %> active</span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-label">Rejected</div>
      <div class="metric-value stat-count--danger"><%= @health[:rejected_applications] %></div>
      <div class="metric-detail">
        <span><strong>Failed Webhooks:</strong> <%= @health[:failed_webhooks] %></span>
      </div>
    </div>
  </div>

  <!-- Portfolio Overview -->
  <div class="section">
    <h2>Portfolio Overview</h2>
    <div class="portfolio-grid">
      <div class="portfolio-card">
        <div class="label">Total Active Portfolio Value</div>
        <div class="value"><%= number_to_currency(@portfolio[:total_active_portfolio_value], precision: 0) %></div>
      </div>
      <div class="portfolio-card">
        <div class="label">Total Distributions Paid</div>
        <div class="value"><%= number_to_currency(@portfolio[:total_distributions_paid], precision: 2) %></div>
      </div>
      <div class="portfolio-card">
        <div class="label">Average Loan Amount</div>
        <div class="value"><%= number_to_currency(@portfolio[:average_loan_amount], precision: 0) %></div>
      </div>
      <div class="portfolio-card">
        <div class="label">Average Loan Term</div>
        <div class="value"><%= number_with_precision(@portfolio[:average_loan_term]) %> years</div>
      </div>
    </div>
  </div>

  <!-- Top Lenders -->
  <div class="section">
    <h2>Top Performing Lenders</h2>
    <% if @top_lenders.any? %>
      <table class="lenders-table">
        <thead>
          <tr>
            <th>Lender</th>
            <th>Active Applications</th>
            <th>Portfolio Value</th>
            <th>Distribution Coverage</th>
          </tr>
        </thead>
        <tbody>
          <% @top_lenders.each do |lender| %>
            <tr>
              <td><strong><%= lender[:name] %></strong></td>
              <td><%= lender[:applications] %></td>
              <td><%= number_to_currency(lender[:portfolio_value], precision: 0) %></td>
              <td>
                <div class="progress-bar">
                  <div class="progress" style="width: <%= lender[:distribution_status][:percentage] %>%">
                    <%= number_with_precision(lender[:distribution_status][:percentage], precision: 1) %>%
                  </div>
                </div>
                <small><%= lender[:distribution_status][:with_distributions] %>/<%= lender[:distribution_status][:total_apps] %> with distributions</small>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="no-data">No active lenders with applications.</p>
    <% end %>
  </div>

  <!-- Monthly Payment Trend -->
  <div class="section">
    <h2>Monthly Payment Distribution</h2>
    <% if @monthly_payments.any? %>
      <table class="payments-table">
        <thead>
          <tr>
            <th>Month</th>
            <th>Count</th>
            <th>Total Amount</th>
          </tr>
        </thead>
        <tbody>
          <% @monthly_payments.each do |month| %>
            <tr>
              <td><strong><%= month[:month] %></strong></td>
              <td><%= month[:count] %> distributions</td>
              <td><%= number_to_currency(month[:total], precision: 2) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="no-data">No distributions processed yet.</p>
    <% end %>
  </div>

  <!-- Failed Webhooks Alert -->
  <% if @failed_webhooks.any? %>
    <div class="section alert-section">
      <h2>Failed Webhook Deliveries (Last 24h)</h2>
      <table class="webhooks-table">
        <thead>
          <tr>
            <th>Event</th>
            <th>URL</th>
            <th>Response Code</th>
            <th>Failed At</th>
            <th>Retries</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @failed_webhooks.each do |webhook| %>
            <tr class="failed-row">
              <td><strong><%= webhook[:event] %></strong></td>
              <td><code><%= truncate(webhook[:url], length: 40) %></code></td>
              <td><span class="status-code status-<%= webhook[:response_code] %>"><%= webhook[:response_code] || 'Timeout' %></span></td>
              <td><%= webhook[:failed_at].strftime('%H:%M %Z') %></td>
              <td><%= webhook[:retries] %>/3</td>
              <td>
                <% if webhook[:retries] < 3 %>
                  <%= link_to "Retry", admin_retry_webhook_path(webhook[:webhook_id]), method: :post, class: "btn btn-sm btn-warning" %>
                <% else %>
                  <span class="badge badge-danger">Max retries</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <!-- Quick Links -->
  <div class="section quick-links">
    <h2>Quick Actions</h2>
    <div class="link-grid">
      <%= link_to "View All Webhooks", admin_dashboard_webhooks_path, class: "btn btn-primary" %>
      <%= link_to "View Applications", admin_dashboard_applications_path, class: "btn btn-primary" %>
      <%= link_to "View Payments", admin_dashboard_payments_path, class: "btn btn-primary" %>
      <%= link_to "Manage Lenders", admin_lenders_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>

<style>
  .admin-dashboard {
    padding: 2rem;
  }

  .dashboard-header {
    margin-bottom: 2rem;
  }

  .dashboard-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #666;
    font-size: 0.95rem;
  }

  .alerts-section {
    margin-bottom: 2rem;
  }

  .alert {
    padding: 1rem;
    margin-bottom: 1rem;
    border-left: 4px solid;
    border-radius: 4px;
  }

  .alert-warning { border-color: #F59E0B; background: #FFFBEB; }
  .alert-error { border-color: #EF4444; background: #FEE2E2; }
  .alert-info { border-color: #3B82F6; background: #EFF6FF; }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .metric-card {
    padding: 1.5rem;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    background: white;
  }

  .metric-label {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .metric-value {
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .section {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    background: white;
  }

  .section h2 {
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .portfolio-card {
    padding: 1rem;
    background: #F9FAFB;
    border-radius: 6px;
    border-left: 3px solid #3B82F6;
  }

  .portfolio-card .label {
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .portfolio-card .value {
    font-size: 1.5rem;
    font-weight: bold;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  table th {
    background: #F9FAFB;
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid #E5E7EB;
  }

  table td {
    padding: 0.75rem;
    border-bottom: 1px solid #E5E7EB;
  }

  .progress-bar {
    background: #E5E7EB;
    height: 24px;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress {
    background: #10B981;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .status-code {
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .status-200 { background: #DCFCE7; color: #166534; }
  .status-400 { background: #FEF3C7; color: #92400E; }
  .status-500 { background: #FEE2E2; color: #991B1B; }

  .quick-links {
    background: #F0F9FF;
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .btn {
    padding: 0.75rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    display: inline-block;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-primary { background: #3B82F6; color: white; }
  .btn-secondary { background: #6B7280; color: white; }
  .btn-warning { background: #F59E0B; color: white; }
</style>
