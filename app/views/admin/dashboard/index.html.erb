<% content_for :page_title, "Agent Command Centre" %>
<div data-controller="admin-dashboard">

<!-- Agent Operations Centre (Real-Time) -->
<%= render "admin/dashboard/agent_live_dashboard" %>

<!-- Priority Inbox — Agent Escalations Only -->
<div class="priority-inbox <%= @attention_items.any? ? 'needs-attention' : '' %>">
  <% if @attention_items.any? %>
    <div class="priority-inbox-header">
      <div class="priority-inbox-title">
        <span class="priority-inbox-icon">🔔</span>
        <h2>Needs Your Attention</h2>
      </div>
      <span class="priority-inbox-count"><%= @attention_items.size %></span>
    </div>
    <div class="priority-inbox-items">
      <% @attention_items.each do |item| %>
        <div class="priority-item priority-item-<%= item[:type] %>">
          <div class="priority-item-icon"><%= item[:icon] %></div>
          <div class="priority-item-content">
            <div class="priority-item-title"><%= item[:title] %></div>
            <div class="priority-item-subtitle"><%= item[:subtitle] %></div>
            <% if item[:detail].present? %>
              <div class="priority-item-detail"><%= item[:detail] %></div>
            <% end %>
          </div>
          <div class="priority-item-actions">
            <%= link_to "Review", item[:url_helper].call, class: "priority-action-btn priority-action-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="priority-inbox-header priority-inbox-clear">
      <div class="priority-inbox-title">
        <span class="priority-inbox-icon">✅</span>
        <h2>All Clear — Agents Are Handling Everything</h2>
      </div>
      <span class="priority-inbox-status">No escalations, flags, or low-confidence decisions need review</span>
    </div>
  <% end %>
</div>

<!-- Agent Status Cards -->
<% if @agents_with_stats.present? %>
  <div class="agent-command-section">
    <h2 class="section-title">🤖 Agent Status</h2>
    <div class="agent-cards-grid">
      <% @agents_with_stats.each do |data| %>
        <% agent = data[:agent] %>
        <div class="dashboard-card agent-status-card">
          <div class="card-content">
            <div class="agent-card-header">
              <%= image_tag(agent.avatar_path, size: "56x56", class: "avatar-lg", alt: agent.name) rescue '' %>
              <div>
                <h3 style="margin: 0 0 2px 0; font-size: 18px;">
                  <%= agent.name %>
                  <span class="agent-status-indicator <%= data[:active] ? 'agent-active' : 'agent-idle' %>">
                    <%= data[:active] ? '● Active' : '○ Idle' %>
                  </span>
                </h3>
                <div class="agent-card-subtitle"><%= agent.role_description %></div>
              </div>
            </div>
            <div class="agent-stat-grid">
              <div class="agent-stat-item agent-stat-item-neutral">
                <div class="agent-stat-value"><%= data[:today] %> / <%= data[:week] %></div>
                <div class="agent-stat-label">Today / This Week</div>
              </div>
              <div class="agent-stat-item agent-stat-item-success">
                <div class="agent-stat-value agent-stat-value-success"><%= data[:approval_rate] %>%</div>
                <div class="agent-stat-label">Approval Rate</div>
              </div>
              <div class="agent-stat-item agent-stat-item-info">
                <div class="agent-stat-value agent-stat-value-info"><%= (data[:avg_confidence] * 100).round(0) %>%</div>
                <div class="agent-stat-label">Avg Confidence</div>
              </div>
              <div class="agent-stat-item agent-stat-item-neutral">
                <div class="agent-stat-value" style="font-size: 14px;">
                  <%= data[:last_action_at] ? time_ago_in_words(data[:last_action_at]) + ' ago' : 'No actions yet' %>
                </div>
                <div class="agent-stat-label">Last Action</div>
              </div>
            </div>
            <%= link_to "View Details →", admin_agent_dashboard_path(agent), class: "agent-view-link" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Agent Performance Metrics -->
<div class="metrics-grid metrics-grid-3 agent-performance">
  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Agent Actions</span>
      <span class="metric-badge metric-badge-blue">AI</span>
    </div>
    <div class="metric-value"><%= number_with_delimiter(@agent_performance[:total_all]) %></div>
    <div class="metric-trend-group">
      <span class="metric-trend-item"><%= @agent_performance[:total_today] %> today</span>
      <span class="metric-trend-sep">·</span>
      <span class="metric-trend-item"><%= @agent_performance[:total_week] %> this week</span>
    </div>
  </div>

  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Avg Confidence Score</span>
      <span class="metric-badge metric-badge-green">Agents</span>
    </div>
    <div class="metric-value"><%= (@agent_performance[:avg_confidence] * 100).round(0) %>%</div>
    <div class="metric-trend">Across all agent decisions</div>
  </div>

  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Human Interventions</span>
      <span class="metric-badge metric-badge-yellow">Review</span>
    </div>
    <div class="metric-value"><%= @agent_performance[:flags_count] + @agent_performance[:escalations_count] %></div>
    <div class="metric-trend"><%= @agent_performance[:flags_count] %> flags · <%= @agent_performance[:escalations_count] %> escalations</div>
  </div>
</div>

<!-- Key Business Metrics (secondary context) -->
<div class="metrics-grid metrics-grid-4">
  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Total Applications</span>
      <span class="metric-badge metric-badge-blue">All Time</span>
    </div>
    <div class="metric-value"><%= number_with_delimiter(@total_applications) %></div>
    <div class="metric-trend metric-trend-up">+<%= @new_applications_this_month %> this month</div>
  </div>

  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Active Contracts</span>
      <span class="metric-badge metric-badge-green">Active</span>
    </div>
    <div class="metric-value"><%= number_with_delimiter(@active_contracts) %></div>
    <div class="metric-trend"><%= abbreviated_currency(@total_allocated || 0) %> allocated</div>
  </div>

  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Conversion Rate</span>
      <span class="metric-badge metric-badge-purple">Apps → Contracts</span>
    </div>
    <div class="metric-value"><%= format_percentage(@total_applications > 0 ? (@accepted_applications.to_f / @total_applications * 100) : 0) %>%</div>
    <div class="metric-trend"><%= @accepted_applications %> of <%= @total_applications %> applications</div>
  </div>

  <div class="metric-card">
    <div class="metric-card-top">
      <span class="metric-label">Available Capital</span>
      <% utilization = @pool_utilization || 0 %>
      <span class="metric-badge <%= utilization >= 80 ? 'metric-badge-red' : utilization >= 50 ? 'metric-badge-yellow' : 'metric-badge-green' %>">
        <%= format_percentage(utilization) %>% used
      </span>
    </div>
    <div class="metric-value"><%= abbreviated_currency(@total_available || 0) %></div>
    <div class="metric-trend">of <%= abbreviated_currency(@total_pool_capacity || 0) %> total capacity</div>
  </div>
</div>

<!-- Agent Decision Distribution + Charts -->
<%
  has_fum_data = @monthly_fum_data.values.any? { |v| v > 0 } || @cumulative_fum_data.values.any? { |v| v > 0 }
  has_pool_data = @pool_allocation_data.present? && @pool_allocation_data.any?
  has_decision_data = @agent_performance[:decision_distribution].any?
  has_any_chart_data = has_fum_data || has_pool_data || has_decision_data
%>

<% if has_any_chart_data %>
  <div class="dashboard-grid">
    <% if has_decision_data %>
      <div class="dashboard-card">
        <div class="card-header">
          <h3>Agent Decision Distribution</h3>
        </div>
        <div class="card-content">
          <% dist = @agent_performance[:decision_distribution] %>
          <div class="decision-distribution">
            <% total_decisions = dist.values.sum.to_f %>
            <% decision_colors = { 'approve' => '#16a34a', 'flag' => '#eab308', 'reject' => '#dc2626', 'advance' => '#2563eb', 'request_info' => '#8b5cf6' } %>
            <div class="decision-bar-track">
              <% dist.each do |decision, count| %>
                <div class="decision-bar-segment" style="width: <%= (count / total_decisions * 100).round(1) %>%; background-color: <%= decision_colors[decision] || '#94a3b8' %>;"></div>
              <% end %>
            </div>
            <div class="decision-legend">
              <% dist.each do |decision, count| %>
                <div class="decision-legend-item">
                  <span class="decision-legend-dot" style="background-color: <%= decision_colors[decision] || '#94a3b8' %>;"></span>
                  <span class="decision-legend-label"><%= decision.humanize %></span>
                  <span class="decision-legend-count"><%= count %> (<%= (count / total_decisions * 100).round(0) %>%)</span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @monthly_fum_data.values.any? { |v| v > 0 } %>
      <div class="dashboard-card">
        <div class="card-header">
          <h3>Funds Under Management — Monthly</h3>
        </div>
        <div class="card-content">
          <div
            data-controller="dashboard-chart"
            data-dashboard-chart-data-value='<%= @monthly_fum_data.map { |month, amount| { label: month, value: amount } }.to_json %>'
            data-dashboard-chart-type-value="bar"
            data-dashboard-chart-format-value="currency"
            class="chart-container">
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if has_pool_data || @cumulative_fum_data.values.any? { |v| v > 0 } %>
    <div class="dashboard-grid">
      <% if has_pool_data %>
        <div class="dashboard-card">
          <div class="card-header">
            <h3>Capital Allocation Overview</h3>
          </div>
          <div class="card-content">
            <div class="capital-allocation-chart">
              <div class="allocation-overview">
                <div class="allocation-segment allocated-segment" style="width: <%= @pool_utilization || 0 %>%">
                  <span class="segment-label">Allocated: <%= abbreviated_currency(@total_allocated || 0) %></span>
                </div>
                <div class="allocation-segment available-segment" style="width: <%= 100 - (@pool_utilization || 0) %>%">
                  <span class="segment-label">Available: <%= abbreviated_currency(@total_available || 0) %></span>
                </div>
              </div>
              <div class="allocation-legend">
                <div class="legend-item">
                  <div class="legend-color allocated-color"></div>
                  <span>Allocated (<%= format_percentage(@pool_utilization || 0) %>%)</span>
                </div>
                <div class="legend-item">
                  <div class="legend-color available-color"></div>
                  <span>Available (<%= format_percentage((100 - (@pool_utilization || 0)).round(1)) %>%)</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @cumulative_fum_data.values.any? { |v| v > 0 } %>
        <div class="dashboard-card">
          <div class="card-header">
            <h3>Funds Under Management — Cumulative</h3>
          </div>
          <div class="card-content">
            <div
              data-controller="dashboard-chart"
              data-dashboard-chart-data-value='<%= @cumulative_fum_data.map { |month, amount| { label: month, value: amount } }.to_json %>'
              data-dashboard-chart-type-value="area"
              data-dashboard-chart-format-value="currency"
              class="chart-container">
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="dashboard-card" style="margin-bottom: 40px;">
    <div class="card-content" style="text-align: center; padding: 40px;">
      <span style="font-size: 32px;">📊</span>
      <p style="color: #64748b; font-size: 15px; margin: 12px 0 0 0;">Charts will populate as contracts are created and agents process decisions</p>
    </div>
  </div>
<% end %>

<!-- Growth Charts -->
<div class="dashboard-grid">
  <% if @application_growth_data.values.any? { |v| v > 0 } %>
    <div class="dashboard-card">
      <div class="card-header">
        <h3>Application Growth (Last 6 Months)</h3>
      </div>
      <div class="card-content">
        <div
          data-controller="dashboard-chart"
          data-dashboard-chart-data-value='<%= @application_growth_data.map { |month, count| { label: month, value: count } }.to_json %>'
          data-dashboard-chart-type-value="bar"
          data-dashboard-chart-format-value="number"
          class="chart-container">
        </div>
      </div>
    </div>
  <% end %>

  <% if @conversion_growth_data.values.any? { |v| v > 0 } %>
    <div class="dashboard-card">
      <div class="card-header">
        <h3>Conversion Rate (Last 6 Months)</h3>
      </div>
      <div class="card-content">
        <div
          data-controller="dashboard-chart"
          data-dashboard-chart-data-value='<%= @conversion_growth_data.map { |month, rate| { label: month, value: rate } }.to_json %>'
          data-dashboard-chart-type-value="area"
          data-dashboard-chart-max-value="100"
          data-dashboard-chart-format-value="percentage"
          class="chart-container">
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Pool Utilization + Application Status Distribution -->
<div class="dashboard-grid">
  <% if @pool_allocation_data.present? && @pool_allocation_data.any? %>
    <div class="dashboard-card">
      <div class="card-header">
        <h3>Pool Utilization by Funder</h3>
      </div>
      <div class="card-content">
        <div class="pool-utilization-chart">
          <% @pool_allocation_data.each do |pool| %>
            <div class="pool-bar">
              <div class="pool-info">
                <span class="pool-name"><%= pool[:name].truncate(25) %></span>
                <span class="pool-stats">
                  <%= abbreviated_currency(pool[:allocated]) %> /
                  <%= abbreviated_currency(pool[:total]) %>
                </span>
              </div>
              <div class="pool-progress">
                <div class="pool-fill" style="width: <%= pool[:utilization] %>%"></div>
                <span class="pool-percentage"><%= format_percentage(pool[:utilization]) %>%</span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Application Status Distribution -->
  <div class="dashboard-card">
    <div class="card-header">
      <h3>Application Status Distribution</h3>
    </div>
    <div class="card-content">
      <div class="status-chart">
        <% @status_distribution.each do |status, count| %>
          <div class="status-bar" data-status="<%= status %>">
            <div class="status-label">
              <span><%= status %></span>
              <strong><%= count %></strong>
            </div>
            <div class="status-progress">
              <div class="status-fill" style="width: <%= @total_applications > 0 ? (count.to_f / @total_applications * 100).round(1) : 0 %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Activity Timeline + Recent Applications -->
<div class="dashboard-grid">
  <!-- Activity Timeline -->
  <div class="dashboard-card">
    <div class="card-header">
      <h3>Activity Timeline</h3>
    </div>
    <div class="card-content">
      <%
      all_activities = []

      if @recent_user_activity.present?
        @recent_user_activity.each do |activity|
          all_activities << {
            type: 'admin',
            time: activity.created_at,
            actor: activity.admin_user&.display_name || 'System',
            action: activity.action_description,
            details: activity.change_details,
            url: admin_user_path(activity.user),
            target_name: activity.user&.display_name
          }
        end
      end

      if @recent_app_activity.present?
        @recent_app_activity.each do |activity|
          all_activities << {
            type: 'admin',
            time: activity.created_at,
            actor: activity.user&.display_name || 'System',
            action: activity.action_description,
            details: activity.change_details,
            url: admin_application_path(activity.application),
            target_name: activity.application&.user&.display_name
          }
        end
      end

      # Include recent agent actions in timeline
      recent_agent_actions = AgentAction.includes(:ai_agent, :actionable).order(created_at: :desc).limit(10)
      recent_agent_actions.each do |aa|
        all_activities << {
          type: 'agent',
          time: aa.created_at,
          actor: aa.ai_agent&.name || 'Agent',
          avatar: aa.ai_agent&.avatar_filename,
          action: "#{aa.action_type.humanize}: #{aa.decision || 'N/A'}",
          details: aa.reasoning.to_s.truncate(80),
          url: aa.actionable.is_a?(Application) ? admin_application_path(aa.actionable) : '#',
          target_name: aa.actionable.is_a?(Application) ? aa.actionable.user&.display_name : aa.actionable&.class&.name
        }
      end

      all_activities = all_activities.sort_by { |a| a[:time] }.reverse.first(10)
      %>

      <% if all_activities.any? %>
        <div class="activity-timeline">
          <% all_activities.each do |activity| %>
            <div class="timeline-item timeline-item-<%= activity[:type] %>">
              <div class="timeline-marker timeline-marker-<%= activity[:type] %>"></div>
              <div class="timeline-content">
                <div class="timeline-header">
                  <% if activity[:type] == 'agent' && activity[:avatar].present? %>
                    <span class="timeline-avatar"><%= image_tag("agents/#{activity[:avatar]}", size: "24x24", class: "timeline-avatar-img") rescue '🤖' %></span>
                  <% end %>
                  <strong class="timeline-actor"><%= activity[:actor] %></strong>
                  <span class="timeline-action"><%= activity[:action] %></span>
                </div>
                <% if activity[:target_name].present? %>
                  <div class="timeline-target">
                    <%= link_to activity[:target_name], activity[:url] %>
                  </div>
                <% end %>
                <% if activity[:details].present? %>
                  <div class="timeline-details"><%= activity[:details] %></div>
                <% end %>
                <div class="timeline-time"><%= time_ago_in_words(activity[:time]) %> ago</div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="no-data">No recent activity</p>
      <% end %>
    </div>
  </div>

  <!-- Recent Applications -->
  <div class="dashboard-card">
    <div class="card-header">
      <h3>Recent Applications</h3>
      <%= link_to "View All", admin_applications_path, class: "card-action-link" %>
    </div>
    <div class="card-content">
      <% if @recent_applications.any? %>
        <div class="recent-list">
          <% @recent_applications.each do |application| %>
            <div class="recent-item">
              <div class="recent-info">
                <strong><%= link_to application.user.display_name, admin_application_path(application) %></strong>
                <p><%= application.display_address %></p>
                <span class="recent-time"><%= time_ago_in_words(application.updated_at) %> ago</span>
              </div>
              <div class="recent-status">
                <span class="status-badge status-<%= application.status %>"><%= application.status.humanize %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="no-data">No applications in the pipeline</p>
      <% end %>
    </div>
  </div>
</div>

</div>
