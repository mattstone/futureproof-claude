<div class="p-6">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Contracts for <%= @wholesale_funder.name %></h1>
    <p class="text-gray-600 mt-2">Manage sample contracts across jurisdictions</p>
  </div>

  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to "← Back to Wholesale Funders", admin_wholesale_funders_path, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <!-- Add Contract Button -->
  <div class="mb-6 flex justify-end">
    <%= link_to "Add Contract", new_admin_wholesale_funder_contract_path(@wholesale_funder), 
        class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition" %>
  </div>

  <!-- Contracts Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Jurisdiction</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Party Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Version</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @contracts.any? %>
            <% @contracts.each do |contract| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                    <%= contract.jurisdiction %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= contract.party_type %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= contract.version %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= contract.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm flex gap-2">
                  <%= link_to "Edit", edit_admin_wholesale_funder_contract_path(@wholesale_funder, contract), 
                      class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                  <%= link_to "Delete", admin_wholesale_funder_contract_path(@wholesale_funder, contract), 
                      method: :delete, data: { confirm: "Are you sure?" },
                      class: "text-red-600 hover:text-red-900 font-medium" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                <p class="text-sm">No contracts found. <%= link_to "Add one", new_admin_wholesale_funder_contract_path(@wholesale_funder), class: "text-blue-600" %></p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
