<% content_for :page_title, "Edit #{@broker.name}" %>

<div class="admin-content-wrapper">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <h2>Edit Broker</h2>
        <p class="admin-card-subtitle"><%= @broker.name %></p>
      </div>
      <div class="admin-card-actions">
        <%= link_to "Back", admin_broker_path(@broker), class: "admin-btn admin-btn-secondary" %>
      </div>
    </div>

    <%= form_with(model: [:admin, @broker], local: true) do |form| %>
      <% if @broker.errors.any? %>
        <div class="admin-alert admin-alert-danger">
          <h4><%= pluralize(@broker.errors.count, "error") %> found</h4>
          <ul>
            <% @broker.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="admin-form-section">
        <div class="admin-form-group">
          <%= form.label :name, "Name", class: "admin-form-label" %>
          <%= form.text_field :name, class: "admin-form-input", required: true %>
        </div>

        <div class="admin-form-group">
          <%= form.label :email, "Email", class: "admin-form-label" %>
          <%= form.email_field :email, class: "admin-form-input", disabled: true %>
          <small class="admin-form-hint">Email cannot be changed</small>
        </div>

        <div class="admin-form-group">
          <%= form.label :phone, "Phone", class: "admin-form-label" %>
          <%= form.text_field :phone, class: "admin-form-input", placeholder: "02 1234 5678" %>
        </div>

        <div class="admin-form-group">
          <%= form.label :jurisdiction, "Jurisdiction", class: "admin-form-label" %>
          <%= form.select :jurisdiction, 
              [["Australia", "AU"], ["United States", "US"], ["New Zealand", "NZ"], ["United Kingdom", "UK"]], 
              {}, 
              class: "admin-form-input", 
              disabled: true %>
          <small class="admin-form-hint">Jurisdiction cannot be changed</small>
        </div>

        <div class="admin-form-group">
          <div class="admin-form-checkbox">
            <%= form.check_box :active %>
            <%= form.label :active, "Active", class: "admin-form-label" %>
          </div>
          <small class="admin-form-hint">Broker can sign in and access portal when active</small>
        </div>
      </div>

      <div class="admin-form-actions">
        <%= form.submit "Save Changes", class: "admin-btn admin-btn-primary" %>
        <%= link_to "Cancel", admin_broker_path(@broker), class: "admin-btn admin-btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
