<%= stylesheet_link_tag "admin/brokers", "data-turbo-track": "reload" %>
<div class="admin-brokers">
  <div class="admin-header">
    <h1>Broker Management</h1>
    <%= link_to "Add New Broker", new_admin_broker_path, class: "btn btn-primary" %>
  </div>

  <!-- Search -->
  <div class="search-section">
    <%= form_with url: admin_brokers_path, method: :get, local: true do |f| %>
      <%= f.text_field :search, placeholder: "Search brokers by name...", value: params[:search], class: "search-input" %>
      <%= submit_tag "Search", class: "btn btn-secondary" %>
      <% if params[:search].present? %>
        <%= link_to "Clear", admin_brokers_path, class: "btn btn-outline" %>
      <% end %>
    <% end %>
  </div>

  <!-- Brokers Table -->
  <div class="brokers-table-section">
    <% if @brokers.any? %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Country</th>
            <th>Lenders</th>
            <th>Applications</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @brokers.each do |broker| %>
            <tr>
              <td>
                <strong><%= link_to broker.name, admin_broker_path(broker) %></strong>
              </td>
              <td><%= broker.email %></td>
              <td><span class="jurisdiction-badge"><%= broker.jurisdiction %></span></td>
              <td>
                <span class="badge"><%= broker.lenders.count %></span>
              </td>
              <td>
                <span class="badge"><%= broker.applications.count %></span>
              </td>
              <td>
                <% if broker.active %>
                  <span class="status-badge status-active">Active</span>
                <% else %>
                  <span class="status-badge status-inactive">Inactive</span>
                <% end %>
              </td>
              <td class="actions">
                <%= link_to "Edit", edit_admin_broker_path(broker), class: "btn btn-sm btn-secondary" %>
                <%= link_to broker.active ? "Deactivate" : "Activate", 
                    toggle_active_admin_broker_path(broker), 
                    method: :patch,
                    class: "btn btn-sm btn-outline" %>
                <%= link_to "Delete", admin_broker_path(broker), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Pagination -->
      <div class="pagination-section">
        <%= paginate @brokers %>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No brokers found.</p>
        <%= link_to "Create the first broker", new_admin_broker_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

