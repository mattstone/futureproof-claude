<% content_for :page_title, "Brokers" %>

<div class="admin-content-wrapper">
  <!-- Stats -->
  <div class="admin-metrics-grid">
    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Total Brokers</span>
      </div>
      <p class="admin-metric-value"><%= @stats[:total] %></p>
    </div>

    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Active</span>
      </div>
      <p class="admin-metric-value"><%= @stats[:active] %></p>
    </div>

    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Inactive</span>
      </div>
      <p class="admin-metric-value"><%= @stats[:inactive] %></p>
    </div>
  </div>

  <!-- Brokers Table -->
  <div class="admin-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h2 style="margin: 0;">Brokers <span class="admin-badge admin-badge-info"><%= @current_jurisdiction %></span></h2>
      <%= link_to "➕ Add Broker", new_admin_broker_path, class: "admin-btn admin-btn-primary" %>
    </div>

    <% if @brokers.any? %>
      <table class="admin-table admin-table-compact">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Lenders</th>
            <th>Status</th>
            <th class="admin-actions-cell">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @brokers.each do |broker| %>
            <tr>
              <td><strong><%= broker.name %></strong></td>
              <td><small><%= broker.email %></small></td>
              <td><small><%= broker.phone || "—" %></small></td>
              <td>
                <small>
                  <% if broker.lenders.any? %>
                    <%= broker.lenders.count %>
                  <% else %>
                    <em class="admin-text-muted">—</em>
                  <% end %>
                </small>
              </td>
              <td>
                <% if broker.active %>
                  <span class="admin-badge admin-badge-success">Active</span>
                <% else %>
                  <span class="admin-badge admin-badge-warning">Inactive</span>
                <% end %>
              </td>
              <td class="admin-actions-cell">
                <%= link_to "View", admin_broker_path(broker), class: "admin-link" %>
                <%= link_to "Edit", edit_admin_broker_path(broker), class: "admin-link" %>
                <%= link_to(broker.active ? "Deactivate" : "Activate", toggle_active_admin_broker_path(broker), method: :patch, class: "admin-link") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="admin-empty-state">
        <p>No brokers in <%= @current_jurisdiction %> yet</p>
        <%= link_to "Create one now", new_admin_broker_path, class: "admin-link" %>
      </div>
    <% end %>
  </div>
</div>
