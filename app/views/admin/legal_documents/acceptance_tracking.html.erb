<div class="container">
  <div class="breadcrumb">
    <%= link_to "Dashboard", admin_path %> <span>›</span>
    <%= link_to "Legal Documents", admin_legal_documents_path %> <span>›</span>
    <span>Acceptance Tracking</span>
  </div>

  <h1>Acceptance Tracking</h1>
  <p>Monitor legal document acceptance across all parties.</p>

  <!-- Filters -->
  <div class="card" style="margin-bottom: 20px;">
    <form method="get" style="display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 15px; align-items: flex-end;">
      <div style="display: flex; flex-direction: column;">
        <label for="doc_type">Document Type</label>
        <select name="document_type" id="doc_type">
          <option value="">All Documents</option>
          <% LegalDocument::DOCUMENT_TYPES.each do |key, name| %>
            <option value="<%= key %>" <%= params[:document_type] == key.to_s ? 'selected' : '' %>>
              <%= name %>
            </option>
          <% end %>
        </select>
      </div>

      <div style="display: flex; flex-direction: column;">
        <label for="jurisdiction">Jurisdiction</label>
        <select name="jurisdiction" id="jurisdiction">
          <option value="">All Jurisdictions</option>
          <% LegalDocument::JURISDICTIONS.each do |jur| %>
            <option value="<%= jur %>" <%= params[:jurisdiction] == jur ? 'selected' : '' %>>
              <%= jur %>
            </option>
          <% end %>
        </select>
      </div>

      <div></div>

      <button type="submit" class="btn-primary" style="padding: 10px 20px;">Apply Filter</button>
    </form>
  </div>

  <!-- Statistics Cards -->
  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 30px;">
    <div class="stats-card">
      <h3>Total Acceptances</h3>
      <div class="stat-value"><%= @acceptances.count %></div>
    </div>

    <div class="stats-card">
      <h3>Acceptance Rate</h3>
      <div class="stat-value" style="color: <%= @acceptance_rate > 80 ? '#16a34a' : (@acceptance_rate > 50 ? '#ea580c' : '#dc2626') %>;">
        <%= @acceptance_rate.round(1) %>%
      </div>
    </div>

    <div class="stats-card">
      <h3>By Party Type</h3>
      <div style="font-size: 13px; text-align: left; padding: 10px; background: #f3f4f6; border-radius: 3px;">
        <% party_breakdown = @acceptances.group(:user_id, :lender_id).count %>
        <p style="margin: 5px 0;">Users: <%= @acceptances.where.not(user_id: nil).count %></p>
        <p style="margin: 5px 0;">Lenders: <%= @acceptances.where.not(lender_id: nil).count %></p>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="card">
    <div class="card-header">
      <h2>Acceptance Timeline</h2>
    </div>

    <% if @acceptances.any? %>
      <div style="padding: 20px 0;">
        <% @acceptances.recent.each do |acceptance| %>
          <div class="timeline-event <%= acceptance.acceptance_type %>">
            <div style="display: flex; justify-content: space-between; align-items: start;">
              <div>
                <span class="badge badge-<%= acceptance.acceptance_type %>">
                  <%= acceptance.acceptance_type.upcase %>
                </span>
                <p style="margin: 10px 0 5px 0; font-weight: 500;">
                  <strong><%= acceptance.legal_document_acceptances.first&.user&.display_name || acceptance.lender&.name || 'Unknown' %></strong>
                  accepted <strong><%= acceptance.legal_document.document_type_display %></strong>
                  (v<%= acceptance.legal_document.version %>)
                </p>
                <p style="margin: 0; font-size: 13px; color: #6b7280;">
                  <%= acceptance.accepted_at.strftime("%B %d, %Y at %I:%M %p") %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="padding: 20px; text-align: center; color: #6b7280;">No acceptances found.</p>
    <% end %>
  </div>

  <!-- Export Button -->
  <div style="margin-top: 20px; text-align: right;">
    <%= link_to "[Export Audit Trail as CSV]", admin_legal_documents_acceptance_tracking_path(format: 'csv', **params.slice(:document_type, :jurisdiction).permit!), class: 'btn-primary', style: 'display: inline-block; padding: 10px 20px; text-decoration: none;' %>
  </div>
</div>

<style>
.stats-card {
  background: white;
  border: 1px solid #e5e7eb;
  padding: 20px;
  border-radius: 6px;
  text-align: center;
}

.stats-card h3 {
  margin: 0 0 10px 0;
  color: #6b7280;
  font-size: 14px;
}

.stat-value {
  font-size: 32px;
  font-weight: bold;
  color: #2563eb;
}

.timeline-event {
  border-left: 4px solid #2563eb;
  padding: 15px;
  margin-bottom: 15px;
  background: white;
  border-radius: 3px;
}

.timeline-event.explicit {
  border-left-color: #16a34a;
}

.timeline-event.implicit {
  border-left-color: #0284c7;
}

.timeline-event.required {
  border-left-color: #ea580c;
}

.badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
}

.badge-explicit {
  background: #dcfce7;
  color: #166534;
}

.badge-implicit {
  background: #dbeafe;
  color: #1e40af;
}

.badge-required {
  background: #fed7aa;
  color: #92400e;
}

@media (max-width: 768px) {
  .stats-card {
    padding: 15px;
  }

  .stat-value {
    font-size: 24px;
  }
}
</style>
