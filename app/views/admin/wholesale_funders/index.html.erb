<div class="p-6">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Wholesale Funders Management</h1>
    <p class="text-gray-600">Global funding allocation and contract management across all jurisdictions</p>
  </div>

  <!-- Global Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-blue-500">
      <div class="text-sm text-gray-600 font-semibold mb-2">TOTAL ALLOCATED</div>
      <div class="text-2xl font-bold text-gray-900">
        <%= number_to_currency(@global_stats[:total_allocated], precision: 0) %>
      </div>
      <p class="text-xs text-gray-500 mt-2">All Jurisdictions</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-purple-500">
      <div class="text-sm text-gray-600 font-semibold mb-2">TOTAL COMMITTED</div>
      <div class="text-2xl font-bold text-gray-900">
        <%= number_to_currency(@global_stats[:total_committed], precision: 0) %>
      </div>
      <p class="text-xs text-gray-500 mt-2">From Active Applications</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
      <div class="text-sm text-gray-600 font-semibold mb-2">TOTAL AVAILABLE</div>
      <div class="text-2xl font-bold text-gray-900">
        <%= number_to_currency(@global_stats[:total_available], precision: 0) %>
      </div>
      <p class="text-xs text-gray-500 mt-2">Ready to Deploy</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6 border-l-4 border-orange-500">
      <div class="text-sm text-gray-600 font-semibold mb-2">UTILIZATION</div>
      <div class="text-2xl font-bold text-gray-900">
        <%= @global_stats[:utilization_pct] %>%
      </div>
      <p class="text-xs text-gray-500 mt-2">Committed / Total</p>
    </div>
  </div>

  <!-- Jurisdiction Switcher & Actions -->
  <div class="bg-white rounded-lg shadow p-6 mb-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="flex-1">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Filter by Jurisdiction</label>
        <select id="jurisdiction-filter" 
                class="block w-full md:w-64 px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500"
                onchange="window.location.href='<%= admin_wholesale_funders_path %>' + '?jurisdiction=' + this.value">
          <option value="All" <%= 'selected' if @selected_jurisdiction == 'All' %>>All Jurisdictions</option>
          <option value="AU" <%= 'selected' if @selected_jurisdiction == 'AU' %>>Australia (AU)</option>
          <option value="US" <%= 'selected' if @selected_jurisdiction == 'US' %>>United States (US)</option>
          <option value="NZ" <%= 'selected' if @selected_jurisdiction == 'NZ' %>>New Zealand (NZ)</option>
          <option value="UK" <%= 'selected' if @selected_jurisdiction == 'UK' %>>United Kingdom (UK)</option>
        </select>
      </div>
      <div class="flex gap-3">
        <%= link_to "Add Funder", new_admin_wholesale_funder_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition" %>
      </div>
    </div>
  </div>

  <!-- Funders Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Country</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Currency</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Allocated</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Committed</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Available</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Utilization</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Runway (mo)</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @wholesale_funders.any? %>
            <% @wholesale_funders.each do |funder| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= funder.name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= funder.country %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= funder.currency %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 font-medium">
                  <%= number_to_currency(funder.total_allocated_amount, precision: 0) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 font-medium">
                  <%= number_to_currency(funder.committed_amount, precision: 0) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 font-medium">
                  <%= number_to_currency(funder.available_amount, precision: 0) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                  <div class="flex items-center justify-end gap-2">
                    <div class="w-20 bg-gray-200 rounded-full h-2">
                      <div class="bg-blue-600 h-2 rounded-full" 
                           style="width: <%= funder.utilization_percentage %>%"></div>
                    </div>
                    <span class="text-gray-900 font-medium min-w-12"><%= funder.utilization_percentage %>%</span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                  <span class="font-medium <%= funder.runway_months > 12 ? 'text-green-600' : funder.runway_months > 6 ? 'text-yellow-600' : 'text-red-600' %>">
                    <% if funder.runway_months >= 999 %>
                      ∞ months
                    <% else %>
                      <%= funder.runway_months %> months
                    <% end %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm flex gap-2">
                  <%= link_to "Contracts", admin_wholesale_funder_contracts_path(funder), 
                      class: "text-blue-600 hover:text-blue-900 font-medium" %>
                  <%= link_to "Edit", edit_admin_wholesale_funder_path(funder), 
                      class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                  <%= link_to "Delete", admin_wholesale_funder_path(funder), 
                      method: :delete, data: { confirm: "Are you sure?" },
                      class: "text-red-600 hover:text-red-900 font-medium" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="9" class="px-6 py-8 text-center text-gray-500">
                <p class="text-sm">No wholesale funders found for this jurisdiction.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div class="mt-6">
    <%= paginate @wholesale_funders, theme: 'bootstrap-4' %>
  </div>
</div>
