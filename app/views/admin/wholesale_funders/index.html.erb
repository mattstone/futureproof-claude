<% provide :page_title, "Wholesale Funders Management" %>

<div class="admin-content-wrapper">
  <div class="admin-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <div>
        <h2 style="margin: 0 0 0.5rem 0;">Wholesale Funders Management</h2>
        <p class="form-help-text" style="margin: 0;">Global funding allocation and contract management across all jurisdictions</p>
      </div>
      <%= link_to "Add Funder", new_admin_wholesale_funder_path, class: "admin-btn admin-btn-primary" %>
    </div>

    <!-- Global Summary Cards -->
    <div class="admin-metrics-grid">
      <div class="admin-metric-card">
        <div class="admin-metric-top">
          <span class="admin-metric-label">Total Allocated</span>
        </div>
        <p class="admin-metric-value"><%= number_to_currency(@global_stats[:total_allocated], precision: 0) %></p>
        <small>All Jurisdictions</small>
      </div>

      <div class="admin-metric-card">
        <div class="admin-metric-top">
          <span class="admin-metric-label">Total Committed</span>
        </div>
        <p class="admin-metric-value"><%= number_to_currency(@global_stats[:total_committed], precision: 0) %></p>
        <small>From Active Applications</small>
      </div>

      <div class="admin-metric-card">
        <div class="admin-metric-top">
          <span class="admin-metric-label">Total Available</span>
        </div>
        <p class="admin-metric-value"><%= number_to_currency(@global_stats[:total_available], precision: 0) %></p>
        <small>Ready to Deploy</small>
      </div>

      <div class="admin-metric-card">
        <div class="admin-metric-top">
          <span class="admin-metric-label">Utilization</span>
        </div>
        <p class="admin-metric-value"><%= @global_stats[:utilization_pct] %>%</p>
        <small>Committed / Total</small>
      </div>
    </div>
  </div>

  <!-- Funders Table -->
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Country</th>
          <th>Currency</th>
          <th>Allocated</th>
          <th>Committed</th>
          <th>Available</th>
          <th>Utilization</th>
          <th>Runway</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @wholesale_funders.any? %>
          <% @wholesale_funders.each do |funder| %>
            <tr>
              <td><strong><%= funder.name %></strong></td>
              <td><%= funder.country %></td>
              <td><%= funder.currency %></td>
              <td><%= number_to_currency(funder.total_allocated_amount, precision: 0) %></td>
              <td><%= number_to_currency(funder.committed_amount, precision: 0) %></td>
              <td><%= number_to_currency(funder.available_amount, precision: 0) %></td>
              <td>
                <div class="admin-progress-inline">
                  <div class="admin-progress-bar-small">
                    <div class="admin-progress-fill-small" style="width: <%= funder.utilization_percentage %>%"></div>
                  </div>
                  <span class="admin-progress-percent"><%= funder.utilization_percentage %>%</span>
                </div>
              </td>
              <td>
                <span class="<%= funder.runway_months > 12 ? 'admin-text-success' : funder.runway_months > 6 ? 'admin-text-warning' : 'admin-text-danger' %>">
                  <% if funder.runway_months >= 999 %>
                    ∞ months
                  <% else %>
                    <%= funder.runway_months %> months
                  <% end %>
                </span>
              </td>
              <td class="admin-actions-cell">
                <%= link_to "Contracts", admin_wholesale_funder_contracts_path(funder), class: "admin-btn admin-btn-sm" %>
                <%= link_to "Edit", edit_admin_wholesale_funder_path(funder), class: "admin-btn admin-btn-sm" %>
                <%= link_to "Delete", admin_wholesale_funder_path(funder), 
                    method: :delete, data: { turbo_confirm: "Are you sure?" },
                    class: "admin-btn admin-btn-sm admin-btn-danger" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="admin-table-empty">
              No wholesale funders found for this jurisdiction.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="admin-pagination">
    <%= paginate @wholesale_funders %>
  </div>
</div>
