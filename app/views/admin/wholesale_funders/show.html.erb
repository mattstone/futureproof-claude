<% content_for :page_title, @wholesale_funder.display_name %>
<%= stylesheet_link_tag "admin/wholesale_funders", "data-turbo-track": "reload" %>

<div class="admin-actions-bar">
  <div>
    <h1><%= @wholesale_funder.name %></h1>
    <p class="page-subtitle"><%= @wholesale_funder.country %> • <%= @wholesale_funder.currency_symbol %><%= @wholesale_funder.currency %></p>
  </div>
  
  <div class="admin-actions">
    <%= link_to "Edit Wholesale Funder", edit_admin_wholesale_funder_path(@wholesale_funder), class: "admin-btn admin-btn-primary" %>
    <%= link_to "Delete", admin_wholesale_funder_path(@wholesale_funder), method: :delete, 
        data: { turbo_confirm: "Are you sure you want to delete this wholesale funder?" }, 
        class: "admin-btn admin-btn-danger" %>
    <%= link_to "Back to Wholesale Funders", admin_wholesale_funders_path, class: "admin-btn admin-btn-secondary" %>
  </div>
</div>

<!-- Wholesale Funder Details -->
<div class="admin-card">
  <h3>Wholesale Funder Information</h3>
  
  <div class="wholesale-funder-details">
    <!-- Column 1: Basic Information -->
    <div class="wholesale-funder-basic">
      <h4>Basic Information</h4>
      <div class="wholesale-funder-name"><%= @wholesale_funder.name %></div>
      <div class="wholesale-funder-location">
        <span class="country-flag">🌍</span>
        <%= @wholesale_funder.country %>
      </div>
      <div class="wholesale-funder-currency">
        <span class="currency-badge currency-<%= @wholesale_funder.currency.downcase %>">
          <%= @wholesale_funder.currency_symbol %> <%= @wholesale_funder.currency %>
        </span>
      </div>
    </div>
    
    <!-- Column 2: Pool Summary -->
    <div class="wholesale-funder-summary">
      <h4>Pool Summary</h4>
      <div class="summary-stats">
        <div class="stat-item">
          <div class="stat-value pools-count"><%= @wholesale_funder.pools_count %></div>
          <div class="stat-label">Pool<%= 's' if @wholesale_funder.pools_count != 1 %></div>
        </div>
        <div class="stat-item">
          <div class="stat-value capital-amount">
            <% if @wholesale_funder.total_capital > 0 %>
              <%= @wholesale_funder.formatted_total_capital %>
            <% else %>
              $0
            <% end %>
          </div>
          <div class="stat-label">Total Capital</div>
        </div>
        <div class="stat-item">
          <div class="stat-value allocated-amount">
            <% if @wholesale_funder.total_allocated > 0 %>
              <%= @wholesale_funder.formatted_total_allocated %>
            <% else %>
              $0
            <% end %>
          </div>
          <div class="stat-label">Allocated</div>
        </div>
      </div>
      
      <% if @wholesale_funder.total_capital > 0 %>
        <div class="allocation-bar">
          <div class="allocation-progress" style="width: <%= @wholesale_funder.capital_allocation_percentage %>%"></div>
        </div>
        <div class="allocation-text">
          <span class="allocation-percentage"><%= @wholesale_funder.capital_allocation_percentage %>% allocated</span>
          <span class="available-amount">
            <%= @wholesale_funder.formatted_total_available %> available
          </span>
        </div>
      <% end %>
    </div>
    
    <!-- Column 3: Meta Information -->
    <div class="wholesale-funder-meta">
      <h4>Timestamps</h4>
      <div class="meta-row">
        <span class="meta-label">Created:</span>
        <span class="meta-value"><%= @wholesale_funder.created_at.strftime("%B %d, %Y") %></span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Last Updated:</span>
        <span class="meta-value"><%= @wholesale_funder.updated_at.strftime("%B %d, %Y") %></span>
      </div>
    </div>
  </div>
</div>

<!-- Wholesale Funder Pools -->
<div class="admin-card">
  <div class="card-header">
    <h3>Wholesale Funder Pools</h3>
    <div class="card-actions">
      <%= link_to "New Pool", new_admin_wholesale_funder_funder_pool_path(@wholesale_funder), class: "admin-btn admin-btn-primary admin-btn-sm" %>
    </div>
  </div>
  
  <% if @wholesale_funder.funder_pools.any? %>
    <div class="admin-table">
      <table>
        <thead>
          <tr>
            <th>Pool Name</th>
            <th>Total Amount</th>
            <th>Allocated</th>
            <th>Available</th>
            <th>Allocation %</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @wholesale_funder.funder_pools.recent.each do |pool| %>
            <tr>
              <td>
                <strong><%= pool.name %></strong>
              </td>
              <td class="amount-cell">
                <span class="amount-total"><%= pool.formatted_amount %></span>
              </td>
              <td class="amount-cell">
                <span class="amount-allocated"><%= pool.formatted_allocated %></span>
              </td>
              <td class="amount-cell">
                <span class="amount-available"><%= pool.formatted_available %></span>
              </td>
              <td class="percentage-cell">
                <div class="mini-allocation-bar">
                  <div class="mini-allocation-progress" style="width: <%= pool.allocation_percentage %>%"></div>
                  <span class="mini-allocation-text"><%= pool.allocation_percentage %>%</span>
                </div>
              </td>
              <td class="actions-cell">
                <div class="admin-actions">
                  <%= link_to "View", admin_wholesale_funder_funder_pool_path(@wholesale_funder, pool), class: "admin-btn admin-btn-sm admin-btn-secondary", data: { turbo_frame: "_top" } %>
                  <%= link_to "Edit", edit_admin_wholesale_funder_funder_pool_path(@wholesale_funder, pool), class: "admin-btn admin-btn-sm admin-btn-primary", data: { turbo_frame: "_top" } %>
                  <%= link_to "Delete", admin_wholesale_funder_funder_pool_path(@wholesale_funder, pool), method: :delete, 
                      data: { turbo_confirm: "Are you sure you want to delete this pool?", turbo_frame: "_top" }, 
                      class: "admin-btn admin-btn-sm admin-btn-danger" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-content">
        <h4>No pools created yet</h4>
        <p>Create funding pools to organize and track allocated amounts for this wholesale funder.</p>
        <div class="empty-state-actions">
          <%= link_to "Create First Pool", new_admin_wholesale_funder_funder_pool_path(@wholesale_funder), class: "admin-btn admin-btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Change History -->
<%= render 'shared/change_history', versions: @wholesale_funder.wholesale_funder_versions.recent %>

