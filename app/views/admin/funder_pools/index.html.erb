<% content_for :page_title, "WholesaleFunder Pools" %>
<%= stylesheet_link_tag "admin/funder_pools", "data-turbo-track": "reload" %>

<div class="admin-actions-bar">
  <div class="admin-search">
    <%= form_with url: admin_funder_pools_path, method: :get, local: true, class: "search-form" do |form| %>
      <%= form.text_field :search, placeholder: "Search by pool name or wholesale_funder...", value: params[:search], class: "search-input" %>
    <% end %>
  </div>
  
  <div class="admin-filter">
    <%= form_with url: admin_funder_pools_path, method: :get, local: true, class: "filter-form" do |form| %>
      <%= form.select :wholesale_funder_id, 
            options_for_select([["All WholesaleFunders", ""]] + @wholesale_funders_for_filter.map { |f| [f.name, f.id] }, params[:wholesale_funder_id]),
            {},
            { 
              class: "filter-select",
              onchange: "this.form.requestSubmit();"
            } %>
      <%= form.hidden_field :search, value: params[:search] %>
    <% end %>
  </div>
  
  <div class="admin-actions">
    <div class="pools-summary">
      Total Pools: <span class="count-badge"><%= @funder_pools.total_count || FunderPool.count %></span>
    </div>
  </div>
</div>

<!-- WholesaleFunder Pools Table -->
<div id="wholesale-funder-pools-results">
  <% if @funder_pools.any? %>
    <div class="admin-table">
      <table>
        <thead>
          <tr>
            <th>Pool Name</th>
            <th>WholesaleFunder</th>
            <th>Total Amount</th>
            <th>Allocated</th>
            <th>Available</th>
            <th>Allocation %</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @funder_pools.each do |pool| %>
            <tr>
              <td>
                <strong><%= pool.name %></strong>
              </td>
              <td>
                <%= link_to pool.wholesale_funder.name, admin_wholesale_funder_path(pool.wholesale_funder), class: "admin-link" %>
                <br><small><%= pool.wholesale_funder.country %> • <%= pool.wholesale_funder.currency %></small>
              </td>
              <td class="amount-cell">
                <span class="amount-total"><%= pool.formatted_amount %></span>
              </td>
              <td class="amount-cell">
                <span class="amount-allocated"><%= pool.formatted_allocated %></span>
              </td>
              <td class="amount-cell">
                <span class="amount-available"><%= pool.formatted_available %></span>
              </td>
              <td class="percentage-cell">
                <div class="mini-allocation-bar">
                  <div class="mini-allocation-progress" style="width: <%= pool.allocation_percentage %>%"></div>
                  <span class="mini-allocation-text"><%= pool.allocation_percentage %>%</span>
                </div>
              </td>
              <td>
                <time><%= pool.created_at.strftime("%b %d, %Y") %></time>
              </td>
              <td class="actions-cell">
                <div class="admin-actions">
                  <%= link_to "View", admin_wholesale_funder_funder_pool_path(pool.wholesale_funder, pool), class: "admin-btn admin-btn-sm admin-btn-secondary", data: { turbo_frame: "_top" } %>
                  <%= link_to "Edit", edit_admin_wholesale_funder_funder_pool_path(pool.wholesale_funder, pool), class: "admin-btn admin-btn-sm admin-btn-primary", data: { turbo_frame: "_top" } %>
                  <%= link_to "Delete", admin_wholesale_funder_funder_pool_path(pool.wholesale_funder, pool), method: :delete, 
                      data: { confirm: "Are you sure you want to delete this pool?", turbo_frame: "_top" }, 
                      class: "admin-btn admin-btn-sm admin-btn-danger" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      
      <!-- Pagination -->
      <%= paginate @funder_pools if respond_to?(:paginate) %>
    </div>
    
  <% else %>
    <div class="empty-state">
      <div class="empty-state-content">
        <h3>No pools found</h3>
        <p>
          <% if params[:search].present? || params[:wholesale_funder_id].present? %>
            No pools match your current filters. Try adjusting your search terms or clear the filters.
          <% else %>
            WholesaleFunder pools will appear here once wholesale_funders create them.
          <% end %>
        </p>
        <div class="empty-state-actions">
          <% if params[:search].present? || params[:wholesale_funder_id].present? %>
            <%= link_to "Clear Filters", admin_funder_pools_path, class: "admin-btn admin-btn-secondary" %>
          <% end %>
          <%= link_to "View WholesaleFunders", admin_wholesale_funders_path, class: "admin-btn admin-btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

