<% content_for :page_title, @funder_pool.display_name %>
<%= stylesheet_link_tag "admin/funder_pools", "data-turbo-track": "reload" %>

<div class="admin-actions-bar">
  <div></div>
  <div class="admin-actions">
    <%= link_to "Edit Pool", edit_admin_wholesale_funder_funder_pool_path(@wholesale_funder, @funder_pool), class: "admin-btn admin-btn-primary" %>
    <%= link_to "Delete", admin_wholesale_funder_funder_pool_path(@wholesale_funder, @funder_pool), method: :delete, 
        data: { confirm: "Are you sure you want to delete this pool?" }, 
        class: "admin-btn admin-btn-danger" %>
    <%= link_to "Back to #{@wholesale_funder.name}", admin_wholesale_funder_path(@wholesale_funder), class: "admin-btn admin-btn-secondary" %>
  </div>
</div>

<!-- Pool Details -->
<div class="admin-card">
  <h3>Pool Summary</h3>
  
  <div class="pool-summary-grid">
    <!-- Financial Overview -->
    <div class="summary-section financial-overview">
      <h4>Financial Overview</h4>
      <div class="financial-stats">
        <div class="stat-row">
          <span class="stat-label">Total Amount</span>
          <span class="stat-value amount-total"><%= @funder_pool.formatted_amount %></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Allocated</span>
          <span class="stat-value amount-allocated"><%= @funder_pool.formatted_allocated %></span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Available</span>
          <span class="stat-value amount-available"><%= @funder_pool.formatted_available %></span>
        </div>
      </div>
      
      <div class="allocation-visualization">
        <div class="allocation-bar">
          <div class="allocation-progress" style="width: <%= @funder_pool.allocation_percentage %>%"></div>
        </div>
        <div class="allocation-details">
          <span class="allocation-percentage"><%= @funder_pool.allocation_percentage %>% allocated</span>
          <span class="contracts-count"><%= @funder_pool.contracts.count %> contract<%= 's' if @funder_pool.contracts.count != 1 %></span>
        </div>
      </div>
    </div>
    
    <!-- Pool Details -->
    <div class="summary-section pool-details">
      <h4>Pool Details</h4>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">WholesaleFunder</span>
          <span class="detail-value">
            <%= link_to @wholesale_funder.name, admin_wholesale_funder_path(@wholesale_funder), class: "admin-link" %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Created</span>
          <span class="detail-value"><%= @funder_pool.created_at.strftime("%B %d, %Y") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Last Updated</span>
          <span class="detail-value"><%= @funder_pool.updated_at.strftime("%B %d, %Y") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label"><%= @funder_pool.benchmark_rate_name %> Rate</span>
          <span class="detail-value rate-value"><%= @funder_pool.formatted_benchmark_rate %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Margin Rate</span>
          <span class="detail-value rate-value"><%= @funder_pool.formatted_margin_rate %></span>
        </div>
        <div class="detail-row total-rate">
          <span class="detail-label">Total Rate</span>
          <span class="detail-value rate-value total-rate-value"><%= @funder_pool.formatted_total_rate %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Allocated Contracts -->
<div class="admin-card">
  <div class="card-header">
    <h3>Allocated Contracts</h3>
    <div class="contract-summary">
      <span class="contract-count"><%= @funder_pool.contracts.count %> contract<%= 's' if @funder_pool.contracts.count != 1 %></span>
      <span class="contract-total">Total: <%= ActionController::Base.helpers.number_to_currency(@funder_pool.contracts.sum(:allocated_amount) || 0, precision: 0) %></span>
    </div>
  </div>
  
  <% if @funder_pool.contracts.any? %>
    <div class="admin-table">
      <table>
        <thead>
          <tr>
            <th>Customer</th>
            <th>Property Address</th>
            <th>Allocated Amount</th>
            <th>Status</th>
            <th>Start Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @funder_pool.contracts.includes(application: :user).order(:created_at).each do |contract| %>
            <tr>
              <td>
                <strong><%= contract.application.user.display_name %></strong>
              </td>
              <td>
                <div class="address-cell">
                  <%= contract.application.address.truncate(60) %>
                </div>
              </td>
              <td class="amount-cell">
                <span class="contract-amount"><%= contract.formatted_allocated_amount %></span>
              </td>
              <td class="status-cell">
                <span class="status-badge status-<%= contract.status %>">
                  <%= contract.status_display %>
                </span>
              </td>
              <td>
                <%= contract.start_date.strftime("%b %d, %Y") if contract.start_date %>
              </td>
              <td class="actions-cell">
                <div class="admin-actions">
                  <%= link_to "View Contract", admin_contract_path(contract), class: "admin-btn admin-btn-sm admin-btn-secondary" %>
                  <%= link_to "View Application", admin_application_path(contract.application), class: "admin-btn admin-btn-sm admin-btn-primary" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-content">
        <h4>No contracts allocated yet</h4>
        <p>When applications with mortgages are accepted, contracts will be automatically allocated to available wholesale_funder pools.</p>
      </div>
    </div>
  <% end %>
</div>

<!-- Change History -->
<%= render 'shared/change_history', versions: @funder_pool.funder_pool_versions.recent %>

