<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
  <div class="container mx-auto px-6 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-5xl font-bold text-slate-900">Dashboard</h1>
      <p class="text-slate-600 mt-3 text-lg">Real-time portfolio metrics and performance analytics</p>
    </div>

    <!-- Portfolio KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <p class="text-slate-600 text-sm font-semibold uppercase tracking-wider">Total Applications</p>
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
        </div>
        <p class="text-4xl font-bold text-slate-900"><%= @total_applications %></p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <p class="text-slate-600 text-sm font-semibold uppercase tracking-wider">Capital Deployed</p>
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <p class="text-4xl font-bold text-slate-900"><%= number_to_currency(@total_capital_deployed || 0, precision: 0) %></p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <p class="text-slate-600 text-sm font-semibold uppercase tracking-wider">Active Investments</p>
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
        </div>
        <p class="text-4xl font-bold text-slate-900"><%= @active_investments %></p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <p class="text-slate-600 text-sm font-semibold uppercase tracking-wider">Total Distributions</p>
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
          </div>
        </div>
        <p class="text-4xl font-bold text-slate-900"><%= number_to_currency(@total_distributions || 0, precision: 0) %></p>
      </div>
    </div>

    <!-- Business Operations Navigation -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Business Operations</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <%= link_to admin_wholesale_funders_path, class: "block p-6 bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-lg hover:border-blue-400 transition-all group" do %>
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5.581m0 0H9m0 0h5.581M9 21h4m-4 0H7m4 0v-4m0 0V9m0 0h0"></path>
              </svg>
            </div>
            <h3 class="ml-4 text-lg font-bold text-slate-900">Wholesale Funders</h3>
          </div>
          <p class="text-sm text-slate-600">Manage funding allocations, deployments, and contracts</p>
        <% end %>

        <div class="block p-6 bg-slate-100 rounded-xl border border-slate-300 opacity-50 cursor-not-allowed">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="ml-4 text-lg font-bold text-slate-700">Lenders</h3>
          </div>
          <p class="text-sm text-slate-600">Coming next...</p>
        </div>

        <div class="block p-6 bg-slate-100 rounded-xl border border-slate-300 opacity-50 cursor-not-allowed">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
              </svg>
            </div>
            <h3 class="ml-4 text-lg font-bold text-slate-700">Brokers</h3>
          </div>
          <p class="text-sm text-slate-600">Coming next...</p>
        </div>

        <div class="block p-6 bg-slate-100 rounded-xl border border-slate-300 opacity-50 cursor-not-allowed">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="ml-4 text-lg font-bold text-slate-700">Agents</h3>
          </div>
          <p class="text-sm text-slate-600">Coming next...</p>
        </div>
      </div>
    </div>

    <!-- Application Funnel & Distribution Performance -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Application Funnel -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Application Funnel</h2>
        <div class="space-y-6">
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Pending</span>
              <span class="text-amber-600 font-bold text-lg"><%= @pending_applications %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-amber-400 to-amber-500 h-3 rounded-full" style="width: <%= @total_applications > 0 ? (@pending_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Approved</span>
              <span class="text-green-600 font-bold text-lg"><%= @approved_applications %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-green-400 to-green-500 h-3 rounded-full" style="width: <%= @total_applications > 0 ? (@approved_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Rejected</span>
              <span class="text-red-600 font-bold text-lg"><%= @rejected_applications %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-red-400 to-red-500 h-3 rounded-full" style="width: <%= @total_applications > 0 ? (@rejected_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Distribution Performance -->
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Distribution Performance</h2>
        <div class="space-y-6">
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Completed</span>
              <span class="text-green-600 font-bold text-lg"><%= @completed_distributions %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-green-400 to-green-500 h-3 rounded-full" style="width: <%= (@completed_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Pending</span>
              <span class="text-amber-600 font-bold text-lg"><%= @pending_distributions %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-amber-400 to-amber-500 h-3 rounded-full" style="width: <%= (@pending_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between mb-3">
              <span class="text-slate-700 font-semibold">Failed</span>
              <span class="text-red-600 font-bold text-lg"><%= @failed_distributions %></span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-3">
              <div class="bg-gradient-to-r from-red-400 to-red-500 h-3 rounded-full" style="width: <%= (@failed_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Regional Breakdown -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 mb-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">Regional Breakdown</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% @applications_by_region.each do |region, count| %>
          <div class="p-6 bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200 rounded-lg">
            <p class="text-slate-600 text-sm font-semibold uppercase tracking-wider"><%= region %></p>
            <p class="text-3xl font-bold text-slate-900 mt-3"><%= count %></p>
            <p class="text-sm text-slate-600 mt-4">
              Capital: <span class="font-semibold"><%= number_to_currency(@capital_by_region[region] || 0) %></span>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Applications -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">Recent Applications</h2>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b-2 border-slate-200">
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">ID</th>
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">Borrower</th>
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">Region</th>
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">Capital</th>
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">Status</th>
              <th class="text-left py-4 px-6 text-sm font-semibold text-slate-900 uppercase tracking-wider">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            <% @recent_applications.each do |app| %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="py-4 px-6 font-mono text-sm text-slate-600"><%= app.id %></td>
                <td class="py-4 px-6 text-slate-900 font-medium"><%= app.borrower_names || "N/A" %></td>
                <td class="py-4 px-6"><span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 rounded text-sm font-medium"><%= app.region&.upcase || "N/A" %></span></td>
                <td class="py-4 px-6 text-slate-900 font-semibold"><%= number_to_currency(app.equity_investment_amount || 0) %></td>
                <td class="py-4 px-6">
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold <%= case app.status
                    when 'accepted' then 'bg-green-100 text-green-800'
                    when 'rejected' then 'bg-red-100 text-red-800'
                    when 'submitted' then 'bg-amber-100 text-amber-800'
                    when 'activated' then 'bg-blue-100 text-blue-800'
                    else 'bg-slate-100 text-slate-800'
                  end %>">
                    <%= app.status&.humanize %>
                  </span>
                </td>
                <td class="py-4 px-6 text-slate-600 text-sm"><%= app.created_at.strftime("%d %b %Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
