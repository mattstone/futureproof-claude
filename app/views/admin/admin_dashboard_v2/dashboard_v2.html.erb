<div class="admin-content-wrapper">
  <!-- Header -->
  <div class="admin-section-header">
    <h1>Dashboard</h1>
    <p class="admin-section-subtitle">
      Real-time portfolio metrics and performance analytics
      <% if @current_jurisdiction != "Summary" %>
        <span class="admin-jurisdiction-badge"><%= @current_jurisdiction %></span>
      <% end %>
    </p>
  </div>

  <!-- Portfolio KPIs -->
  <div class="admin-metrics-grid">
    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Total Applications</span>
      </div>
      <p class="admin-metric-value"><%= @total_applications %></p>
    </div>

    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Capital Deployed</span>
      </div>
      <p class="admin-metric-value"><%= number_to_currency(@total_capital_deployed || 0, precision: 0) %></p>
    </div>

    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Active Investments</span>
      </div>
      <p class="admin-metric-value"><%= @active_investments %></p>
    </div>

    <div class="admin-metric-card">
      <div class="admin-metric-top">
        <span class="admin-metric-label">Total Distributions</span>
      </div>
      <p class="admin-metric-value"><%= number_to_currency(@total_distributions || 0, precision: 0) %></p>
    </div>
  </div>

  <!-- Business Operations Navigation -->
  <div class="admin-section">
    <h2>Business Operations</h2>
    <div class="admin-nav-grid">
      <%= link_to admin_wholesale_funders_path, class: "admin-nav-card" do %>
        <span class="admin-nav-title">Wholesale Funders</span>
        <span class="admin-nav-desc">Manage funding allocations, deployments, and contracts</span>
      <% end %>

      <%= link_to admin_lenders_path, class: "admin-nav-card" do %>
        <span class="admin-nav-title">Lenders</span>
        <span class="admin-nav-desc">Manage lender profiles, relationships, and assignments</span>
      <% end %>

      <div class="admin-nav-card admin-nav-card-disabled">
        <span class="admin-nav-title">Brokers</span>
        <span class="admin-nav-desc">Coming next...</span>
      </div>

      <div class="admin-nav-card admin-nav-card-disabled">
        <span class="admin-nav-title">Agents</span>
        <span class="admin-nav-desc">Coming next...</span>
      </div>
    </div>
  </div>

  <!-- Application Funnel & Distribution Performance -->
  <div class="admin-two-column">
    <!-- Application Funnel -->
    <div class="admin-card">
      <h2>Application Funnel</h2>
      <div class="admin-progress-section">
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Pending</span>
            <span class="admin-progress-value"><%= @pending_applications %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-pending" style="width: <%= @total_applications > 0 ? (@pending_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
          </div>
        </div>
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Approved</span>
            <span class="admin-progress-value"><%= @approved_applications %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-success" style="width: <%= @total_applications > 0 ? (@approved_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
          </div>
        </div>
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Rejected</span>
            <span class="admin-progress-value"><%= @rejected_applications %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-danger" style="width: <%= @total_applications > 0 ? (@rejected_applications.to_f / @total_applications * 100).round : 0 %>%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Distribution Performance -->
    <div class="admin-card">
      <h2>Distribution Performance</h2>
      <div class="admin-progress-section">
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Completed</span>
            <span class="admin-progress-value"><%= @completed_distributions %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-success" style="width: <%= (@completed_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
          </div>
        </div>
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Pending</span>
            <span class="admin-progress-value"><%= @pending_distributions %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-pending" style="width: <%= (@pending_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
          </div>
        </div>
        <div class="admin-progress-item">
          <div class="admin-progress-header">
            <span>Failed</span>
            <span class="admin-progress-value"><%= @failed_distributions %></span>
          </div>
          <div class="admin-progress-bar">
            <div class="admin-progress-fill admin-progress-fill-danger" style="width: <%= (@failed_distributions.to_f / (@completed_distributions + @pending_distributions + @failed_distributions).to_f * 100).round rescue 0 %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Regional Breakdown -->
  <div class="admin-card">
    <h2>Regional Breakdown</h2>
    <div class="admin-region-grid">
      <% @applications_by_region.each do |region, count| %>
        <div class="admin-region-card">
          <p class="admin-region-label"><%= region %></p>
          <p class="admin-region-value"><%= count %></p>
          <p class="admin-region-detail">
            Capital: <span class="admin-region-capital"><%= number_to_currency(@capital_by_region[region] || 0) %></span>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Applications -->
  <div class="admin-card">
    <h2>Recent Applications</h2>
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Borrower</th>
            <th>Region</th>
            <th>Capital</th>
            <th>Status</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_applications.each do |app| %>
            <tr>
              <td><code><%= app.id %></code></td>
              <td><%= app.borrower_names || "N/A" %></td>
              <td><span class="admin-badge"><%= app.region&.upcase || "N/A" %></span></td>
              <td><strong><%= number_to_currency(app.equity_investment_amount || 0) %></strong></td>
              <td>
                <span class="admin-badge <%= case app.status
                  when 'accepted' then 'admin-badge-accepted'
                  when 'rejected' then 'admin-badge-rejected'
                  when 'submitted' then 'admin-badge-pending'
                  when 'activated' then 'admin-badge-activated'
                  else ''
                end %>">
                  <%= app.status&.humanize %>
                </span>
              </td>
              <td><%= app.created_at.strftime("%d %b %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
