<%= stylesheet_link_tag "admin/email_workflows", "data-turbo-track": "reload" %>
<% content_for :title, @workflow.name %>
<% content_for :breadcrumb do %>
  <%= link_to "Workflows", admin_email_workflows_path, class: "breadcrumb-link" %>
  <span class="breadcrumb-separator">→</span>
  <span><%= @workflow.name %></span>
<% end %>

<div class="workflow-detail-container">
  <!-- Hero Header -->
  <div class="workflow-hero">
    <div class="workflow-hero-content">
      <div class="workflow-identity">
        <div class="workflow-status-badge">
          <div class="status-dot <%= @workflow.active? ? 'active' : 'inactive' %>"></div>
          <span class="status-text"><%= @workflow.active? ? 'Active' : 'Inactive' %></span>
        </div>
        <h1 class="workflow-title"><%= @workflow.name %></h1>
        <% if @workflow.description.present? %>
          <p class="workflow-description"><%= @workflow.description %></p>
        <% end %>
        <div class="workflow-meta">
          <span class="meta-item">
            <i class="fas fa-bolt"></i>
            Triggered by <%= @workflow.trigger_type.humanize %>
          </span>
          <span class="meta-item">
            <i class="fas fa-layer-group"></i>
            <%= pluralize(@workflow.workflow_steps.count, 'step') %>
          </span>
          <span class="meta-item">
            <i class="fas fa-user"></i>
            Created by <%= @workflow.created_by.display_name %>
          </span>
        </div>
      </div>
      
      <div class="workflow-actions">
        <div class="action-buttons">
          <%= link_to edit_admin_email_workflow_path(@workflow), class: "btn site-btn-secondary" do %>
            <i class="fas fa-edit"></i> Edit Workflow
          <% end %>
          <%= link_to preview_admin_email_workflow_path(@workflow), class: "btn site-btn-secondary" do %>
            <i class="fas fa-eye"></i> Preview
          <% end %>
          <%= link_to toggle_active_admin_email_workflow_path(@workflow), 
                     method: :patch, class: "btn site-btn-secondary toggle-btn" do %>
            <i class="fas fa-<%= @workflow.active? ? 'pause' : 'play' %>"></i>
            <%= @workflow.active? ? 'Pause' : 'Activate' %>
          <% end %>
        </div>
        <div class="secondary-actions">
          <%= link_to duplicate_admin_email_workflow_path(@workflow), 
                     method: :post, class: "btn btn-ghost btn-sm" do %>
            <i class="fas fa-copy"></i> Duplicate
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Performance Dashboard -->
  <div class="performance-dashboard">
    <div class="dashboard-header">
      <h2 class="dashboard-title">Performance Overview</h2>
      <div class="dashboard-period">Last 30 days</div>
    </div>
    
    <div class="metrics-grid">
      <div class="metric-card primary">
        <div class="metric-icon">
          <i class="fas fa-play-circle"></i>
        </div>
        <div class="metric-content">
          <div class="metric-value"><%= @execution_stats[:total] %></div>
          <div class="metric-label">Total Executions</div>
          <div class="metric-trend">
            <% if @execution_stats[:total] > 0 %>
              <span class="trend-positive">+<%= @execution_stats[:total] %> this month</span>
            <% else %>
              <span class="trend-neutral">No executions yet</span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="metric-card success">
        <div class="metric-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <div class="metric-content">
          <div class="metric-value"><%= @execution_stats[:success_rate] %>%</div>
          <div class="metric-label">Success Rate</div>
          <div class="metric-trend">
            <% if @execution_stats[:success_rate] >= 90 %>
              <span class="trend-positive">Excellent performance</span>
            <% elsif @execution_stats[:success_rate] >= 75 %>
              <span class="trend-neutral">Good performance</span>
            <% else %>
              <span class="trend-negative">Needs attention</span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="metric-card warning">
        <div class="metric-icon">
          <i class="fas fa-clock"></i>
        </div>
        <div class="metric-content">
          <div class="metric-value"><%= @execution_stats[:running] + @execution_stats[:pending] %></div>
          <div class="metric-label">In Progress</div>
          <div class="metric-trend">
            <span class="trend-neutral">
              <%= @execution_stats[:running] %> running, <%= @execution_stats[:pending] %> pending
            </span>
          </div>
        </div>
      </div>

      <div class="metric-card danger">
        <div class="metric-icon">
          <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="metric-content">
          <div class="metric-value"><%= @execution_stats[:failed] %></div>
          <div class="metric-label">Failed</div>
          <div class="metric-trend">
            <% if @execution_stats[:failed] == 0 %>
              <span class="trend-positive">No failures</span>
            <% elsif @execution_stats[:failed] < 5 %>
              <span class="trend-neutral">Minor issues</span>
            <% else %>
              <span class="trend-negative">Requires investigation</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="workflow-main-content">
    <!-- Workflow Flow Visualization -->
    <div class="workflow-flow-section">
      <div class="section-header">
        <h2 class="section-title">
          <i class="fas fa-project-diagram"></i>
          Workflow Steps
        </h2>
        <div class="section-badge">
          <%= pluralize(@workflow.workflow_steps.count, 'step') %>
        </div>
      </div>

      <% if @workflow.workflow_steps.any? %>
        <div class="workflow-flow">
          <!-- Trigger -->
          <div class="flow-node trigger-node">
            <div class="node-icon">
              <i class="fas fa-bolt"></i>
            </div>
            <div class="node-content">
              <h4 class="node-title">Trigger</h4>
              <p class="node-description"><%= @workflow.trigger_type.humanize %></p>
              <% if @workflow.trigger_conditions.present? && @workflow.trigger_conditions.any? %>
                <div class="node-conditions">
                  <% @workflow.trigger_conditions.each do |key, value| %>
                    <span class="condition-tag">
                      <%= key.humanize %>: <%= value %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Flow connector -->
          <div class="flow-connector">
            <div class="connector-line"></div>
            <div class="connector-arrow">
              <i class="fas fa-chevron-down"></i>
            </div>
          </div>

          <!-- Steps -->
          <div class="workflow-steps">
            <% @workflow.workflow_steps.ordered.each_with_index do |step, index| %>
              <div class="flow-node step-node">
                <div class="step-number-badge">
                  <%= index + 1 %>
                </div>
                <div class="node-icon step-icon">
                  <%= render 'step_icon', step: step %>
                </div>
                <div class="node-content">
                  <h4 class="node-title">
                    <%= step.name.present? ? step.name : step.step_type.humanize %>
                  </h4>
                  <div class="node-type-badge">
                    <%= step.step_type.humanize %>
                  </div>
                  
                  <% if step.description.present? %>
                    <p class="node-description"><%= step.description %></p>
                  <% end %>

                  <!-- Step Configuration Preview -->
                  <div class="node-config">
                    <% case step.step_type %>
                    <% when 'send_email' %>
                      <% if step.configuration['email_template_id'].present? %>
                        <% template = EmailTemplate.find_by(id: step.configuration['email_template_id']) %>
                        <div class="config-item">
                          <i class="fas fa-envelope"></i>
                          <span>Template: 
                            <%= template ? link_to(template.name, admin_email_template_path(template), class: 'config-link', target: '_blank') : 'Template not found' %>
                          </span>
                        </div>
                      <% end %>
                    <% when 'delay' %>
                      <div class="config-item">
                        <i class="fas fa-clock"></i>
                        <span>Wait <%= step.configuration['duration'] %> <%= step.configuration['unit'] %></span>
                      </div>
                    <% when 'condition' %>
                      <div class="config-item">
                        <i class="fas fa-code-branch"></i>
                        <span>
                          <%= step.configuration['condition_type']&.humanize || 'Condition check' %>
                          <% if step.configuration['expected_status'].present? %>
                            → <%= step.configuration['expected_status'] %>
                          <% end %>
                        </span>
                      </div>
                    <% when 'update_status' %>
                      <div class="config-item">
                        <i class="fas fa-edit"></i>
                        <span>Update <%= step.configuration['field'] %> to "<%= step.configuration['value'] %>"</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>

              <% unless step == @workflow.workflow_steps.ordered.last %>
                <div class="flow-connector">
                  <div class="connector-line"></div>
                  <div class="connector-arrow">
                    <i class="fas fa-chevron-down"></i>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="empty-workflow">
          <div class="empty-icon">
            <i class="fas fa-project-diagram"></i>
          </div>
          <h3>No Steps Configured</h3>
          <p>This workflow doesn't have any steps yet. Add some steps to define what happens when this workflow is triggered.</p>
          <%= link_to edit_admin_email_workflow_path(@workflow), class: "btn site-btn-primary" do %>
            <i class="fas fa-plus"></i> Add Steps
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Recent Activity -->
    <div class="workflow-activity-section">
      <div class="section-header">
        <h2 class="section-title">
          <i class="fas fa-history"></i>
          Recent Activity
        </h2>
        <% if @executions.any? %>
          <div class="section-badge">
            <%= @executions.limit(10).count %> of <%= @executions.count %>
          </div>
        <% end %>
      </div>

      <% if @executions.any? %>
        <div class="activity-timeline">
          <% @executions.limit(10).each do |execution| %>
            <div class="timeline-item">
              <div class="timeline-marker">
                <div class="status-dot <%= execution.status %>"></div>
              </div>
              <div class="timeline-content">
                <div class="activity-header">
                  <div class="activity-title">
                    Workflow executed for 
                    <span class="activity-target">
                      <% if execution.target.respond_to?(:user) %>
                        <%= execution.target.user.display_name %>
                      <% elsif execution.target.respond_to?(:display_name) %>
                        <%= execution.target.display_name %>
                      <% else %>
                        <%= execution.target.class.name %> #<%= execution.target.id %>
                      <% end %>
                    </span>
                  </div>
                  <div class="activity-status status-<%= execution.status %>">
                    <i class="fas fa-<%= case execution.status
                      when 'completed' then 'check-circle'
                      when 'failed' then 'times-circle'
                      when 'running' then 'play-circle'
                      else 'clock'
                      end %>"></i>
                    <%= execution.status.humanize %>
                  </div>
                </div>
                <div class="activity-meta">
                  <span class="activity-time">
                    <i class="fas fa-clock"></i>
                    <%= time_ago_in_words(execution.created_at) %> ago
                  </span>
                  <% if execution.completed_at %>
                    <span class="activity-duration">
                      <i class="fas fa-stopwatch"></i>
                      Took <%= distance_of_time_in_words(execution.created_at, execution.completed_at) %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>

          <% if @executions.count > 10 %>
            <div class="timeline-item more-items">
              <div class="timeline-marker">
                <div class="status-dot neutral"></div>
              </div>
              <div class="timeline-content">
                <div class="more-items-text">
                  <i class="fas fa-ellipsis-h"></i>
                  <%= @executions.count - 10 %> more executions...
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-activity">
          <div class="empty-icon">
            <i class="fas fa-history"></i>
          </div>
          <h3>No Activity Yet</h3>
          <p>This workflow hasn't been triggered yet. When it runs, you'll see the execution history here.</p>
          <% if @workflow.active? %>
            <div class="help-text">
              <i class="fas fa-info-circle"></i>
              This workflow will trigger automatically when the conditions are met.
            </div>
          <% else %>
            <div class="help-text warning">
              <i class="fas fa-pause-circle"></i>
              This workflow is currently inactive and won't trigger automatically.
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Workflow Details -->
  <div class="workflow-details-section">
    <div class="section-header">
      <h2 class="section-title">
        <i class="fas fa-info-circle"></i>
        Workflow Details
      </h2>
    </div>
    
    <div class="details-grid">
      <div class="detail-item">
        <label class="detail-label">Workflow ID</label>
        <span class="detail-value mono"><%= @workflow.id %></span>
      </div>
      
      <div class="detail-item">
        <label class="detail-label">Created</label>
        <span class="detail-value">
          <%= @workflow.created_at.strftime('%B %d, %Y at %I:%M %p') %>
        </span>
      </div>
      
      <div class="detail-item">
        <label class="detail-label">Last Modified</label>
        <span class="detail-value">
          <%= @workflow.updated_at.strftime('%B %d, %Y at %I:%M %p') %>
        </span>
      </div>
      
      <div class="detail-item">
        <label class="detail-label">Created By</label>
        <span class="detail-value">
          <%= @workflow.created_by.display_name %>
        </span>
      </div>
    </div>
  </div>
</div>

