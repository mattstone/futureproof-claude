<% content_for :page_title, "Agent Overview — Timeline" %>

<div class="agent-page-header">
  <p>Full chronological log of all AI agent actions.</p>
</div>

<div class="admin-tabs">
  <%= link_to "Activity", admin_agent_dashboard_index_path, class: "admin-tab" %>
  <%= link_to "Configuration", admin_agent_lifecycle_index_path, class: "admin-tab" %>
  <%= link_to "Timeline", timeline_admin_agent_dashboard_index_path, class: "admin-tab active" %>
</div>

<!-- Filters -->
<div class="agent-filter-bar">
  <span class="agent-filter-label">Filter:</span>
  <select id="filter-agent" onchange="filterTimeline()" class="agent-filter-select">
    <option value="">All Agents</option>
    <% @agents.each do |agent| %>
      <option value="<%= agent.name %>"><%= agent.name %></option>
    <% end %>
  </select>
  <select id="filter-action-type" onchange="filterTimeline()" class="agent-filter-select">
    <option value="">All Action Types</option>
    <% AgentAction::ACTION_TYPES.each do |t| %>
      <option value="<%= t %>"><%= t.titleize %></option>
    <% end %>
  </select>
  <select id="filter-decision" onchange="filterTimeline()" class="agent-filter-select">
    <option value="">All Decisions</option>
    <% AgentAction::DECISIONS.each do |d| %>
      <option value="<%= d %>"><%= d.titleize %></option>
    <% end %>
  </select>
</div>

<!-- Timeline -->
<div class="timeline-container">
  <div class="timeline-line"></div>

  <% if @actions.any? %>
    <% @actions.each do |action| %>
      <% dot_class = case action.decision
        when 'approve' then 'timeline-dot-approve'
        when 'flag' then 'timeline-dot-flag'
        when 'reject' then 'timeline-dot-reject'
        else 'timeline-dot-other'
        end %>
      <div class="timeline-entry" data-agent="<%= action.ai_agent.name %>" data-action-type="<%= action.action_type %>" data-decision="<%= action.decision %>">
        <div class="timeline-dot <%= dot_class %>"></div>

        <div class="timeline-entry-header">
          <%= image_tag action.ai_agent.avatar_path, class: "avatar-sm" %>
          <strong class="timeline-entry-name"><%= action.ai_agent.name %></strong>
          <span class="action-type-badge"><%= action.action_type %></span>
          <% if action.decision %>
            <% decision_class = case action.decision
              when 'approve' then 'decision-approve'
              when 'flag' then 'decision-flag'
              when 'reject' then 'decision-reject'
              else 'decision-other'
              end %>
            <span class="decision-badge <%= decision_class %>"><%= action.decision %></span>
          <% end %>
          <% if action.confidence %>
            <span class="timeline-entry-confidence">Confidence: <strong><%= (action.confidence * 100).round(0) %>%</strong></span>
          <% end %>
          <span class="timeline-entry-time"><%= time_ago_in_words(action.created_at) %> ago</span>
        </div>

        <% if action.reasoning.present? %>
          <div class="timeline-entry-reasoning"><%= truncate(action.reasoning, length: 200) %></div>
        <% end %>

        <% if action.actionable_type.present? %>
          <div class="timeline-entry-entity"><%= action.actionable_type %> #<%= action.actionable_id %></div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="agent-empty-state">
      <div class="agent-empty-state-icon">📜</div>
      <div class="agent-empty-state-title">No timeline entries</div>
      <div class="agent-empty-state-text">Agent actions will appear here chronologically as they occur.</div>
    </div>
  <% end %>
</div>

<script>
function filterTimeline() {
  var agent = document.getElementById('filter-agent').value;
  var actionType = document.getElementById('filter-action-type').value;
  var decision = document.getElementById('filter-decision').value;
  document.querySelectorAll('.timeline-entry').forEach(function(el) {
    var show = true;
    if (agent && el.dataset.agent !== agent) show = false;
    if (actionType && el.dataset.actionType !== actionType) show = false;
    if (decision && el.dataset.decision !== decision) show = false;
    el.style.display = show ? '' : 'none';
  });
}
</script>
