<% content_for :page_title, "Agent Overview" %>

<div class="agent-page-header">
  <h1>🤖 Agent Overview</h1>
  <p>Monitor AI agent decisions, confidence scores, and activity across the platform.</p>
</div>

<div class="admin-tabs">
  <%= link_to "Activity", admin_agent_dashboard_index_path, class: "admin-tab #{'active' unless params[:tab]}" %>
  <%= link_to "Configuration", admin_agent_lifecycle_index_path, class: "admin-tab" %>
  <%= link_to "Timeline", timeline_admin_agent_dashboard_index_path, class: "admin-tab" %>
</div>

<!-- Flagged Items Requiring Human Review -->
<% flagged_actions = AgentAction.where(decision: ['flag', 'escalate']).where(status: 'completed').includes(:ai_agent).order(created_at: :desc).limit(10) %>
<% if flagged_actions.any? %>
  <div class="flagged-items-panel">
    <h2>⚠️ Requires Human Review (<%= flagged_actions.count %>)</h2>
    <% flagged_actions.each do |action| %>
      <div class="flagged-item">
        <div class="flagged-item-header">
          <img src="<%= action.ai_agent.avatar_path %>" class="avatar-sm">
          <strong><%= action.ai_agent.name %></strong> flagged
          <% if action.actionable_type == 'Application' %>
            <a href="<%= admin_application_path(action.actionable_id) %>">
              <%= action.actionable_type %> #<%= action.actionable_id %>
            </a>
          <% else %>
            <%= action.actionable_type %> #<%= action.actionable_id %>
          <% end %>
        </div>
        <div class="flagged-item-reasoning"><%= action.reasoning %></div>
        <div class="flagged-item-meta">
          Confidence: <%= (action.confidence * 100).round(0) %>% ·
          Risk Score: <%= action.result&.dig('risk_score') || 'N/A' %> ·
          <%= time_ago_in_words(action.created_at) %> ago
        </div>
        <div class="flagged-item-actions">
          <%= button_to "✅ Override — Approve", override_admin_agent_dashboard_path(action),
              method: :patch, params: { decision: 'approve', reason: '' },
              class: "btn-override btn-override-approve",
              data: { confirm: "Override this decision to APPROVE?" } %>
          <%= button_to "❌ Override — Reject", override_admin_agent_dashboard_path(action),
              method: :patch, params: { decision: 'reject', reason: '' },
              class: "btn-override btn-override-reject",
              data: { confirm: "Override this decision to REJECT?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Agent Cards -->
<div class="agent-cards-grid">
  <% @agents.each do |agent| %>
    <% agent_stats = @stats[agent.id] || { total: 0, approval_rate: 0, avg_confidence: 0, flags: 0, rejections: 0, last_action_at: nil } %>
    <div class="agent-card">
      <div class="agent-card-header">
        <%= image_tag agent.avatar_path, class: "avatar-lg" %>
        <div>
          <h3><%= agent.name %></h3>
          <div class="agent-card-subtitle"><%= agent.agent_type.titleize %> Agent</div>
          <% if agent.respond_to?(:description) && agent.description.present? %>
            <div class="agent-card-description"><%= truncate(agent.description, length: 80) %></div>
          <% end %>
        </div>
      </div>

      <div class="agent-stat-grid">
        <div class="agent-stat-item agent-stat-item-neutral">
          <div class="agent-stat-value"><%= agent_stats[:total] %></div>
          <div class="agent-stat-label">Actions</div>
        </div>
        <div class="agent-stat-item agent-stat-item-success">
          <div class="agent-stat-value agent-stat-value-success"><%= agent_stats[:approval_rate] %>%</div>
          <div class="agent-stat-label">Approval Rate</div>
        </div>
        <div class="agent-stat-item agent-stat-item-info">
          <div class="agent-stat-value agent-stat-value-info"><%= agent_stats[:avg_confidence] %></div>
          <div class="agent-stat-label">Avg Confidence</div>
        </div>
        <div class="agent-stat-item agent-stat-item-danger">
          <div class="agent-stat-value agent-stat-value-danger"><%= agent_stats[:flags] + agent_stats[:rejections] %></div>
          <div class="agent-stat-label">Flags + Rejects</div>
        </div>
      </div>

      <div class="agent-card-meta">
        Last action: <%= agent_stats[:last_action_at] ? time_ago_in_words(agent_stats[:last_action_at]) + " ago" : "No actions yet" %>
      </div>

      <%= link_to "View Details →", admin_agent_dashboard_path(agent), class: "agent-view-link" %>
    </div>
  <% end %>
</div>

<!-- Recent Activity -->
<div class="agent-panel">
  <div class="agent-panel-header">
    <h2>Recent Activity</h2>
    <%= link_to "View Full Timeline →", timeline_admin_agent_dashboard_index_path, class: "agent-panel-link" %>
  </div>

  <% if @recent_actions.any? %>
    <div class="activity-feed">
      <% @recent_actions.first(20).each do |action| %>
        <div class="activity-feed-item">
          <%= image_tag action.ai_agent.avatar_path, class: "avatar-md" %>
          <div class="activity-feed-content">
            <strong class="activity-feed-name"><%= action.ai_agent.name %></strong>
            <span class="action-type-badge"><%= action.action_type %></span>
            <% if action.decision %>
              <% decision_class = case action.decision
                when 'approve' then 'decision-approve'
                when 'flag' then 'decision-flag'
                when 'reject' then 'decision-reject'
                else 'decision-other'
                end %>
              <span class="decision-badge <%= decision_class %>"><%= action.decision %></span>
            <% end %>
            <% if action.actionable_type.present? %>
              <span class="activity-feed-entity"><%= action.actionable_type %> #<%= action.actionable_id %></span>
            <% end %>
          </div>
          <span class="activity-feed-time"><%= time_ago_in_words(action.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="agent-empty-state">
      <div class="agent-empty-state-icon">🔍</div>
      <div class="agent-empty-state-title">No activity yet</div>
      <div class="agent-empty-state-text">Agent actions will appear here once your AI agents start processing applications.</div>
    </div>
  <% end %>
</div>
