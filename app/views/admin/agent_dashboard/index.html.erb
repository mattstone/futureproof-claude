<% content_for :page_title, "Agent Performance" %>

<div class="agent-dashboard">
  <p class="subtitle">Real-time agent metrics and activity</p>

  <div class="metrics-grid">
    <div class="metric-card">
      <p class="label">Total Agents</p>
      <p class="value"><%= @agents.count %></p>
    </div>
    <div class="metric-card">
      <p class="label">Tasks Completed (Today)</p>
      <p class="value"><%= @agents.sum(:tasks_completed_today) %></p>
    </div>
    <div class="metric-card">
      <p class="label">Avg Resolution Time</p>
      <p class="value"><%= number_with_precision(@agents.average(:avg_resolution_minutes).to_i, precision: 0) %> min</p>
    </div>
    <div class="metric-card">
      <p class="label">Avg Satisfaction</p>
      <p class="value"><%= number_with_precision(@agents.average(:satisfaction_score), precision: 1) %>/5</p>
    </div>
  </div>

  <div class="agents-grid">
    <% @agents.each do |agent| %>
      <div class="agent-card">
        <div class="agent-header">
          <h3><%= agent.agent_type.humanize %></h3>
          <span class="status-badge <%= agent.status %>"><%= agent.status.upcase %></span>
        </div>
        <div class="agent-metrics">
          <p><strong>Tasks (Today):</strong> <%= agent.tasks_completed_today %></p>
          <p><strong>Avg Resolution:</strong> <%= agent.avg_resolution_minutes %> min</p>
          <p><strong>Satisfaction:</strong> <span class="rating"><%= number_with_precision(agent.satisfaction_score, precision: 1) %>/5</span></p>
          <p><strong>Quality Score:</strong> <span class="rating"><%= number_with_precision(agent.quality_score, precision: 1) %>/5</span></p>
        </div>
        <div class="agent-chart">
          <div class="sparkline" data-values="<%= agent.agent_tasks.order(:completed_at).limit(7).pluck(:resolution_minutes).compact.join(',') %>"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="activity-stream">
    <h2>Recent Activity</h2>
    <% @recent_tasks.each do |task| %>
      <div class="activity-item">
        <p><strong><%= task.task_type %></strong> completed in <%= task.resolution_minutes %> minutes</p>
        <p class="time"><%= time_ago_in_words(task.completed_at) %> ago</p>
      </div>
    <% end %>
  </div>
</div>

