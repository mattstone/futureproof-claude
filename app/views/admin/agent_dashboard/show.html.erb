<% content_for :page_title, "#{@agent.name} — Agent Detail" %>

<%= link_to "← Back to Command Center", admin_agent_dashboard_index_path, class: "agent-back-link" %>

<!-- Agent Profile -->
<div class="agent-panel agent-panel-mb">
  <div class="agent-profile-header">
    <%= image_tag @agent.avatar_path, class: "avatar-xl" %>
    <div>
      <div class="agent-profile-name"><%= @agent.name %></div>
      <div class="agent-profile-subtitle"><%= @agent.agent_type.titleize %> Agent</div>
      <% if @agent.respond_to?(:description) && @agent.description.present? %>
        <div class="agent-profile-description"><%= @agent.description %></div>
      <% end %>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="agent-stats-row">
  <div class="metric-card">
    <div class="metric-content">
      <h3><%= @total_actions %></h3>
      <p>Total Actions</p>
    </div>
  </div>
  <div class="metric-card">
    <div class="metric-content">
      <h3 class="agent-stat-value-success"><%= @approval_rate %>%</h3>
      <p>Approval Rate</p>
    </div>
  </div>
  <div class="metric-card">
    <div class="metric-content">
      <h3 class="agent-stat-value-info"><%= @avg_confidence %></h3>
      <p>Avg Confidence</p>
    </div>
  </div>
  <div class="metric-card">
    <div class="metric-content">
      <h3 class="agent-stat-value-warning"><%= @flags_count %></h3>
      <p>Flags</p>
    </div>
  </div>
  <div class="metric-card">
    <div class="metric-content">
      <h3 class="agent-stat-value-danger"><%= @rejections_count %></h3>
      <p>Rejections</p>
    </div>
  </div>
</div>

<!-- Decision Breakdown -->
<div class="agent-breakdown-grid">
  <div class="agent-panel">
    <h3>Decisions</h3>
    <% @decision_breakdown.each do |decision, count| %>
      <% next if decision.nil? %>
      <% pct = @total_actions > 0 ? (count.to_f / @total_actions * 100).round(1) : 0 %>
      <div class="agent-breakdown-item">
        <div class="agent-breakdown-label">
          <span><%= decision %></span>
          <span><%= count %> (<%= pct %>%)</span>
        </div>
        <div class="agent-progress-track">
          <% progress_class = case decision
            when 'approve' then 'agent-progress-approve'
            when 'flag' then 'agent-progress-flag'
            when 'reject' then 'agent-progress-reject'
            else 'agent-progress-other'
            end %>
          <div class="agent-progress-bar <%= progress_class %>" style="width: <%= pct %>%;"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="agent-panel">
    <h3>Action Types</h3>
    <% @action_type_breakdown.each do |action_type, count| %>
      <% pct = @total_actions > 0 ? (count.to_f / @total_actions * 100).round(1) : 0 %>
      <div class="agent-breakdown-item">
        <div class="agent-breakdown-label">
          <span><%= action_type %></span>
          <span><%= count %> (<%= pct %>%)</span>
        </div>
        <div class="agent-progress-track">
          <div class="agent-progress-bar agent-progress-other" style="width: <%= pct %>%;"></div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Action Log Table -->
<div class="agent-panel">
  <h3>Action Log</h3>

  <% if @actions.any? %>
    <table class="agent-action-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Action</th>
          <th>Entity</th>
          <th>Decision</th>
          <th>Confidence</th>
          <th>Reasoning</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @actions.each do |action| %>
          <tr title="<%= action.reasoning %>">
            <td class="cell-time"><%= action.created_at.strftime("%b %d, %H:%M") %></td>
            <td>
              <span class="action-type-badge"><%= action.action_type %></span>
            </td>
            <td class="cell-entity">
              <% if action.actionable_type.present? %>
                <%= action.actionable_type %> #<%= action.actionable_id %>
              <% else %>
                —
              <% end %>
            </td>
            <td>
              <% if action.decision %>
                <% decision_class = case action.decision
                  when 'approve' then 'decision-approve'
                  when 'flag' then 'decision-flag'
                  when 'reject' then 'decision-reject'
                  else 'decision-other'
                  end %>
                <span class="decision-badge <%= decision_class %>"><%= action.decision %></span>
              <% end %>
            </td>
            <td>
              <% if action.confidence %>
                <% conf_class = if action.confidence >= 0.8
                    'confidence-high'
                  elsif action.confidence >= 0.6
                    'confidence-medium'
                  else
                    'confidence-low'
                  end %>
                <span class="<%= conf_class %>"><%= (action.confidence * 100).round(0) %>%</span>
              <% else %>
                —
              <% end %>
            </td>
            <td class="cell-reasoning"><%= truncate(action.reasoning || "—", length: 60) %></td>
            <td>
              <% status_class = case action.status
                when 'completed' then 'status-completed'
                when 'overridden' then 'status-overridden'
                when 'failed' then 'status-failed'
                else 'status-default'
                end %>
              <span class="<%= status_class %>"><%= action.status %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="agent-empty-state">
      <div class="agent-empty-state-icon">📋</div>
      <div class="agent-empty-state-title">No actions recorded</div>
      <div class="agent-empty-state-text">This agent hasn't performed any actions yet. Actions will appear here once <%= @agent.name %> starts processing.</div>
    </div>
  <% end %>
</div>
