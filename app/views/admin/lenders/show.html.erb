<% content_for :page_title, @lender.name %>

<div class="admin-content-wrapper">
  <!-- Header with Actions -->
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <h2><%= @lender.name %></h2>
        <div class="admin-badges">
          <span class="admin-badge admin-badge-<%= @lender.lender_type %>">
            <%= @lender.lender_type.humanize %>
          </span>
          <% if @lender.lender_type_futureproof? %>
            <span class="admin-badge admin-badge-futureproof">FUTUREPROOF</span>
          <% end %>
        </div>
      </div>
      <div class="admin-card-actions">
        <%= link_to "Edit", edit_admin_lender_path(@lender), class: "admin-btn admin-btn-primary" %>
        <% unless @lender.lender_type_futureproof? %>
          <%= link_to "Delete", admin_lender_path(@lender), method: :delete,
              data: { turbo_confirm: "Delete #{@lender.name}?" },
              class: "admin-btn admin-btn-danger" %>
        <% end %>
        <%= link_to "Back", admin_lenders_path, class: "admin-btn admin-btn-secondary" %>
      </div>
    </div>

    <!-- Details Grid -->
    <div class="admin-detail-grid">
      <div class="admin-detail-item">
        <span class="admin-detail-label">Country</span>
        <span class="admin-detail-value"><code><%= @lender.country %></code></span>
      </div>
      <div class="admin-detail-item">
        <span class="admin-detail-label">Email</span>
        <span class="admin-detail-value">
          <%= link_to @lender.contact_email, "mailto:#{@lender.contact_email}", class: "admin-link" %>
        </span>
      </div>
      <div class="admin-detail-item">
        <span class="admin-detail-label">Phone</span>
        <span class="admin-detail-value">
          <% if @lender.contact_telephone.present? %>
            <%= "#{@lender.contact_telephone_country_code} #{@lender.contact_telephone}" %>
          <% else %>
            <em class="admin-text-muted">Not set</em>
          <% end %>
        </span>
      </div>
      <div class="admin-detail-item">
        <span class="admin-detail-label">Applications</span>
        <span class="admin-detail-value"><strong><%= @lender.applications.count %></strong></span>
      </div>
    </div>
  </div>

  <!-- Wholesale Funders -->
  <div class="admin-card">
    <div class="admin-card-header">
      <h2>Wholesale Funders</h2>
      <div class="admin-card-actions">
        <%= link_to "➕ Add Funder", new_admin_lender_wholesale_funder_path(@lender), class: "admin-btn admin-btn-primary admin-btn-sm" %>
      </div>
    </div>

    <% if @lender.lender_wholesale_funders.any? %>
      <table class="admin-table admin-table-compact">
        <thead>
          <tr>
            <th>Name</th>
            <th>Country</th>
            <th>Currency</th>
            <th>Status</th>
            <th class="admin-actions-cell">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @lender.lender_wholesale_funders.includes(:wholesale_funder).each do |rel| %>
            <tr>
              <td><strong><%= rel.wholesale_funder.name %></strong></td>
              <td><code><%= rel.wholesale_funder.country %></code></td>
              <td><%= rel.wholesale_funder.currency %></td>
              <td>
                <span class="admin-badge <%= rel.active? ? 'admin-badge-active' : 'admin-badge-inactive' %>">
                  <%= rel.active? ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td class="admin-actions-cell">
                <%= link_to "Remove", admin_lender_wholesale_funder_path(@lender, rel), 
                    method: :delete, data: { turbo_confirm: "Remove?" },
                    class: "admin-link-btn admin-link-btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="admin-text-muted">No wholesale funders connected. Use the "Add Funder" button to create relationships.</p>
    <% end %>
  </div>

  <!-- Funder Pools -->
  <div class="admin-card">
    <div class="admin-card-header">
      <h2>Funder Pools</h2>
      <div class="admin-card-actions">
        <% if @lender.active_wholesale_funders.any? %>
          <%= link_to "➕ Add Pool", new_admin_lender_funder_pool_path(@lender), class: "admin-btn admin-btn-primary admin-btn-sm" %>
        <% end %>
      </div>
    </div>

    <% if @lender.lender_funder_pools.any? %>
      <table class="admin-table admin-table-compact">
        <thead>
          <tr>
            <th>Pool Name</th>
            <th>Wholesale Funder</th>
            <th>Amount</th>
            <th>Available</th>
            <th>Status</th>
            <th class="admin-actions-cell">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @lender.lender_funder_pools.includes(funder_pool: :wholesale_funder).each do |rel| %>
            <% pool = rel.funder_pool %>
            <tr>
              <td><strong><%= pool.name %></strong></td>
              <td><%= pool.wholesale_funder.name %></td>
              <td><%= number_to_currency(pool.amount, precision: 0) %></td>
              <td><%= number_to_currency(pool.available_amount, precision: 0) %></td>
              <td>
                <span class="admin-badge <%= rel.active? ? 'admin-badge-active' : 'admin-badge-inactive' %>">
                  <%= rel.active? ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td class="admin-actions-cell">
                <%= link_to "Remove", admin_lender_funder_pool_path(@lender, rel), 
                    method: :delete, data: { turbo_confirm: "Remove?" },
                    class: "admin-link-btn admin-link-btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="admin-text-muted">No funder pools connected. <% if @lender.active_wholesale_funders.any? %>Use "Add Pool" to add one.<% else %>Add wholesale funders first.<% end %></p>
    <% end %>
  </div>

  <!-- Active Applications -->
  <div class="admin-card">
    <div class="admin-card-header">
      <h2>Active Applications</h2>
      <div class="admin-badge"><%= @lender.applications.count %></div>
    </div>

    <% if @lender.applications.any? %>
      <div class="admin-table-wrapper">
        <table class="admin-table admin-table-compact">
          <thead>
            <tr>
              <th>Borrower</th>
              <th>Property</th>
              <th>Amount</th>
              <th>Status</th>
              <th class="admin-actions-cell">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @lender.applications.includes(:user).order(created_at: :desc).limit(10).each do |app| %>
              <tr>
                <td><strong><%= app.user.display_name %></strong></td>
                <td><span class="admin-text-muted"><%= app.address.truncate(40) %></span></td>
                <td><%= number_to_currency(app.equity_investment_amount || 0, precision: 0) %></td>
                <td>
                  <span class="admin-badge admin-badge-<%= app.status %>">
                    <%= app.status.humanize %>
                  </span>
                </td>
                <td class="admin-actions-cell">
                  <%= link_to "View", admin_application_path(app), class: "admin-link-btn" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="admin-text-muted">No applications from this lender yet.</p>
    <% end %>
  </div>

  <!-- System Info -->
  <div class="admin-card admin-card-minimal">
    <div class="admin-detail-grid admin-detail-grid-minimal">
      <div class="admin-detail-item">
        <span class="admin-detail-label">Created</span>
        <span class="admin-detail-value"><%= @lender.created_at.strftime("%b %d, %Y") %></span>
      </div>
      <div class="admin-detail-item">
        <span class="admin-detail-label">Last Updated</span>
        <span class="admin-detail-value"><%= @lender.updated_at.strftime("%b %d, %Y %H:%M") %></span>
      </div>
    </div>
  </div>
</div>
