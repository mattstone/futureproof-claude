<% content_for :page_title, "Edit #{@lender.name}" %>

<div class="admin-content-wrapper">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <h2>Edit Lender</h2>
        <p class="admin-section-subtitle">Update lender information</p>
      </div>
      <div class="admin-card-actions">
        <%= link_to "View", admin_lender_path(@lender), class: "admin-btn admin-btn-secondary" %>
        <%= link_to "Back", admin_lenders_path, class: "admin-btn admin-btn-secondary" %>
      </div>
    </div>

    <%= render 'form', lender: @lender %>
  </div>
</div>
