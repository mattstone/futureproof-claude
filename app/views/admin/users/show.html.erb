<% content_for :page_title, "User Details" %>
<%
related = @user.applications.order(created_at: :desc).limit(5).map do |app|
  ["📋 Application ##{app.id} (#{app.status.humanize})", admin_application_path(app)]
end
%>
<%= render 'admin/shared/related_records', links: related %>

<div class="admin-actions-bar">
  <div>
    <%= link_to "← Back to Users", admin_users_path, class: "admin-btn admin-btn-secondary" %>
  </div>
  
  <div class="admin-actions">
    <%= link_to "Edit User", edit_admin_user_path(@user), class: "admin-btn admin-btn-primary" %>
  </div>
</div>

<div class="admin-form">
  <h2><%= @user.display_name %></h2>
  
  <div class="user-details">
    <div class="detail-row">
      <strong>Email:</strong>
      <%= @user.email %>
    </div>
    
    <div class="detail-row">
      <strong>First Name:</strong>
      <%= @user.first_name %>
    </div>
    
    <div class="detail-row">
      <strong>Last Name:</strong>
      <%= @user.last_name %>
    </div>
    
    <div class="detail-row">
      <strong>Country of Residence:</strong>
      <%= @user.country_of_residence %>
    </div>
    
    <div class="detail-row">
      <strong>Role:</strong>
      <% if @user.admin? %>
        <span class="admin-badge admin-badge-admin">Admin</span>
      <% else %>
        <span class="admin-badge admin-badge-user">User</span>
      <% end %>
    </div>
    
    <div class="detail-row">
      <strong>Account Status:</strong>
      <% if @user.confirmed? %>
        <span class="admin-badge admin-badge-user">Confirmed</span>
      <% else %>
        <span class="admin-badge admin-badge-admin">Pending Confirmation</span>
      <% end %>
    </div>
    
    <div class="detail-row">
      <strong>Created:</strong>
      <%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %>
    </div>
    
    <div class="detail-row">
      <strong>Last Updated:</strong>
      <%= @user.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
    </div>
  </div>
</div>

<div class="admin-card security-panel">
  <div class="card-header">
    <h3>Security</h3>
  </div>
  <div class="card-content">
    <div class="detail-row">
      <strong>Sign-ins:</strong>
      <span><%= @user.sign_in_count %> total<% if @user.current_sign_in_at %> — current session since <%= @user.current_sign_in_at.strftime("%d %b %Y %H:%M") %> (<%= @user.current_sign_in_ip %>)<% end %></span>
    </div>
    <div class="detail-row">
      <strong>Last sign-in:</strong>
      <span><% if @user.last_sign_in_at %><%= @user.last_sign_in_at.strftime("%d %b %Y %H:%M") %> from <%= @user.last_sign_in_ip %><% else %>Never signed in<% end %></span>
    </div>
    <div class="detail-row">
      <strong>Failed attempts:</strong>
      <span><%= @user.failed_attempts %></span>
    </div>
    <div class="detail-row">
      <strong>Account status:</strong>
      <% if @user.access_locked? %>
        <span class="admin-badge admin-badge-danger">Locked<% if @user.locked_at %> since <%= @user.locked_at.strftime("%d %b %Y %H:%M") %><% end %></span>
      <% else %>
        <span class="admin-badge admin-badge-success">Active</span>
      <% end %>
    </div>
    <div class="detail-row security-actions">
      <% if @user.access_locked? %>
        <%= button_to "Unlock account", unlock_admin_user_path(@user), method: :post, class: "admin-btn admin-btn-success admin-btn-sm", data: { turbo_confirm: "Unlock this account?" } %>
      <% else %>
        <%= button_to "Lock account", lock_admin_user_path(@user), method: :post, class: "admin-btn admin-btn-danger admin-btn-sm", data: { turbo_confirm: "Lock this account? The user will be unable to sign in." } %>
      <% end %>
      <%= button_to "Send password reset email", send_reset_password_admin_user_path(@user), method: :post, class: "admin-btn admin-btn-secondary admin-btn-sm", data: { turbo_confirm: "Email a password reset link to #{@user.email}?" } %>
    </div>
  </div>
</div>

<!-- Change History Section -->
<%= render 'shared/change_history', versions: @user_versions %>

<style>
.user-details {
  margin-top: 24px;
}

.detail-row {
  padding: 12px 0;
  border-bottom: 1px solid #e5e7eb;
  display: flex;
  gap: 16px;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row strong {
  min-width: 180px;
  color: #374151;
}

</style>