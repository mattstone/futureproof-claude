<% content_for :page_title, "Application Details" %>

<div class="admin-actions-bar">
  <div>
    <%= link_to "← Back to Applications", admin_applications_path, class: "admin-btn admin-btn-secondary" %>
  </div>
  
  <div class="admin-actions">
    <%= link_to "Edit Application", edit_admin_application_path(@application), class: "admin-btn admin-btn-primary" %>
  </div>
</div>

<div class="admin-tabs">
  <nav class="admin-tab-nav">
    <a href="#details" class="admin-tab active" data-tab="details">Details</a>
    <a href="#documents" class="admin-tab" data-tab="documents">Documents <span class="tab-badge"><%= @outstanding_docs_count if @outstanding_docs_count.to_i > 0 %></span></a>
    <a href="#messages" class="admin-tab" data-tab="messages">Messages <span class="tab-badge"><%= @unread_messages_count if @unread_messages_count.to_i > 0 %></span></a>
    <a href="#agent-activity" class="admin-tab" data-tab="agent-activity">Agent Activity <span class="tab-badge"><%= @agent_actions.size if @agent_actions.present? && @agent_actions.size > 0 %></span></a>
    <a href="#history" class="admin-tab" data-tab="history">History</a>
  </nav>

  <!-- Tab 1: Details -->
  <div class="admin-tab-content" id="details">
    <div class="admin-form">
      <div class="application-header">
        <h2>Application #<%= @application.id %></h2>
        <div class="application-status">
          <%= render 'status_badge', application: @application %>
        </div>
      </div>
      
      <div class="application-details">
        <div class="detail-row">
          <strong>User:</strong>
          <div>
            <%= @application.user.display_name %>
            <br>
            <small class="user-email"><%= @application.user.email %></small>
            <br>
            <%= link_to "View User", admin_user_path(@application.user), class: "admin-link" %>
          </div>
        </div>
        
        <div class="detail-row">
          <strong>Address:</strong>
          <%= @application.address %>
        </div>

        <div class="detail-row">
          <strong>Home Value:</strong>
          <span class="admin-badge admin-badge-user">
            <%= @application.formatted_home_value %>
          </span>
          <% if @application.has_property_valuation? %>
            <br>
            <small class="valuation-info">
              Property Valuation: <%= @application.formatted_property_valuation_middle %>
              <br>
              <em>Range: <%= @application.formatted_property_valuation_range %></em>
            </small>
          <% end %>
        </div>

        <% if @application.corelogic_data_hash.present? %>
          <div class="detail-row">
            <strong>Property Details:</strong>
            <div class="property-details-grid property-details-compact">
              <% if @application.property_type.present? %>
                <div class="property-detail-item">
                  <span class="admin-badge admin-badge-secondary">
                    <%= @application.property_type.humanize %>
                  </span>
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['bedrooms'].present? %>
                <div class="property-detail-item">
                  <strong><%= @application.corelogic_data_hash['bedrooms'] %></strong> bedrooms
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['bathrooms'].present? %>
                <div class="property-detail-item">
                  <strong><%= @application.corelogic_data_hash['bathrooms'] %></strong> bathrooms
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['parking_spaces'].present? %>
                <div class="property-detail-item">
                  <strong><%= @application.corelogic_data_hash['parking_spaces'] %></strong> parking
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['land_area'].present? %>
                <div class="property-detail-item">
                  <strong><%= @application.corelogic_data_hash['land_area'] %></strong> m² land
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['building_area'].present? %>
                <div class="property-detail-item">
                  <strong><%= @application.corelogic_data_hash['building_area'] %></strong> m² building
                </div>
              <% end %>
              <% if @application.corelogic_data_hash['year_built'].present? %>
                <div class="property-detail-item">
                  Built <strong><%= @application.corelogic_data_hash['year_built'] %></strong>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @application.property_images_array.any? %>
          <div class="detail-row" data-controller="image-lightbox">
            <strong>Property Images:</strong>
            <div class="property-images-grid">
              <% @application.property_images_array.each_with_index do |image_url, index| %>
                <div class="property-image-item">
                  <img src="<%= image_url %>"
                       alt="Property image <%= index + 1 %>"
                       class="property-image"
                       loading="lazy"
                       data-action="click->image-lightbox#show">
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <div class="detail-row">
          <strong>Ownership Status:</strong>
          <%= @application.ownership_status_display %>
        </div>
        
        <div class="detail-row">
          <strong>Property State:</strong>
          <%= @application.property_state_display %>
        </div>
        
        <% if @application.has_existing_mortgage? %>
          <div class="detail-row">
            <strong>Existing Mortgage:</strong>
            <%= @application.formatted_existing_mortgage_amount %>
          </div>
        <% else %>
          <div class="detail-row">
            <strong>Existing Mortgage:</strong>
            <span class="no-mortgage-text">No existing mortgage</span>
          </div>
        <% end %>
        
        <% if @application.mortgage.present? %>
          <div class="detail-row">
            <strong>Mortgage Type:</strong>
            <span class="admin-badge admin-badge-secondary">
              <%= @application.mortgage.mortgage_type_display %>
            </span>
          </div>
          
          <div class="detail-row">
            <strong>Monthly Income:</strong>
            <span class="admin-badge admin-badge-success">
              <%= @application.formatted_monthly_income_amount %>
            </span>
          </div>
        <% else %>
          <div class="detail-row">
            <strong>Mortgage Type:</strong>
            <span class="not-selected-text">Not selected</span>
          </div>
          
          <div class="detail-row">
            <strong>Monthly Income:</strong>
            <span class="not-calculated-text">Not calculated</span>
          </div>
        <% end %>
        
        <div class="detail-row">
          <strong>Borrower Age:</strong>
          <%= @application.borrower_age %> years
        </div>

        <% if @application.ownership_status_individual? %>
          <div class="detail-row">
            <strong>Borrower Name:</strong>
            <div class="borrower-name-display"><%= @application.user.display_name %></div>
          </div>
        <% elsif @application.ownership_status_joint? && @application.has_borrower_names? %>
          <div class="detail-row">
            <strong>Borrower Names:</strong>
            <div class="borrower-names-display"><%= @application.formatted_borrower_names %></div>
          </div>
        <% elsif @application.ownership_status_super? && @application.super_fund_name.present? %>
          <div class="detail-row">
            <strong>Superannuation Fund Name:</strong>
            <div class="super-fund-display"><%= @application.super_fund_name %></div>
          </div>
        <% elsif @application.ownership_status_lender? && @application.company_name.present? %>
          <div class="detail-row">
            <strong>Company Name:</strong>
            <div class="company-name-display"><%= @application.company_name %></div>
          </div>
        <% end %>
        
        <% if @application.status_rejected? && @application.rejected_reason.present? %>
          <div class="detail-row">
            <strong>Rejection Reason:</strong>
            <div class="rejection-reason">
              <%= simple_format(@application.rejected_reason) %>
            </div>
          </div>
        <% end %>
        
        <div class="detail-row">
          <strong>Created:</strong>
          <%= @application.created_at.strftime("%B %d, %Y at %I:%M %p") %>
        </div>
        
        <div class="detail-row">
          <strong>Last Updated:</strong>
          <%= @application.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab 2: Documents -->
  <div class="admin-tab-content" id="documents" style="display:none">
    <div class="admin-form">
      <div class="application-header">
        <h3>Documents</h3>
        <%= button_to "Request All Documents", request_all_admin_application_documents_path(@application), method: :post, class: "admin-btn admin-btn-secondary", style: "font-size: 0.85rem; padding: 0.3rem 0.8rem;" %>
      </div>

      <% if @application.application_documents.any? %>
        <div class="application-details">
          <% @application.application_documents.order(:document_type).each do |doc| %>
            <div class="detail-row" style="align-items: center; flex-wrap: wrap; gap: 0.5rem;">
              <strong style="min-width: 140px;"><%= doc.display_name %></strong>
              <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                <% badge_class = case doc.status
                   when "pending" then "admin-badge-secondary"
                   when "uploaded" then "admin-badge-info"
                   when "verified" then "admin-badge-success"
                   when "rejected" then "admin-badge-danger"
                   when "expired" then "admin-badge-secondary"
                   else "admin-badge-secondary"
                   end %>
                <span class="admin-badge <%= badge_class %>"><%= doc.status.capitalize %></span>

                <% if doc.verified_by.present? %>
                  <small>by <%= doc.verified_by %></small>
                <% end %>

                <% if doc.uploaded? %>
                  <%= button_to "Verify", verify_admin_application_document_path(@application, doc), method: :patch, class: "admin-btn admin-btn-primary", style: "font-size: 0.75rem; padding: 0.2rem 0.5rem;" %>
                  <%= button_to "Reject", reject_admin_application_document_path(@application, doc), method: :patch, params: { reason: "Does not meet requirements" }, class: "admin-btn admin-btn-secondary", style: "font-size: 0.75rem; padding: 0.2rem 0.5rem;" %>
                  <%= button_to "Auto-Verify", auto_verify_admin_application_document_path(@application, doc), method: :post, class: "admin-btn admin-btn-secondary", style: "font-size: 0.75rem; padding: 0.2rem 0.5rem;" %>
                <% end %>

                <% if doc.rejected? && doc.rejection_reason.present? %>
                  <small class="text-danger"><%= doc.rejection_reason %></small>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div style="margin-top: 1rem; padding: 0.5rem; background: #f8f9fa; border-radius: 4px; font-size: 0.85rem;">
          <strong>Summary:</strong>
          <%= @application.application_documents.where(status: "verified").count %> verified,
          <%= @application.application_documents.where(status: "uploaded").count %> awaiting review,
          <%= @application.application_documents.outstanding.count %> outstanding
        </div>
      <% else %>
        <p style="color: #6c757d; padding: 1rem 0;">No documents requested yet. Click "Request All Documents" to begin.</p>
      <% end %>
    </div>
  </div>

  <!-- Tab 3: Messages -->
  <div class="admin-tab-content" id="messages" style="display:none">
    <%= render 'shared/messaging/messaging_interface' %>
  </div>

  <!-- Tab 4: Agent Activity -->
  <div class="admin-tab-content" id="agent-activity" style="display:none">
    <div class="admin-form">
      <h3>Agent Activity Timeline</h3>
      <% if @agent_actions.present? && @agent_actions.any? %>
        <div class="agent-activity-timeline">
          <% @agent_actions.each do |action| %>
            <div class="agent-action-item">
              <div class="agent-action-header">
                <% if action.ai_agent %>
                  <img src="<%= action.ai_agent.avatar_path %>" alt="<%= action.ai_agent.name %>" class="agent-avatar-sm">
                  <strong><%= action.ai_agent.name %></strong>
                <% else %>
                  <strong>Unknown Agent</strong>
                <% end %>
                <span class="admin-badge admin-badge-secondary"><%= action.action_type %></span>
                <% if action.decision.present? %>
                  <span class="admin-badge decision-badge-<%= action.decision %>"><%= action.decision %></span>
                <% end %>
                <span class="action-time"><%= time_ago_in_words(action.created_at) %> ago</span>
              </div>
              <% if action.reasoning.present? %>
                <div class="agent-action-reasoning"><%= action.reasoning %></div>
              <% end %>
              <div class="agent-action-meta">
                <% if action.confidence.present? %>
                  <span>Confidence: <strong><%= (action.confidence * 100).round(0) %>%</strong></span>
                <% end %>
                <% if action.result.is_a?(Hash) && action.result['risk_score'].present? %>
                  <span>Risk Score: <strong><%= action.result['risk_score'] %></strong></span>
                <% end %>
                <span class="admin-badge admin-badge-<%= action.status == 'completed' ? 'success' : 'secondary' %>"><%= action.status %></span>
              </div>
              <% if action.decision == 'flag' && action.status != 'overridden' %>
                <div class="agent-action-override">
                  <%= button_to "Override — Approve", "#", class: "admin-btn admin-btn-primary", style: "font-size: 0.8rem; padding: 0.3rem 0.8rem;", disabled: true, title: "Coming soon" %>
                  <%= button_to "Override — Reject", "#", class: "admin-btn admin-btn-secondary", style: "font-size: 0.8rem; padding: 0.3rem 0.8rem;", disabled: true, title: "Coming soon" %>
                </div>
              <% end %>
              <% if action.status == 'overridden' && action.override_reason.present? %>
                <div class="agent-action-override-info">
                  <small>Overridden by <%= action.overridden_by %>: <%= action.override_reason %></small>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p style="color: #6c757d; padding: 1rem 0;">No agent activity recorded for this application yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Tab 5: History -->
  <div class="admin-tab-content" id="history" style="display:none">
    <!-- Application Processing Checklist -->
    <%= render 'checklist', editable: false %>
    
    <!-- Change History Section -->
    <div class="form-actions">
      <%= render 'shared/change_history', versions: @application_versions %>
    </div>
  </div>
</div>

<%= render 'shared/messaging/messaging_assets' %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.admin-tab-nav .admin-tab').forEach(function(tab) {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      var targetId = this.getAttribute('data-tab');
      // Deactivate all tabs
      document.querySelectorAll('.admin-tab-nav .admin-tab').forEach(function(t) { t.classList.remove('active'); });
      // Hide all panels
      document.querySelectorAll('.admin-tab-content').forEach(function(p) { p.style.display = 'none'; });
      // Activate clicked tab and show panel
      this.classList.add('active');
      document.getElementById(targetId).style.display = 'block';
    });
  });
});
</script>
