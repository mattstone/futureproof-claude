<% content_for :page_title, "Mortgage Details" %>
<%= stylesheet_link_tag "admin/mortgages", "data-turbo-track": "reload" %>

<div class="admin-actions-bar">
  <div>
    <%= link_to "← Back to Mortgages", admin_mortgages_path, class: "admin-btn admin-btn-secondary" %>
  </div>
  
  <div class="admin-actions">
    <%= link_to "Edit Mortgage", edit_admin_mortgage_path(@mortgage), class: "admin-btn admin-btn-primary" %>
  </div>
</div>

<div class="mortgage-overview">
  <div class="overview-header">
    <h2><%= @mortgage.name %></h2>
    <div class="mortgage-type-badge">
      <span class="admin-badge <%= @mortgage.mortgage_type_interest_only? ? 'admin-badge-admin' : 'admin-badge-user' %>">
        <%= @mortgage.mortgage_type_display %>
      </span>
    </div>
  </div>
  
  <div class="mortgage-details">
    <div class="detail-row">
      <div class="detail-label">Loan-to-Value Ratio:</div>
      <div class="detail-value primary"><%= @mortgage.formatted_lvr %></div>
    </div>
    
    <div class="detail-row">
      <div class="detail-label">Active Lenders:</div>
      <div class="detail-value"><%= @mortgage.active_lenders.count %> lender<%= @mortgage.active_lenders.count == 1 ? '' : 's' %></div>
    </div>
    
    <div class="detail-row">
      <div class="detail-label">Contracts:</div>
      <div class="detail-value"><%= @mortgage.mortgage_contracts.count %> contract<%= @mortgage.mortgage_contracts.count == 1 ? '' : 's' %></div>
    </div>
    
    <div class="detail-row">
      <div class="detail-label">Created:</div>
      <div class="detail-value">
        <%= @mortgage.created_at.strftime("%B %d, %Y") %> 
        <span class="detail-meta">at <%= @mortgage.created_at.strftime("%I:%M %p") %></span>
      </div>
    </div>
    
    <div class="detail-row">
      <div class="detail-label">Last Updated:</div>
      <div class="detail-value">
        <%= @mortgage.updated_at.strftime("%B %d, %Y") %> 
        <span class="detail-meta">at <%= @mortgage.updated_at.strftime("%I:%M %p") %></span>
      </div>
    </div>
    
    <div class="detail-row">
      <div class="detail-label">Lender Names:</div>
      <div class="detail-value"><%= @mortgage.lender_names %></div>
    </div>
  </div>
</div>

<!-- Mortgage Contracts Section -->
<div class="mortgage-contracts-section">
  <div class="contracts-header-with-actions">
    <div></div>
    <h3>Mortgage Contracts</h3>
    <div class="contracts-actions-right">
      <% if @mortgage.mortgage_contracts.any? %>
        <%= link_to "View All Contracts", admin_mortgage_mortgage_contracts_path(@mortgage), class: "admin-btn admin-btn-secondary" %>
      <% end %>
      <%= link_to "New Contract", new_admin_mortgage_mortgage_contract_path(@mortgage), class: "admin-btn admin-btn-primary" %>
    </div>
  </div>
  
  <div class="contracts-summary">
    <% if @mortgage.mortgage_contracts.any? %>
      <div class="contracts-grid">
        <% @mortgage.mortgage_contracts.order(:version).limit(3).each do |contract| %>
          <div class="contract-card">
            <div class="contract-info">
              <h5><%= contract.title %></h5>
              <div class="contract-meta">
                <span class="version-badge">v<%= contract.version %></span>
                <span class="status-badge status-<%= contract.status_color %>">
                  <%= contract.status %>
                </span>
              </div>
              <p class="contract-updated">Updated <%= contract.formatted_last_updated %></p>
            </div>
            <div class="contract-actions">
              <%= link_to "View", admin_mortgage_mortgage_contract_path(@mortgage, contract), class: "admin-btn admin-btn-sm admin-btn-secondary" %>
              <% if contract.draft? %>
                <%= link_to "Edit", edit_admin_mortgage_mortgage_contract_path(@mortgage, contract), class: "admin-btn admin-btn-sm admin-btn-primary" %>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <% if @mortgage.mortgage_contracts.count > 3 %>
          <div class="contract-card contract-more">
            <div class="more-info">
              <div class="more-icon">📄</div>
              <h5><%= @mortgage.mortgage_contracts.count - 3 %> more contract<%= @mortgage.mortgage_contracts.count - 3 == 1 ? '' : 's' %></h5>
              <p>View all contracts to see the complete history</p>
            </div>
            <%= link_to "View All", admin_mortgage_mortgage_contracts_path(@mortgage), class: "admin-btn admin-btn-sm admin-btn-secondary" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-contracts">
        <div class="empty-icon">📄</div>
        <h5>No Contracts Yet</h5>
        <p>Create the first contract document for this mortgage using the "New Contract" button above.</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Lenders Section -->
<div class="lender-relationships-section">
  <div class="lenders-header-with-actions">
    <div></div>
    <h3>Lenders</h3>
    <div class="lenders-actions-right">
      <button class="admin-btn admin-btn-primary" 
              data-controller="mortgage-lender-selector" 
              data-mortgage-lender-selector-mortgage-id-value="<%= @mortgage.id %>"
              data-action="click->mortgage-lender-selector#showSelection">
        Add Lender
      </button>
    </div>
  </div>
  
  <div class="lenders-summary">
    <!-- Hidden area for Stimulus controller compatibility -->
    <div id="existing-lenders" data-mortgage-lender-selector-target="existingLenders" style="display: none;">
      <!-- Keep for Stimulus controller compatibility -->
    </div>
    <div id="lender-list-content">
      <% if @mortgage.mortgage_lenders.any? %>
        <div class="lenders-grid">
          <% @mortgage.mortgage_lenders.includes(:lender).each do |relationship| %>
            <div class="lender-card">
              <div class="lender-info">
                <h5><%= relationship.lender.name %></h5>
                <div class="lender-meta">
                  <span class="lender-type-badge <%= relationship.lender.lender_type_futureproof? ? 'lender-futureproof' : 'lender-external' %>">
                    <%= relationship.lender.lender_type.humanize %>
                  </span>
                  <span class="status-badge <%= relationship.active? ? 'status-active' : 'status-inactive' %>">
                    <%= relationship.active? ? 'Active' : 'Inactive' %>
                  </span>
                </div>
                <p class="lender-email"><%= relationship.lender.contact_email %></p>
                <p class="relationship-created">Added <%= relationship.created_at.strftime("%B %d, %Y") %></p>
                
                <!-- Clause Information (Singleton) - Clickable Badge -->
                <div class="clause-info">
                  <% if relationship.lender.has_clause? %>
                    <div class="clause-status">
                      <%= link_to edit_admin_lender_clause_path(relationship.lender), 
                          class: "clause-badge active clickable", 
                          title: "Click to edit clause" do %>
                        📄 Clause: <%= relationship.lender.clause_summary %>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="clause-status">
                      <%= link_to edit_admin_lender_clause_path(relationship.lender), 
                          class: "clause-badge inactive clickable", 
                          title: "Click to add clause" do %>
                        📄 Add Clause
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <div class="lender-actions">
                <div class="primary-actions">
                  <%= button_to "Toggle", admin_mortgage_lender_path(@mortgage, relationship), 
                      method: :patch, 
                      remote: true, 
                      params: { _method: :patch, authenticity_token: form_authenticity_token },
                      data: { 
                        confirm: "Are you sure you want to #{relationship.active? ? 'deactivate' : 'activate'} this lender?"
                      },
                      class: "admin-btn admin-btn-sm admin-btn-secondary" %>
                  <%= button_to "Remove", admin_mortgage_lender_path(@mortgage, relationship), 
                      method: :delete, 
                      remote: true,
                      params: { authenticity_token: form_authenticity_token },
                      data: { 
                        confirm: "Are you sure you want to remove this lender? This action cannot be undone."
                      },
                      class: "admin-btn admin-btn-sm admin-btn-danger" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-lenders">
          <div class="empty-icon">🏦</div>
          <h5>No Lenders Yet</h5>
          <p>Associate lenders with this mortgage using the "Add Lender" button above.</p>
        </div>
      <% end %>
    </div>
    
    <!-- Lender Selection Interface (initially hidden) -->
    <div id="lender-selection" data-mortgage-lender-selector-target="selectionInterface" style="display: none;">
      <div class="selection-header">
        <h5>Available Lenders</h5>
        <button type="button" class="close-selection" data-action="click->mortgage-lender-selector#hideSelection">×</button>
      </div>
      
      <div class="selection-loading" data-mortgage-lender-selector-target="loadingState">
        <div class="loading-spinner"></div>
        <p>Loading available lenders...</p>
      </div>
      
      <div class="lender-options" data-mortgage-lender-selector-target="lenderOptions">
        <!-- Lender options will be populated here -->
      </div>
    </div>
  </div>
</div>

<!-- Change History Section -->
<div style="margin-top: 32px;">
  <%= render 'shared/change_history', versions: @all_versions %>
</div>


