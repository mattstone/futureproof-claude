<!-- Jurisdiction Switcher -->
<div class="admin-jurisdiction-switcher">
  <%= form_with url: admin_set_jurisdiction_path, method: :post, local: true, class: "admin-jurisdiction-form" do |f| %>
    <fieldset class="admin-jurisdiction-options">
      <legend class="admin-jurisdiction-label">Jurisdiction:</legend>
      <% ["Summary", "AU", "US", "NZ", "UK"].each do |jurisdiction| %>
        <label class="admin-jurisdiction-radio">
          <%= radio_button_tag :admin_jurisdiction, jurisdiction, 
              (session[:admin_jurisdiction] || "Summary") == jurisdiction,
              class: "admin-jurisdiction-input",
              onchange: "this.form.submit()" %>
          <span class="admin-jurisdiction-text"><%= jurisdiction %></span>
        </label>
      <% end %>
    </fieldset>
  <% end %>
</div>
