<% content_for :page_title, @email_template.name %>
<%= stylesheet_link_tag "admin/email_templates", "data-turbo-track": "reload" %>

<div class="admin-content-header">
  <div class="admin-content-actions">
    <%= link_to "← Back to Email Templates", admin_email_templates_path, class: "admin-btn admin-btn-secondary" %>
    <%= link_to "Edit", edit_admin_email_template_path(@email_template), class: "admin-btn admin-btn-primary" %>
    <%= link_to "Preview", preview_admin_email_template_path(@email_template), class: "admin-btn admin-btn-info", target: "_blank" %>
    <%= link_to "Send Test Email", test_email_admin_email_template_path(@email_template), method: :post, class: "admin-btn admin-btn-success", data: { turbo_confirm: "Send a test email to #{current_user.email}?" } %>
  </div>
</div>

<div class="email-template-details">
  <!-- Template Information -->
  <div class="template-info-card">
    <div class="card-header">
      <h3>Template Information</h3>
      <div class="template-status">
        <% if @email_template.is_active? %>
          <span class="admin-badge admin-badge-success">Active</span>
        <% else %>
          <span class="admin-badge admin-badge-secondary">Inactive</span>
        <% end %>
      </div>
    </div>
    
    <div class="card-content">
      <div class="info-grid">
        <div class="info-item">
          <label>Name:</label>
          <span><%= @email_template.name %></span>
        </div>
        <div class="info-item">
          <label>Type:</label>
          <span class="admin-badge admin-badge-info"><%= @email_template.template_type.humanize %></span>
        </div>
        <div class="info-item">
          <label>Subject:</label>
          <span><%= @email_template.subject %></span>
        </div>
        <% if @email_template.description.present? %>
          <div class="info-item full-width">
            <label>Description:</label>
            <span><%= @email_template.description %></span>
          </div>
        <% end %>
        <div class="info-item">
          <label>Last Updated:</label>
          <span><%= @email_template.updated_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>
        <div class="info-item">
          <label>Created:</label>
          <span><%= @email_template.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>
      </div>
    </div>
  </div>


  <!-- Content Preview -->
  <div class="content-preview-card">
    <div class="card-header">
      <h3>Content Preview</h3>
      <p class="card-subtitle">Rendered preview with sample data</p>
    </div>
    <div class="card-content">
      <div class="rendered-preview">
        <div class="email-preview-container">
          <div class="email-subject">
            <strong>Subject:</strong> <%= @rendered_preview[:subject] %>
          </div>
          <div class="email-content">
            <%= @rendered_preview[:content].html_safe %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Change History -->
  <div class="change-history-card">
    <div class="card-header">
      <h3>Change History</h3>
      <p class="card-subtitle">Track all modifications made to this email template</p>
    </div>
    
    <% if @audit_history.any? %>
      <div class="change-history-list">
        <% @audit_history.each do |version| %>
          <div class="change-entry">
            <div class="change-header">
              <div class="change-info">
                <strong><%= version.user.display_name %></strong>
                <span class="change-action"><%= version.action_description %></span>
                <time class="change-time"><%= version.formatted_created_at %></time>
              </div>
            </div>
            
            <% if version.change_details.present? %>
              <div class="change-details">
                <%= version.change_details %>
              </div>
            <% end %>
            
            <% if version.has_content_changes? || version.has_subject_changes? %>
              <div class="change-content">
                <details class="change-diff">
                  <summary>View Changes</summary>
                  
                  <% if version.has_subject_changes? %>
                    <div class="diff-section">
                      <h5>Subject Changes:</h5>
                      <div class="diff-line removed">- <%= version.previous_subject %></div>
                      <div class="diff-line added">+ <%= version.new_subject %></div>
                    </div>
                  <% end %>
                  
                  <% if version.has_content_changes? %>
                    <div class="diff-section">
                      <h5>Content Changes:</h5>
                      <div class="diff-content">
                        <% version.content_diff.each do |diff_line| %>
                          <div class="diff-line <%= diff_line[:type] %>">
                            <% case diff_line[:type] %>
                            <% when :added %>
                              + <%= diff_line[:content] %>
                            <% when :removed %>
                              - <%= diff_line[:content] %>
                            <% when :context %>
                              <em><%= diff_line[:content] %></em>
                            <% else %>
                              <%= diff_line[:content] %>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </details>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      
      <%= paginate @audit_history if respond_to?(:paginate) %>
    <% else %>
      <div class="empty-state">
        <p>No change history available yet.</p>
      </div>
    <% end %>
  </div>
</div>

