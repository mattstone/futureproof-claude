<div class="commission-form">
  <%= form_with model: [@lender, @commission_rate], local: true, class: "admin-form" do |f| %>
    <% if @commission_rate.errors.any? %>
      <div class="error-messages">
        <h2><%= pluralize(@commission_rate.errors.count, "error") %> prohibited this commission rate from being saved:</h2>
        <ul>
          <% @commission_rate.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :broker_id, "Broker" %>
      <%= f.select :broker_id, 
          @brokers.map { |b| [b.name, b.id] },
          { prompt: "Select a broker" },
          required: true,
          class: "form-input",
          disabled: @commission_rate.persisted? %>
      <small class="form-hint">Cannot change broker after creation</small>
    </div>

    <div class="form-group">
      <%= f.label :commission_percentage, "Commission %" %>
      <%= f.number_field :commission_percentage, 
          step: 0.01,
          min: 0,
          max: 100,
          required: true,
          class: "form-input",
          placeholder: "e.g., 2.5" %>
      <small class="form-hint">Percentage of loan amount (0-100%)</small>
    </div>

    <div class="form-group">
      <%= f.label :payment_trigger, "When to Earn Commission" %>
      <%= f.select :payment_trigger,
          [
            ["On Application Approval", "on_approval"],
            ["On Loan Funding", "on_funding"],
            ["On First Payment Received", "on_first_payment"]
          ],
          { prompt: "Select trigger" },
          required: true,
          class: "form-input" %>
      <small class="form-hint">Determines when commission is earned and payable</small>
    </div>

    <div class="form-group form-checkbox">
      <%= f.label :active do %>
        <%= f.check_box :active, class: "form-checkbox-input" %>
        <span>Active (enable this commission rate)</span>
      <% end %>
    </div>

    <div class="form-actions">
      <%= f.submit @commission_rate.new_record? ? "Create Commission Rate" : "Update Commission Rate", class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_lender_broker_commission_rates_path(@lender), class: "btn btn-outline" %>
    </div>
  <% end %>
</div>

<style>
  .commission-form {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 2rem;
    max-width: 500px;
  }

  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .error-messages {
    background-color: #ffebee;
    border: 1px solid #ef5350;
    border-radius: 4px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .error-messages h2 {
    margin-top: 0;
    font-size: 1rem;
    color: #c62828;
  }

  .error-messages ul {
    margin: 0.5rem 0 0 0;
    padding-left: 1.5rem;
    color: #d32f2f;
  }

  .error-messages li {
    margin: 0.25rem 0;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #333;
  }

  .form-input {
    padding: 0.75rem;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    font-size: 0.95rem;
    font-family: inherit;
  }

  .form-input:focus {
    outline: none;
    border-color: #0066cc;
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
  }

  .form-input:disabled {
    background-color: #f5f5f5;
    color: #999;
    cursor: not-allowed;
  }

  .form-hint {
    font-size: 0.8rem;
    color: #999;
    margin-top: 0.25rem;
    font-style: italic;
  }

  .form-checkbox {
    flex-direction: row;
    align-items: flex-start;
  }

  .form-checkbox label {
    display: flex;
    align-items: center;
    margin-bottom: 0;
    gap: 0.5rem;
    font-weight: 500;
  }

  .form-checkbox-input {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .form-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
  }

  .btn-primary {
    background-color: #0066cc;
    color: white;
  }

  .btn-primary:hover {
    background-color: #0052a3;
  }

  .btn-outline {
    background-color: transparent;
    color: #0066cc;
    border: 1px solid #0066cc;
  }

  .btn-outline:hover {
    background-color: #0066cc;
    color: white;
  }
</style>
