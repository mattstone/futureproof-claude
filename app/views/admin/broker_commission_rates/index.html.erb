<div class="commission-rates">
  <div class="header">
    <h1>Broker Commission Rates — <%= @lender.name %></h1>
    <div class="header-actions">
      <%= link_to "Add Commission Rate", new_admin_lender_broker_commission_rate_path(@lender), class: "btn btn-primary" %>
      <%= link_to "Back to Lender", edit_admin_lender_path(@lender), class: "btn btn-outline" %>
    </div>
  </div>

  <% if @commission_rates.any? %>
    <div class="commission-table-section">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Broker</th>
            <th>Commission %</th>
            <th>Payment Trigger</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @commission_rates.each do |rate| %>
            <tr>
              <td>
                <strong><%= link_to rate.broker.name, admin_broker_path(rate.broker) %></strong>
              </td>
              <td><%= number_to_percentage(rate.commission_percentage, precision: 2) %></td>
              <td>
                <span class="trigger-badge trigger-<%= rate.payment_trigger %>">
                  <%= rate.payment_trigger.titleize %>
                </span>
              </td>
              <td>
                <% if rate.active %>
                  <span class="status-badge status-active">Active</span>
                <% else %>
                  <span class="status-badge status-inactive">Inactive</span>
                <% end %>
              </td>
              <td class="actions">
                <%= link_to "Edit", edit_admin_lender_broker_commission_rate_path(@lender, rate), class: "btn btn-sm btn-secondary" %>
                <%= link_to rate.active ? "Deactivate" : "Activate", 
                    toggle_active_admin_lender_broker_commission_rate_path(@lender, rate), 
                    method: :patch,
                    class: "btn btn-sm btn-outline" %>
                <%= link_to "Delete", admin_lender_broker_commission_rate_path(@lender, rate), 
                    method: :delete, 
                    data: { confirm: "Are you sure?" }, 
                    class: "btn btn-sm btn-danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <p>No commission rates configured for this lender.</p>
      <%= link_to "Add the first commission rate", new_admin_lender_broker_commission_rate_path(@lender), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<style>
  .commission-rates {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .header h1 {
    margin: 0;
    font-size: 1.75rem;
  }

  .header-actions {
    display: flex;
    gap: 0.5rem;
  }

  .commission-table-section {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
  }

  .admin-table thead {
    background-color: #f5f5f5;
  }

  .admin-table th {
    text-align: left;
    padding: 0.75rem;
    font-weight: 600;
    color: #666;
    border-bottom: 2px solid #e0e0e0;
  }

  .admin-table td {
    padding: 0.75rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .admin-table tbody tr:hover {
    background-color: #f9f9f9;
  }

  .trigger-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: white;
  }

  .trigger-on_approval {
    background-color: #2196f3;
  }

  .trigger-on_funding {
    background-color: #ff9800;
  }

  .trigger-on_first_payment {
    background-color: #4caf50;
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: white;
  }

  .status-active {
    background-color: #4caf50;
  }

  .status-inactive {
    background-color: #f44336;
  }

  .actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .btn-primary {
    background-color: #0066cc;
    color: white;
  }

  .btn-primary:hover {
    background-color: #0052a3;
  }

  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #5a6268;
  }

  .btn-outline {
    background-color: transparent;
    color: #0066cc;
    border: 1px solid #0066cc;
  }

  .btn-outline:hover {
    background-color: #0066cc;
    color: white;
  }

  .btn-danger {
    background-color: #f44336;
    color: white;
  }

  .btn-danger:hover {
    background-color: #da190b;
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.8rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #999;
  }

  .empty-state p {
    margin-bottom: 1rem;
  }
</style>
