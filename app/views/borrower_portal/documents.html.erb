<div class="container mx-auto px-4 py-8">
  <%= link_to "← Back to Borrower Portal", borrower_portal_path(region: @region, application_id: @application.id), class: "text-blue-600 hover:underline mb-4 inline-block" %>

  <h1 class="text-3xl font-bold mb-6">Documents & Contracts</h1>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Application Documents -->
    <div class="space-y-6">
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold mb-4">Application Documents</h3>
        <div class="space-y-4">
          <div class="flex items-center justify-between p-3 border border-gray-200 rounded">
            <div class="flex items-center">
              <div class="bg-blue-100 rounded p-2 mr-3">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
              </div>
              <div>
                <p class="font-medium">EPM Application Form</p>
                <p class="text-sm text-gray-600">Application #<%= @application.id %></p>
              </div>
            </div>
            <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Complete</span>
          </div>

          <div class="flex items-center justify-between p-3 border border-gray-200 rounded">
            <div class="flex items-center">
              <div class="bg-purple-100 rounded p-2 mr-3">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path>
                </svg>
              </div>
              <div>
                <p class="font-medium">Identity Verification</p>
                <p class="text-sm text-gray-600"><%= @application.government_id || "Government ID" %></p>
              </div>
            </div>
            <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Verified</span>
          </div>

          <% if @application.super_fund_name %>
            <div class="flex items-center justify-between p-3 border border-gray-200 rounded">
              <div class="flex items-center">
                <div class="bg-green-100 rounded p-2 mr-3">
                  <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Superannuation Fund</p>
                  <p class="text-sm text-gray-600"><%= @application.super_fund_name %></p>
                </div>
              </div>
              <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">Verified</span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Contracts & Legal Documents -->
    <div class="space-y-6">
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold mb-4">EPM Contracts</h3>
        
        <% if @application.status == 'accepted' %>
          <div class="space-y-4">
            <div class="flex items-center justify-between p-3 border border-green-200 bg-green-50 rounded">
              <div class="flex items-center">
                <div class="bg-green-200 rounded p-2 mr-3">
                  <svg class="w-5 h-5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-green-800">EPM Agreement</p>
                  <p class="text-sm text-green-600">Equity Partnership Contract</p>
                </div>
              </div>
              <button class="text-xs bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700">
                Download
              </button>
            </div>

            <div class="flex items-center justify-between p-3 border border-gray-200 rounded">
              <div class="flex items-center">
                <div class="bg-blue-100 rounded p-2 mr-3">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Property Title Documents</p>
                  <p class="text-sm text-gray-600">Legal title registration</p>
                </div>
              </div>
              <button class="text-xs bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700">
                Download
              </button>
            </div>

            <div class="flex items-center justify-between p-3 border border-gray-200 rounded">
              <div class="flex items-center">
                <div class="bg-yellow-100 rounded p-2 mr-3">
                  <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 0v2m-2 0V6a2 2 0 00-2 0v2m2 0h.01M12 21v-8.5m0 0V12"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Distribution Schedule</p>
                  <p class="text-sm text-gray-600">Payment schedule agreement</p>
                </div>
              </div>
              <button class="text-xs bg-yellow-600 text-white px-3 py-1 rounded hover:bg-yellow-700">
                Download
              </button>
            </div>
          </div>
        <% else %>
          <div class="text-center py-8">
            <div class="text-gray-400 mb-4">
              <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-gray-900 mb-2">Contracts Pending</h4>
            <p class="text-gray-600">EPM contracts will be available once your application is approved.</p>
            <p class="text-sm text-gray-500 mt-2">Current Status: <strong><%= @application.status.humanize %></strong></p>
          </div>
        <% end %>
      </div>

      <!-- Document Upload -->
      <div class="bg-blue-50 rounded-lg p-6">
        <h4 class="font-semibold text-blue-900 mb-2">Need to Upload Documents?</h4>
        <p class="text-blue-800 text-sm mb-4">
          If you have additional documents to provide, please contact your equity partner or use our support system.
        </p>
        <button class="text-sm bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
          Contact Support
        </button>
      </div>
    </div>
  </div>
</div>