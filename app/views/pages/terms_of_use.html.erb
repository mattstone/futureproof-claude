<%= render 'shared/demo_header' %>

<div class="legal-page">
  <div class="legal-container">
    <% if @legal_document %>
      <h1><%= @legal_document.title %></h1>
      <p class="last-updated">Last updated: <%= @legal_document.updated_at.strftime("%B %d, %Y") %></p>

      <div class="legal-content">
        <% if @legal_document.rich_content.body.present? %>
          <%= @legal_document.rich_content %>
        <% else %>
          <%= raw @legal_document.content %>
        <% end %>
      </div>
    <% elsif @terms_of_use %>
      <h1><%= @terms_of_use.title %></h1>
      <p class="last-updated">Last updated: <%= @terms_of_use.formatted_last_updated %></p>

      <div class="legal-content">
        <%= raw @terms_of_use.rendered_content %>
      </div>
    <% else %>
      <h1>Terms of Use</h1>
      <p class="last-updated">Last updated: January 31, 2025</p>

      <div class="legal-content">
        <section class="legal-section">
          <h2>Terms of Use Coming Soon</h2>
          <p>Our terms of use are currently being updated. Please check back soon.</p>
        </section>
      </div>
    <% end %>

    <div class="legal-footer">
      <%= link_to "Back to Home", root_path, class: "back-link" %>
    </div>
  </div>
</div>

<%= render 'shared/demo_footer' %>
