<%= render 'shared/demo_header' %>

<div class="legal-page">
  <div class="legal-container">
    <% if @legal_document %>
      <h1><%= @legal_document.title %></h1>
      <p class="last-updated">Last updated: <%= @legal_document.updated_at.strftime("%B %d, %Y") %></p>

      <div class="legal-content">
        <% if @legal_document.rich_content.body.present? %>
          <%= @legal_document.rich_content %>
        <% else %>
          <%= raw @legal_document.content %>
        <% end %>
      </div>
    <% elsif @privacy_policy %>
      <h1><%= @privacy_policy.title %></h1>
      <p class="last-updated">Last updated: <%= @privacy_policy.formatted_last_updated %></p>

      <div class="legal-content">
        <%= raw @privacy_policy.rendered_content %>
      </div>
    <% else %>
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last updated: January 31, 2025</p>

      <div class="legal-content">
        <section class="legal-section">
          <h2>Privacy Policy Coming Soon</h2>
          <p>Our privacy policy is currently being updated. Please check back soon.</p>
        </section>
      </div>
    <% end %>

    <div class="legal-footer">
      <%= link_to "Back to Home", root_path, class: "back-link" %>
    </div>
  </div>
</div>

<%= render 'shared/demo_footer' %>
