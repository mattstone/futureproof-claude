<!-- Demo Header - Simplified without auth links -->
<section class="header-section">
  <div class="header-container">
    <div class="header-content">
      <div class="top-left-logo">
        <%= link_to root_path do %>
          <%= image_tag "futureproof-logo.png", class: "futureproof-logo" %>
        <% end %>
      </div>
      <div class="logo-title-wrapper">
        <%= image_tag "futureproof-financial-group-logo.jpeg", class: "company-logo" %>
        <div class="title-group">
          <h1 class="main-title">Equity Preservation Mortgage ®</h1>
          <p class="subtitle-text">Tax free income from your property equity</p>
        </div>
      </div>
      <!-- No auth links in demo mode -->
    </div>
  </div>
</section>
