<div class="container mx-auto px-4 py-8">
  <%= link_to "← Back to Dashboard", lender_dashboard_index_path, class: "text-blue-600 hover:underline mb-4 inline-block" %>
  
  <h1 class="text-3xl font-bold mb-6">Applications</h1>

  <!-- Filter/Search Section -->
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold mb-4">Filter Applications</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Status</label>
        <select class="w-full px-4 py-2 border rounded-lg" id="filterStatus">
          <option value="">All Statuses</option>
          <option value="accepted">Approved</option>
          <option value="rejected">Rejected</option>
          <option value="submitted">Submitted</option>
          <option value="processing">Processing</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Min Amount</label>
        <input type="number" placeholder="$0" class="w-full px-4 py-2 border rounded-lg" id="filterMinAmount">
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Max Amount</label>
        <input type="number" placeholder="$5M" class="w-full px-4 py-2 border rounded-lg" id="filterMaxAmount">
      </div>
    </div>
  </div>

  <!-- Applications Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <% if @lender.applications.any? %>
      <table class="w-full">
        <thead class="bg-gray-100 border-b-2 border-gray-300">
          <tr>
            <th class="text-left p-4 font-semibold">Applicant</th>
            <th class="text-left p-4 font-semibold">Region</th>
            <th class="text-right p-4 font-semibold">Loan Amount</th>
            <th class="text-left p-4 font-semibold">Status</th>
            <th class="text-left p-4 font-semibold">Submitted</th>
            <th class="text-center p-4 font-semibold">Action</th>
          </tr>
        </thead>
        <tbody>
          <% @lender.applications.each do |app| %>
            <tr class="border-b hover:bg-gray-50">
              <td class="p-4">
                <p class="font-semibold"><%= app.borrower_names || "Unnamed" %></p>
                <p class="text-gray-600 text-sm"><%= app.id %></p>
              </td>
              <td class="p-4 text-gray-700"><%= app.region&.upcase %></td>
              <td class="p-4 text-right">
                <p class="font-bold text-lg"><%= number_to_currency(app.approved_loan_amount || 0) %></p>
              </td>
              <td class="p-4">
                <% case app.status %>
                  <% when 'accepted' %>
                    <span class="inline-block px-3 py-1 rounded-full bg-green-100 text-green-800 font-semibold text-sm">✓ Approved</span>
                  <% when 'rejected' %>
                    <span class="inline-block px-3 py-1 rounded-full bg-red-100 text-red-800 font-semibold text-sm">✗ Rejected</span>
                  <% when 'submitted' %>
                    <span class="inline-block px-3 py-1 rounded-full bg-blue-100 text-blue-800 font-semibold text-sm">⊙ Submitted</span>
                  <% when 'processing' %>
                    <span class="inline-block px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 font-semibold text-sm">⟳ Processing</span>
                  <% else %>
                    <span class="inline-block px-3 py-1 rounded-full bg-gray-100 text-gray-800 font-semibold text-sm"><%= app.status&.humanize %></span>
                <% end %>
              </td>
              <td class="p-4 text-gray-600"><%= app.created_at.strftime("%d %b %Y") %></td>
              <td class="p-4 text-center">
                <%= link_to "View", lender_dashboard_application_detail_path(app), class: "text-blue-600 hover:underline font-semibold" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-gray-600 text-lg">No applications found.</p>
      </div>
    <% end %>
  </div>
</div>
