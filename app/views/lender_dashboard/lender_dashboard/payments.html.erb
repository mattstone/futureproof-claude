<div class="container mx-auto px-4 py-8">
  <%= link_to "← Back to Dashboard", lender_dashboard_index_path, class: "text-blue-600 hover:underline mb-4 inline-block" %>

  <h1 class="text-3xl font-bold mb-6">Distribution Schedule</h1>

  <% distributions = Distribution.joins(:application).where(applications: { lender: @lender }) %>

  <!-- Payment Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm">Total Distributed</p>
      <p class="text-2xl font-bold text-green-600"><%= number_to_currency(distributions.where(status: :completed).sum(:amount)) %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm">Total Margin</p>
      <p class="text-2xl font-bold text-blue-600"><%= number_to_currency(distributions.where(status: :completed).sum(:lender_margin)) %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm">Pending</p>
      <p class="text-2xl font-bold text-yellow-600"><%= number_to_currency(distributions.where(status: :pending).sum(:amount)) %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm">Total Distributions</p>
      <p class="text-2xl font-bold"><%= distributions.count %></p>
    </div>
  </div>

  <!-- Distributions Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <% if distributions.any? %>
      <table class="w-full text-sm">
        <thead class="bg-gray-100 border-b-2 border-gray-300">
          <tr>
            <th class="text-left p-4">Date</th>
            <th class="text-left p-4">Borrower</th>
            <th class="text-right p-4">Amount</th>
            <th class="text-right p-4">Margin</th>
            <th class="text-left p-4">Status</th>
            <th class="text-left p-4">Transaction</th>
          </tr>
        </thead>
        <tbody>
          <% distributions.includes(:application).order(distribution_date: :desc).each do |dist| %>
            <tr class="border-b hover:bg-gray-50">
              <td class="p-4"><%= dist.distribution_date&.strftime("%d %b %Y") %></td>
              <td class="p-4"><%= dist.application.borrower_names || "—" %></td>
              <td class="p-4 text-right font-semibold"><%= number_to_currency(dist.amount || 0) %></td>
              <td class="p-4 text-right"><%= number_to_currency(dist.lender_margin || 0) %></td>
              <td class="p-4">
                <span class="px-2 py-1 rounded text-xs font-semibold
                  <%= case dist.status
                      when 'completed' then 'bg-green-100 text-green-800'
                      when 'pending' then 'bg-yellow-100 text-yellow-800'
                      when 'processing' then 'bg-blue-100 text-blue-800'
                      when 'failed' then 'bg-red-100 text-red-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>
                "><%= dist.status&.humanize %></span>
              </td>
              <td class="p-4 font-mono text-xs"><%= dist.transaction_id || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-gray-600 text-lg">No distributions recorded yet.</p>
      </div>
    <% end %>
  </div>
</div>
