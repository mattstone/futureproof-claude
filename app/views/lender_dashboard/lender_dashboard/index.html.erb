<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Equity Partner Dashboard</h1>
    <%= link_to "Account Settings", lender_dashboard_account_path, class: "btn btn-primary" %>
  </div>

  <!-- EPM Portfolio Metrics -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Active Equity Investments -->
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm mb-2">Active Investments</p>
      <p class="text-3xl font-bold text-blue-600"><%= @active_investments %></p>
      <p class="text-gray-500 text-xs mt-2">EPM Portfolio</p>
    </div>

    <!-- Total Capital Deployed -->
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm mb-2">Capital Deployed</p>
      <p class="text-2xl font-bold text-green-600">
        <%= number_to_currency(@total_equity_investments) %>
      </p>
      <p class="text-gray-500 text-xs mt-2">Total Investment</p>
    </div>

    <!-- Property Portfolio Value -->
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm mb-2">Portfolio Value</p>
      <p class="text-2xl font-bold text-purple-600">
        <%= number_to_currency(@property_portfolio_value) %>
      </p>
      <p class="text-gray-500 text-xs mt-2">Total Property Value</p>
    </div>

    <!-- Distributions Made -->
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-gray-600 text-sm mb-2">Distributions Made</p>
      <p class="text-2xl font-bold text-orange-600">
        <%= number_to_currency(@total_distributions_made) %>
      </p>
      <p class="text-gray-500 text-xs mt-2">To Borrowers</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <%= link_to lender_dashboard_applications_path, class: "bg-white rounded-lg shadow p-6 hover:shadow-lg transition text-center no-underline" do %>
      <p class="text-gray-600 mb-2">📋</p>
      <h3 class="font-semibold text-gray-800">Investment Applications</h3>
      <p class="text-gray-500 text-sm mt-1">Review EPM investment opportunities</p>
    <% end %>

    <%= link_to lender_dashboard_payments_path, class: "bg-white rounded-lg shadow p-6 hover:shadow-lg transition text-center no-underline" do %>
      <p class="text-gray-600 mb-2">💰</p>
      <h3 class="font-semibold text-gray-800">Distribution Management</h3>
      <p class="text-gray-500 text-sm mt-1">Manage distributions to borrowers</p>
    <% end %>

    <%= link_to lender_dashboard_reports_path, class: "bg-white rounded-lg shadow p-6 hover:shadow-lg transition text-center no-underline" do %>
      <p class="text-gray-600 mb-2">📊</p>
      <h3 class="font-semibold text-gray-800">Portfolio Performance</h3>
      <p class="text-gray-500 text-sm mt-1">Analyze equity investment returns</p>
    <% end %>
  </div>

  <!-- Recent EPM Applications -->
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold mb-4">Recent EPM Applications</h2>
    
    <% if @portfolio_applications.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-100 border-b">
            <tr>
              <th class="text-left p-3">Borrower</th>
              <th class="text-left p-3">Equity Investment</th>
              <th class="text-left p-3">Property Value</th>
              <th class="text-left p-3">Status</th>
              <th class="text-left p-3">Applied</th>
              <th class="text-center p-3">Action</th>
            </tr>
          </thead>
          <tbody>
            <% @portfolio_applications.limit(10).each do |app| %>
              <tr class="border-b hover:bg-gray-50">
                <td class="p-3"><%= app.borrower_names || "Anonymous" %></td>
                <td class="p-3 font-semibold text-green-600">
                  <%= number_to_currency(app.equity_investment_amount || 0) %>
                </td>
                <td class="p-3 font-semibold">
                  <%= number_to_currency(app.home_value || 0) %>
                </td>
                <td class="p-3">
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold
                    <% case app.status %>
                      <% when 'accepted' %>
                        bg-green-100 text-green-800
                      <% when 'rejected' %>
                        bg-red-100 text-red-800
                      <% when 'processing' %>
                        bg-blue-100 text-blue-800
                      <% else %>
                        bg-yellow-100 text-yellow-800
                    <% end %>
                  "><%= app.status.humanize %></span>
                </td>
                <td class="p-3 text-gray-600"><%= app.created_at.strftime("%d %b %Y") %></td>
                <td class="p-3 text-center">
                  <%= link_to "Review", lender_dashboard_application_detail_path(app), class: "text-blue-600 hover:underline font-semibold" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View All Investments", lender_dashboard_applications_path, class: "text-blue-600 hover:underline font-semibold" %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-600 text-lg">No EPM investments yet.</p>
        <p class="text-gray-500 text-sm mt-2">Investment applications will appear here when borrowers apply for equity partnerships.</p>
      </div>
    <% end %>
  </div>
</div>
