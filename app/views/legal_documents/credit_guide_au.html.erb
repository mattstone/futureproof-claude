    <h2>8. Contact Information</h2>
    <p><strong><%= @company_name || 'FutureProof' %> Pty Ltd</strong></p>
    <p>
      Email: <%= @contact_email || 'support@futureproof.com.au' %><br>
      Phone: 1300 FUTURE (1300 388 873)<br>
      Address: [INSERT ADDRESS], Australia<br>
      ACL Number: [INSERT ACL NUMBER]
    </p>
  </section>

  <div class="document-footer" style="margin-top: 40px; padding-top: 20px; border-top: 2px solid #1a5490;">
    <p><strong>Please keep this Credit Guide for your records.</strong></p>
    <p><small>This Credit Guide complies with the requirements of section 113 of the <em>National Consumer Credit Protection Act 2009</em>.</small></p>
  </div>
</div>
