<!-- Arcade Header Section - Mirrors Main Site Structure -->
<section class="header-section">
  <div class="header-container">
    <div class="header-content">
      <div class="top-left-logo">
        <%= link_to root_path do %>
          <%= image_tag "futureproof-logo.png", class: "futureproof-logo" %>
        <% end %>
      </div>
      <div class="logo-title-wrapper">
        <div class="arcade-logo">🕹️</div>
        <div class="title-group">
          <h1 class="main-title">Futureproof Arcade</h1>
          <p class="subtitle-text"><span class="lightning-bolt">⚡</span> UNLIMITED PLAY <span class="lightning-bolt">⚡</span> NO QUARTERS NEEDED <span class="lightning-bolt">⚡</span></p>
        </div>
      </div>
      <div class="header-auth">
        <% if user_signed_in? %>
          <div class="nav-links">
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_root_path, class: "nav-link" %>
            <% end %>
            <%= link_to "Profile", edit_user_registration_path, class: "nav-link" %>
            <%= render 'shared/sign_out_link' %>
          </div>
          <div class="nav-user"><%= current_user.email %></div>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "nav-link nav-signin" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

