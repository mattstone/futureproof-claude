<div class="admin-section">
  <div class="admin-section-header">
    <h1>Application Details</h1>
    <p class="admin-section-subtitle">Applicant: <%= @applicant.first_name %> <%= @applicant.last_name %></p>
  </div>

  <!-- Applicant Info -->
  <div class="admin-two-column" style="margin-bottom: 2rem;">
    <div class="admin-section">
      <h3 style="margin-bottom: 1rem;">Applicant Information</h3>
      <div style="display: grid; gap: 1rem;">
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Full Name</label>
          <p><%= @applicant.first_name %> <%= @applicant.last_name %></p>
        </div>
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Email</label>
          <p><%= @applicant.email %></p>
        </div>
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Phone</label>
          <p><%= @applicant.phone || "N/A" %></p>
        </div>
      </div>
    </div>

    <div class="admin-section">
      <h3 style="margin-bottom: 1rem;">Application Status</h3>
      <div style="display: grid; gap: 1rem;">
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Status</label>
          <p>
            <% case @application.status %>
              <% when 'submitted', 'processing' %>
                <span style="color: #fbbf24; font-weight: 600;">Pending</span>
              <% when 'accepted' %>
                <span style="color: #10b981; font-weight: 600;">Approved</span>
              <% when 'rejected' %>
                <span style="color: #ef4444; font-weight: 600;">Rejected</span>
              <% else %>
                <span><%= @application.status.humanize %></span>
            <% end %>
          </p>
        </div>
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Applied</label>
          <p><%= @application.created_at.strftime("%B %d, %Y") %></p>
        </div>
        <div>
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Lender</label>
          <p><%= @application.lender.name %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- EPM Performance -->
  <div class="admin-section">
    <h3 style="margin-bottom: 1rem;">EPM Performance</h3>
    
    <% mortgage = @application.mortgage %>
    <% if mortgage %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div style="padding: 1rem; background: #f9fafb; border-radius: 0.5rem; border-left: 4px solid #6366f1;">
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Equity Investment</label>
          <p style="font-size: 1.5rem; font-weight: 700; color: #111827;">
            <%= number_to_currency((mortgage.equity_investment_amount || 0) / 100.0) %>
          </p>
        </div>

        <div style="padding: 1rem; background: #f9fafb; border-radius: 0.5rem; border-left: 4px solid #8b5cf6;">
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Equity %</label>
          <p style="font-size: 1.5rem; font-weight: 700; color: #111827;">
            <%= number_to_percentage((mortgage.equity_percentage || 0), precision: 1) %>
          </p>
        </div>

        <div style="padding: 1rem; background: #f9fafb; border-radius: 0.5rem; border-left: 4px solid #ec4899;">
          <label style="font-weight: 600; color: #374151; font-size: 0.875rem;">Term (Years)</label>
          <p style="font-size: 1.5rem; font-weight: 700; color: #111827;">
            <%= mortgage.participation_term_years || "N/A" %>
          </p>
        </div>
      </div>
    <% else %>
      <p style="color: #6b7280;">No mortgage contract details available yet.</p>
    <% end %>
  </div>

  <!-- Distributions -->
  <div class="admin-section" style="margin-top: 2rem;">
    <h3 style="margin-bottom: 1rem;">Distribution History</h3>
    
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Amount</th>
            <th>Type</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if @distributions.any? %>
            <% @distributions.each do |dist| %>
              <tr>
                <td><%= dist.created_at.strftime("%b %d, %Y") %></td>
                <td><strong><%= number_to_currency(dist.amount / 100.0) %></strong></td>
                <td><%= dist.distribution_type || "Monthly" %></td>
                <td>
                  <% case dist.status %>
                    <% when 'completed' %>
                      <span style="color: #10b981; font-weight: 600;">Completed</span>
                    <% when 'pending' %>
                      <span style="color: #f59e0b; font-weight: 600;">Pending</span>
                    <% when 'processing' %>
                      <span style="color: #3b82f6; font-weight: 600;">Processing</span>
                    <% when 'failed' %>
                      <span style="color: #ef4444; font-weight: 600;">Failed</span>
                    <% else %>
                      <span><%= dist.status&.humanize %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="admin-table-empty">No distributions yet</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Back Link -->
  <div style="margin-top: 2rem;">
    <%= link_to "← Back to Applications", broker_applications_path, class: "admin-link" %>
  </div>
</div>
