<div style="font-family: Arial, sans-serif; color: #333; line-height: 1.6; max-width: 600px; margin: 0 auto;">
  <div style="background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%); color: white; padding: 30px; text-align: center; border-radius: 8px 8px 0 0;">
    <h1 style="margin: 0; font-size: 28px;">💬 New Message</h1>
    <p style="margin: 10px 0 0 0; font-size: 16px;">You have a new message from your lender</p>
  </div>

  <div style="background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb;">
    <p style="margin: 0 0 20px 0;">Hi <%= @user.first_name %>,</p>

    <p style="margin: 0 0 20px 0;">You have received a new message regarding your Equity Partner Mortgage.</p>

    <div style="background: white; border-left: 4px solid #2196F3; padding: 20px; margin: 20px 0;">
      <div style="margin-bottom: 12px;">
        <span style="display: inline-block; width: 120px; font-weight: bold;">From:</span>
        <span><%= @lender.company_name || @lender.full_name %></span>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="display: inline-block; width: 120px; font-weight: bold;">Property:</span>
        <span><%= @application.property_address %></span>
      </div>
      <div style="margin-bottom: 15px;">
        <span style="display: inline-block; width: 120px; font-weight: bold;">Date:</span>
        <span><%= @message.created_at.strftime('%d %B %Y, %H:%M') %></span>
      </div>
      <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e5e7eb;">
        <p style="margin: 0 0 10px 0; font-weight: bold; color: #1976D2;">Message Preview:</p>
        <p style="margin: 0; white-space: pre-wrap; color: #555; font-size: 14px;"><%= @preview %></p>
      </div>
    </div>

    <div style="background: #fffbeb; padding: 15px; border-radius: 4px; margin: 20px 0; border-left: 4px solid #f59e0b;">
      <p style="margin: 0; font-size: 13px;">
        <strong>To see the full message and reply,</strong> please log in to your borrower portal.
      </p>
    </div>

    <div style="text-align: center; margin: 30px 0;">
      <a href="<%= borrower_application_messages_url(@application) %>" style="display: inline-block; background: #2196F3; color: white; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-weight: bold;">View Message</a>
    </div>

    <h3 style="margin: 20px 0 10px 0; color: #1f2937;">Quick Links</h3>
    <ul style="margin: 10px 0 20px 0; padding-left: 20px;">
      <li style="margin-bottom: 8px;">
        <a href="<%= borrower_application_messages_url(@application) %>" style="color: #2196F3; text-decoration: none;">View all messages</a> with your lender
      </li>
      <li style="margin-bottom: 8px;">
        <a href="<%= borrower_application_url(@application) %>" style="color: #2196F3; text-decoration: none;">View your loan details</a>
      </li>
      <li>
        <a href="<%= edit_borrower_account_url %>" style="color: #2196F3; text-decoration: none;">Update notification preferences</a>
      </li>
    </ul>

    <p style="margin: 20px 0 0 0; padding-top: 20px; border-top: 1px solid #e5e7eb; font-size: 13px; color: #666;">
      You can reply to messages directly from your portal or disable these notifications in your account settings.
    </p>
  </div>

  <div style="background: #f3f4f6; padding: 20px; text-align: center; font-size: 12px; color: #6b7280; border-radius: 0 0 8px 8px;">
    <p style="margin: 0 0 10px 0;">This is an automated notification from your EPM borrower portal.</p>
    <p style="margin: 0;">
      <a href="<%= edit_borrower_account_url %>" style="color: #2196F3; text-decoration: none;">Notification Settings</a> | 
      <a href="<%= borrower_root_url %>" style="color: #2196F3; text-decoration: none;">Borrower Portal</a>
    </p>
  </div>
</div>
