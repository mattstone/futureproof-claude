<div style="font-family: Arial, sans-serif; color: #333; line-height: 1.6; max-width: 600px; margin: 0 auto;">
  <div style="background: linear-gradient(135deg, #059669 0%, #047857 100%); color: white; padding: 30px; text-align: center; border-radius: 8px 8px 0 0;">
    <h1 style="margin: 0; font-size: 28px;">✓ Payment Received</h1>
    <p style="margin: 10px 0 0 0; font-size: 16px;">Your monthly EPM income has been paid</p>
  </div>

  <div style="background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb;">
    <p style="margin: 0 0 20px 0;">Hi <%= @user.first_name %>,</p>

    <p style="margin: 0 0 20px 0;">Great news! Your monthly guaranteed income payment has been successfully processed and deposited into your bank account.</p>

    <div style="background: white; border-left: 4px solid #059669; padding: 20px; margin: 20px 0;">
      <div style="margin-bottom: 12px;">
        <span style="display: inline-block; width: 150px; font-weight: bold;">Payment Amount:</span>
        <span style="font-size: 20px; color: #059669; font-weight: bold;">$<%= @amount %></span>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="display: inline-block; width: 150px; font-weight: bold;">Property:</span>
        <span><%= @property %></span>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="display: inline-block; width: 150px; font-weight: bold;">Payment Date:</span>
        <span><%= @distribution.processed_at.strftime('%d %B %Y') %></span>
      </div>
      <div>
        <span style="display: inline-block; width: 150px; font-weight: bold;">Transaction ID:</span>
        <span style="font-family: monospace; color: #666;"><%= @distribution.transaction_id %></span>
      </div>
    </div>

    <div style="background: #ecfdf5; padding: 15px; border-radius: 4px; margin: 20px 0;">
      <p style="margin: 0; font-size: 13px; color: #047857;">
        <strong>Total Income Received (Cumulative):</strong> $<%= @total_received %>
      </p>
    </div>

    <h3 style="margin: 20px 0 10px 0; color: #1f2937;">What's Next?</h3>
    <ul style="margin: 10px 0 20px 0; padding-left: 20px;">
      <li style="margin-bottom: 8px;">
        <strong>Download Receipt:</strong> 
        <a href="<%= borrower_distribution_download_receipt_url(@distribution, format: :pdf) %>" style="color: #2196F3; text-decoration: none;">Click here to download your payment receipt</a> for tax or accounting purposes.
      </li>
      <li style="margin-bottom: 8px;">
        <strong>View Loan Details:</strong> 
        <a href="<%= borrower_application_url(@application) %>" style="color: #2196F3; text-decoration: none;">Check your payment history and documents</a> in your borrower portal.
      </li>
      <li>
        <strong>Questions?</strong> 
        Reply to this email or <a href="<%= borrower_application_messages_url(@application) %>" style="color: #2196F3; text-decoration: none;">message your lender</a> directly from your portal.
      </li>
    </ul>

    <p style="margin: 20px 0 0 0; padding-top: 20px; border-top: 1px solid #e5e7eb; font-size: 13px; color: #666;">
      <strong>Reminder:</strong> Your guaranteed income may be subject to income tax. Consult your accountant for tax treatment.
    </p>
  </div>

  <div style="background: #f3f4f6; padding: 20px; text-align: center; font-size: 12px; color: #6b7280; border-radius: 0 0 8px 8px;">
    <p style="margin: 0 0 10px 0;">This is an automated message. Please don't reply with sensitive information.</p>
    <p style="margin: 0;">
      <a href="<%= edit_borrower_account_url %>" style="color: #2196F3; text-decoration: none;">Update notification preferences</a> | 
      <a href="<%= borrower_root_url %>" style="color: #2196F3; text-decoration: none;">View portal</a>
    </p>
  </div>
</div>
