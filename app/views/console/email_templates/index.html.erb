<% content_for :title, "Email templates — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Email templates",
      subtitle: "Transactional email content — one active template per type.") do |header| %>
  <% header.with_action do %>
    <%= link_to "New template", new_console_email_template_path, class: "console-btn console-btn-primary" %>
  <% end %>
<% end %>

<%= render Console::FilterBarComponent.new(url: console_email_templates_path,
      search_value: params[:search], search_placeholder: "Name or subject…",
      clear_url: console_email_templates_path) do |bar| %>
  <% bar.with_select(:template_type, options: %w[verification application_submitted security_notification].map { |t| [ t.humanize, t ] }, selected: params[:template_type], label: "Type") %>
  <% bar.with_select(:email_category, options: [ [ "Operational", "operational" ], [ "Marketing", "marketing" ] ], selected: params[:email_category], label: "Category") %>
<% end %>

<%= render Console::DataTableComponent.new(records: @records, id: "email_templates",
      csv_path: console_email_templates_path(format: :csv),
      empty_message: "No templates match those filters.",
      empty_action: link_to("New template", new_console_email_template_path, class: "console-btn console-btn-sm console-btn-primary")) do |table| %>
  <% table.with_column "Name", sort: "name" do |template| %>
    <%= link_to template.name, console_email_template_path(template) %>
  <% end %>
  <% table.with_column "Type", sort: "type" do |template| %>
    <%= template.template_type.humanize %>
  <% end %>
  <% table.with_column "Category" do |template| %>
    <%= template.email_category.humanize %>
  <% end %>
  <% table.with_column "Status" do |template| %>
    <%= render Console::BadgeComponent.new(status: template.is_active? ? "active" : "inactive") %>
  <% end %>
  <% table.with_column "Updated", sort: "updated" do |template| %>
    <%= template.updated_at.strftime("%-d %b %Y") %>
  <% end %>
<% end %>
