<% content_for :title, "#{@lender.name} — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: @lender.name, subtitle: "#{@lender.lender_type.humanize} · #{@lender.country}") do |header| %>
  <% header.with_action do %>
    <%= link_to "Edit", edit_console_lender_path(@lender), class: "console-btn console-btn-secondary" %>
  <% end %>
<% end %>

<%= render "console/shared/partner_onboarding", onboarding: @onboarding, links: {
      agreement: new_console_agreement_path(party_type: "Lender", agreeable_id: @lender.id),
      admin_user: "#invite-admin",
      funding: "#wholesale-funders",
      product: console_mortgages_path
    } %>

<%= render "console/shared/partner_agreements", partner: @lender, party_type: "Lender" %>

<%= render Console::CardComponent.new(title: "Details") do %>
  <%= render Console::DescriptionListComponent.new(columns: 3, rows: {
        "Type" => @lender.lender_type.humanize,
        "Country" => @lender.country,
        "Address" => [ @lender.address, @lender.postcode ].compact.join(", "),
        "Contact email" => @lender.contact_email,
        "Phone" => [ @lender.contact_telephone_country_code, @lender.contact_telephone ].compact.join(" ")
      }) %>
<% end %>

<div id="wholesale-funders"></div>
<%= render Console::CardComponent.new(title: "Wholesale funders") do %>
  <% if @wholesale_funder_relationships.any? %>
    <ul class="console-doc-list">
      <% @wholesale_funder_relationships.each do |relationship| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to relationship.wholesale_funder.name, console_wholesale_funder_path(relationship.wholesale_funder) %></strong>
            <span class="console-cell-sub"><%= relationship.wholesale_funder.country %> · <%= relationship.wholesale_funder.currency %></span>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: relationship.active? ? "active" : "inactive") %>
            <%= button_to relationship.active? ? "Deactivate" : "Activate",
                  toggle_active_console_lender_wholesale_funder_path(@lender, relationship),
                  method: :patch, class: "console-btn console-btn-sm console-btn-secondary" %>
            <%= button_to "Remove", console_lender_wholesale_funder_path(@lender, relationship),
                  method: :delete, class: "console-btn console-btn-sm console-btn-danger",
                  data: { turbo_confirm: "Remove #{relationship.wholesale_funder.name}? Associated pool relationships are removed too." } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No wholesale funder relationships yet.</p>
  <% end %>

  <% if @available_wholesale_funders.any? %>
    <%= form_with url: console_lender_wholesale_funders_path(@lender), method: :post, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="wholesale_funder_id">Add wholesale funder</label>
        <%= select_tag :wholesale_funder_id,
              options_from_collection_for_select(@available_wholesale_funders, :id, :name),
              prompt: "Select funder…", class: "console-select" %>
      </div>
      <%= submit_tag "Add", class: "console-btn console-btn-primary" %>
    <% end %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Funder pools") do %>
  <% if @pool_relationships.any? %>
    <ul class="console-doc-list">
      <% @pool_relationships.each do |relationship| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= relationship.funder_pool.name %></strong>
            <span class="console-cell-sub">
              <%= relationship.funder_pool.wholesale_funder.name %> ·
              <%= relationship.funder_pool.formatted_available %> available of <%= relationship.funder_pool.formatted_amount %>
            </span>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: relationship.active? ? "active" : "inactive") %>
            <%= button_to relationship.active? ? "Deactivate" : "Activate",
                  toggle_active_console_lender_funder_pool_path(@lender, relationship),
                  method: :patch, class: "console-btn console-btn-sm console-btn-secondary" %>
            <%= button_to "Remove", console_lender_funder_pool_path(@lender, relationship),
                  method: :delete, class: "console-btn console-btn-sm console-btn-danger",
                  data: { turbo_confirm: "Remove #{relationship.funder_pool.name} from this lender?" } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No pool relationships yet. Add a wholesale funder first, then its pools become available.</p>
  <% end %>

  <% if @available_pools.any? %>
    <%= form_with url: console_lender_funder_pools_path(@lender), method: :post, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="funder_pool_id">Add pool</label>
        <%= select_tag :funder_pool_id,
              options_from_collection_for_select(@available_pools, :id, ->(p) { "#{p.wholesale_funder.name} — #{p.name}" }),
              prompt: "Select pool…", class: "console-select" %>
      </div>
      <%= submit_tag "Add", class: "console-btn console-btn-primary" %>
    <% end %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Contract clause") do |card| %>
  <% card.with_header_action do %>
    <%= link_to @lender.has_clause? ? "Edit clause" : "Add clause", edit_console_lender_clause_path(@lender), class: "console-btn console-btn-sm console-btn-secondary" %>
  <% end %>
  <% if @lender.has_clause? %>
    <div class="console-clause-preview"><%= truncate(strip_tags(@lender.clause_content), length: 400) %></div>
  <% else %>
    <p class="console-muted">No custom clause — contracts use the standard wording.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Broker commission rates") do |card| %>
  <% card.with_header_action do %>
    <%= link_to "New rate", new_console_lender_broker_commission_rate_path(@lender), class: "console-btn console-btn-sm console-btn-primary" %>
  <% end %>
  <% if @commission_rates.any? %>
    <ul class="console-doc-list">
      <% @commission_rates.each do |rate| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= rate.broker&.name || "Unknown broker" %></strong>
            <span class="console-cell-sub"><%= rate.commission_percentage %>% · <%= rate.payment_trigger.humanize %></span>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: rate.active? ? "active" : "inactive") %>
            <%= link_to "Edit", edit_console_lender_broker_commission_rate_path(@lender, rate), class: "console-btn console-btn-sm console-btn-secondary" %>
            <%= button_to rate.active? ? "Deactivate" : "Activate",
                  toggle_active_console_lender_broker_commission_rate_path(@lender, rate),
                  method: :patch, class: "console-btn console-btn-sm console-btn-secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No commission rates configured.</p>
  <% end %>
<% end %>

<div id="invite-admin"></div>
<%= render Console::CardComponent.new(title: "Lender admin users") do %>
  <% admins = @lender.users.where(admin: true).order(:email) %>
  <% if admins.any? %>
    <ul class="console-doc-list">
      <% admins.each do |admin| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to admin.email, console_user_path(admin) %></strong>
            <span class="console-cell-sub"><%= admin.display_name %> · <%= admin.last_sign_in_at ? "last seen #{time_ago_in_words(admin.last_sign_in_at)} ago" : "never signed in" %></span>
          </div>
          <%= render Console::BadgeComponent.new(status: admin.access_locked? ? "locked" : "active") %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No admin users yet — invite the lender's first operator below.</p>
  <% end %>

  <%= form_with url: invite_admin_console_lender_path(@lender), method: :post, class: "console-ticket-form" do %>
    <div class="console-field">
      <label class="console-field-label" for="first_name">First name</label>
      <%= text_field_tag :first_name, nil, class: "console-input", required: true %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="last_name">Last name</label>
      <%= text_field_tag :last_name, nil, class: "console-input", required: true %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="email">Email</label>
      <%= email_field_tag :email, nil, class: "console-input", required: true %>
    </div>
    <%= submit_tag "Invite admin", class: "console-btn console-btn-primary",
          data: { turbo_confirm: "Invite this person as an admin for #{@lender.name}? They'll receive a password setup email." } %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Lifecycle") do %>
  <% if @lender.status_suspended? %>
    <div class="console-flash console-flash-error">Suspended — excluded from approvals and new assignments.</div>
    <%= form_with url: reactivate_console_lender_path(@lender), method: :patch, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="reason">Reason</label>
        <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
      </div>
      <%= submit_tag "Reactivate", class: "console-btn console-btn-success",
            data: { turbo_confirm: "Reactivate #{@lender.name}?" } %>
    <% end %>
  <% elsif !@lender.lender_type_futureproof? %>
    <%= form_with url: suspend_console_lender_path(@lender), method: :patch, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="reason">Reason</label>
        <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
      </div>
      <%= submit_tag "Suspend partner", class: "console-btn console-btn-danger",
            data: { turbo_confirm: "Suspend #{@lender.name}? They are removed from approvals and new assignments; records and history remain." } %>
    <% end %>
  <% else %>
    <p class="console-muted">The Futureproof house lender cannot be suspended.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new do %>
  <%= render Console::ChangeHistoryComponent.new(versions: @versions, limit: 30) %>
<% end %>
