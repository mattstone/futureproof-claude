<% content_for :title, "#{@funder_pool.name} — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: @funder_pool.name,
      subtitle: @wholesale_funder.name) do |header| %>
  <% header.with_action do %>
    <%= link_to "Edit", edit_console_wholesale_funder_funder_pool_path(@wholesale_funder, @funder_pool), class: "console-btn console-btn-secondary" %>
  <% end %>
<% end %>

<%= render Console::RelatedRecordsComponent.new do |related| %>
  <% related.with_item(@wholesale_funder.name, href: console_wholesale_funder_path(@wholesale_funder), meta: "wholesale funder") %>
<% end %>

<div class="console-stat-grid">
  <%= render Console::StatCardComponent.new(value: @funder_pool.formatted_amount, label: "Capacity") %>
  <%= render Console::StatCardComponent.new(value: @funder_pool.formatted_allocated, label: "Allocated") %>
  <%= render Console::StatCardComponent.new(value: @funder_pool.formatted_available, label: "Available") %>
  <%= render Console::StatCardComponent.new(value: @funder_pool.formatted_total_rate, label: "Rate (benchmark + margin)") %>
</div>

<%= render Console::CardComponent.new(title: "Capacity") do %>
  <% utilisation = @funder_pool.amount.to_f.positive? ? (@funder_pool.allocated.to_f / @funder_pool.amount * 100).round(1) : 0 %>
  <div class="console-checklist-progress">
    <progress class="console-progress" value="<%= utilisation %>" max="100"></progress>
    <span class="console-cell-sub"><%= utilisation %>% allocated</span>
  </div>

  <%= form_with url: top_up_console_wholesale_funder_funder_pool_path(@wholesale_funder, @funder_pool), method: :post, class: "console-ticket-form" do %>
    <div class="console-field">
      <label class="console-field-label" for="amount_delta">Adjust capacity by $ (negative to reduce)</label>
      <%= number_field_tag :amount_delta, nil, step: 1000, class: "console-input", required: true %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="reason">Reason</label>
      <%= text_field_tag :reason, nil, class: "console-input", placeholder: "Recorded in the audit log", required: true %>
    </div>
    <%= submit_tag "Apply", class: "console-btn console-btn-primary",
          data: { turbo_confirm: "Adjust this pool's capacity? The change is audit-logged." } %>
  <% end %>
<% end %>

<% if @funder_pool.allocated.to_f.zero? %>
  <%= render Console::CardComponent.new(title: "Danger zone") do %>
    <%= button_to "Delete pool", console_wholesale_funder_funder_pool_path(@wholesale_funder, @funder_pool),
          method: :delete, class: "console-btn console-btn-danger",
          data: { turbo_confirm: "Delete #{@funder_pool.name}? Only possible because nothing is allocated." } %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Contracts funded from this pool") do %>
  <% contracts = @funder_pool.contracts %>
  <% if contracts.any? %>
    <ul class="console-doc-list">
      <% contracts.each do |contract| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to "Contract ##{contract.id}", console_contract_path(contract) %></strong>
            <span class="console-cell-sub"><%= contract.application.user.display_name %> · <%= contract.formatted_allocated_amount %></span>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: contract.status) %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No contracts allocated from this pool yet.</p>
  <% end %>
<% end %>
