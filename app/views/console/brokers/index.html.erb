<% content_for :title, "Brokers — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Brokers",
      subtitle: "Referral partners and their lender assignments.") do |header| %>
  <% header.with_action do %>
    <%= link_to "Scorecard", scorecard_console_brokers_path, class: "console-btn console-btn-secondary" %>
  <% end %>
  <% header.with_action do %>
    <%= link_to "New broker", new_console_broker_path, class: "console-btn console-btn-primary" %>
  <% end %>
<% end %>

<%= render Console::FilterBarComponent.new(url: console_brokers_path,
      search_value: params[:search], search_placeholder: "Name or email…",
      clear_url: console_brokers_path) do |bar| %>
  <% bar.with_select(:jurisdiction, options: %w[AU US NZ UK], selected: params[:jurisdiction]) %>
  <% bar.with_select(:status, options: [ [ "Pending", "pending" ], [ "Active", "active" ], [ "Suspended", "suspended" ] ], selected: params[:status], label: "Status") %>
<% end %>

<%= render Console::DataTableComponent.new(records: @records, id: "brokers",
      csv_path: console_brokers_path(format: :csv, search: params[:search], jurisdiction: params[:jurisdiction], status: params[:status]),
      empty_message: "No brokers match those filters.") do |table| %>
  <% table.with_column "Name", sort: "name" do |broker| %>
    <%= link_to broker.name, console_broker_path(broker) %>
  <% end %>
  <% table.with_column "Email" do |broker| %>
    <%= broker.email %>
  <% end %>
  <% table.with_column "Jurisdiction" do |broker| %>
    <%= broker.jurisdiction %>
  <% end %>
  <% table.with_column "Onboarding" do |broker| %>
    <% onboarding = Console::PartnerOnboarding.for(broker) %>
    <%= render Console::BadgeComponent.new(status: onboarding.complete? ? "active" : "in_progress", label: onboarding.progress_label) %>
  <% end %>
  <% table.with_column "Status" do |broker| %>
    <%= render Console::BadgeComponent.new(status: broker.status) %>
  <% end %>
  <% table.with_column "Joined", sort: "created" do |broker| %>
    <%= broker.created_at.strftime("%-d %b %Y") %>
  <% end %>
<% end %>
