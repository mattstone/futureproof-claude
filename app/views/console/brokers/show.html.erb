<% content_for :title, "#{@broker.name} — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: @broker.name, subtitle: @broker.email) do |header| %>
  <% header.with_action do %>
    <%= render Console::BadgeComponent.new(status: @broker.active? ? "active" : "inactive") %>
  <% end %>
  <% header.with_action do %>
    <%= link_to "Edit", edit_console_broker_path(@broker), class: "console-btn console-btn-secondary" %>
  <% end %>
  <% header.with_action do %>
    <%= button_to @broker.active? ? "Deactivate" : "Activate", toggle_active_console_broker_path(@broker),
          method: :patch, class: "console-btn console-btn-secondary" %>
  <% end %>
  <% header.with_action do %>
    <%= button_to "Resend setup email", resend_setup_console_broker_path(@broker), method: :post,
          class: "console-btn console-btn-secondary",
          data: { turbo_confirm: "Resend the password setup email to #{@broker.email}?" } %>
  <% end %>
<% end %>

<%= render "console/shared/partner_onboarding", onboarding: @onboarding, links: {
      agreement: new_console_agreement_path(party_type: "Broker", agreeable_id: @broker.id),
      lender_access: "#lender-assignments",
      commission: console_lenders_path
    } %>

<%= render "console/shared/partner_agreements", partner: @broker, party_type: "Broker" %>

<%= render Console::CardComponent.new(title: "Details") do %>
  <%= render Console::DescriptionListComponent.new(columns: 3, rows: {
        "Email" => @broker.email,
        "Phone" => @broker.phone,
        "Jurisdiction" => @broker.jurisdiction,
        "Joined" => @broker.created_at.strftime("%-d %b %Y")
      }) %>
<% end %>

<div id="lender-assignments"></div>
<%= render Console::CardComponent.new(title: "Lender assignments") do %>
  <% if @assignments.any? %>
    <ul class="console-doc-list">
      <% @assignments.each do |assignment| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to assignment.lender.name, console_lender_path(assignment.lender) %></strong>
            <% if assignment.access_level.present? %>
              <span class="console-cell-sub">access: <%= assignment.access_level.humanize %></span>
            <% end %>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: assignment.active? ? "active" : "inactive") %>
            <%= button_to assignment.active? ? "Deactivate" : "Activate",
                  toggle_lender_console_broker_path(@broker, lender_id: assignment.lender_id),
                  method: :patch, class: "console-btn console-btn-sm console-btn-secondary" %>
            <%= button_to "Remove", remove_lender_console_broker_path(@broker, lender_id: assignment.lender_id),
                  method: :delete, class: "console-btn console-btn-sm console-btn-danger",
                  data: { turbo_confirm: "Remove #{@broker.name} from #{assignment.lender.name}?" } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">Not assigned to any lender yet.</p>
  <% end %>

  <% if @available_lenders.any? %>
    <%= form_with url: assign_lender_console_broker_path(@broker), method: :post, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="lender_id">Assign to lender</label>
        <%= select_tag :lender_id, options_from_collection_for_select(@available_lenders, :id, :name),
              prompt: "Select lender…", class: "console-select" %>
      </div>
      <%= submit_tag "Assign", class: "console-btn console-btn-primary" %>
    <% end %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Commissions") do |card| %>
  <% card.with_header_action do %>
    <%= link_to "Full ledger", console_broker_commissions_path(broker_id: @broker.id), class: "console-btn console-btn-sm console-btn-secondary" %>
  <% end %>
  <%= render Console::DescriptionListComponent.new(columns: 2, rows: {
        "Unpaid" => number_to_currency(@commission_totals[:unpaid], precision: 2),
        "Paid to date" => number_to_currency(@commission_totals[:paid], precision: 2)
      }) %>
  <% if @commission_totals[:unpaid].positive? %>
    <%= button_to "Run payment — pay all unpaid", pay_run_console_broker_commissions_path(broker_id: @broker.id),
          method: :post, class: "console-btn console-btn-success",
          data: { turbo_confirm: "Mark ALL unpaid commissions for #{@broker.name} (#{number_to_currency(@commission_totals[:unpaid], precision: 2)}) as paid? This is audit-logged." } %>
  <% end %>
  <% if @recent_commissions.any? %>
    <ul class="console-doc-list">
      <% @recent_commissions.each do |commission| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= number_to_currency(commission.commission_amount, precision: 2) %></strong>
            <span class="console-cell-sub">app #<%= commission.application_id %> · earned <%= commission.earned_date&.strftime("%-d %b %Y") %></span>
          </div>
          <%= render Console::BadgeComponent.new(status: commission.status) %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Recent referrals") do %>
  <% if @applications.any? %>
    <ul class="console-doc-list">
      <% @applications.each do |application| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to "Application ##{application.id}", console_application_path(application) %></strong>
            <span class="console-cell-sub"><%= application.user.display_name %> · <%= application.created_at.strftime("%-d %b %Y") %></span>
          </div>
          <div class="console-doc-actions">
            <%= render Console::BadgeComponent.new(status: application.status) %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No referrals yet.</p>
  <% end %>
<% end %>
