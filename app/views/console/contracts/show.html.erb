<% content_for :title, "Contract ##{@contract.id} — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Contract ##{@contract.id}",
      subtitle: @contract.application.address) do |header| %>
  <% if @contract.demo? %>
    <% header.with_action do %>
      <%= render Console::BadgeComponent.new(status: "demo", label: "Demo data") %>
    <% end %>
  <% end %>
  <% header.with_action do %>
    <%= render Console::BadgeComponent.new(status: @contract.status) %>
  <% end %>
  <% header.with_action do %>
    <%= link_to "Edit", edit_console_contract_path(@contract), class: "console-btn console-btn-secondary" %>
  <% end %>
<% end %>

<%= render Console::RelatedRecordsComponent.new do |related| %>
  <% related.with_item(@contract.application.user.display_name, href: console_user_path(@contract.application.user), meta: "customer") %>
  <% related.with_item("Application ##{@contract.application_id}", href: console_application_path(@contract.application_id), meta: @contract.application.status.humanize) %>
  <% if @contract.mortgage_contract %>
    <% related.with_item("Signed instrument — #{@contract.mortgage_contract.title}",
         href: console_mortgage_mortgage_contract_path(@contract.mortgage_contract.mortgage_id, @contract.mortgage_contract),
         meta: "v#{@contract.mortgage_contract.version}") %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Contract details") do %>
  <%= render Console::DescriptionListComponent.new(rows: {
        "Status" => @contract.status_display,
        "Allocated" => @contract.formatted_allocated_amount,
        "Start" => @contract.start_date&.strftime("%-d %b %Y"),
        "End" => @contract.end_date&.strftime("%-d %b %Y"),
        "Investment balance" => number_to_currency(@contract.investment_balance, precision: 0),
        "Offset balance" => number_to_currency(@contract.offset_balance, precision: 0),
        "Return rate" => (@contract.investment_return_rate ? "#{@contract.investment_return_rate}%" : nil),
        "Lender" => @contract.lender&.name,
        "Funder pool" => @contract.funder_pool&.name
      }) %>

  <% if @contract.start_date && @contract.end_date && @contract.end_date > @contract.start_date %>
    <% total_days = (@contract.end_date - @contract.start_date).to_i %>
    <% elapsed_days = [ [ (Date.current - @contract.start_date).to_i, 0 ].max, total_days ].min %>
    <div class="console-term-progress">
      <progress class="console-progress" value="<%= elapsed_days %>" max="<%= total_days %>"></progress>
      <span class="console-cell-sub">
        <%= (elapsed_days * 100.0 / total_days).round %>% of term elapsed ·
        <%= ((total_days - elapsed_days) / 30.44).round %> months to maturity
      </span>
    </div>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Customer & collateral") do %>
  <%= render Console::DescriptionListComponent.new(columns: 3, rows: {
        "Customer" => "#{@contract.application.user.display_name} (#{@contract.application.user.email})",
        "Country" => @contract.application.user.country_of_residence,
        "Mobile" => (@contract.application.user.respond_to?(:mobile_number) ? @contract.application.user.mobile_number : nil),
        "Property" => @contract.application.address,
        "Home value" => @contract.application.formatted_home_value,
        "Ownership" => @contract.application.ownership_status_display,
        "Property state" => @contract.application.property_state_display,
        "Borrower age" => "#{@contract.application.borrower_age} years",
        "Existing mortgage" => (@contract.application.has_existing_mortgage? ? @contract.application.formatted_existing_mortgage_amount : "None")
      }) %>
<% end %>

<%= render Console::CardComponent.new(title: "Economics") do %>
  <% return_rate = @contract.investment_return_rate.to_f %>
  <% cost_rate = @contract.cost_of_capital_rate.to_f %>
  <%= render Console::DescriptionListComponent.new(columns: 4, rows: {
        "Monthly income to borrower" => (@contract.monthly_payment ? number_to_currency(@contract.monthly_payment, precision: 2) : "Not set"),
        "Total paid to date" => number_to_currency(@contract.total_payments_made.to_f, precision: 2),
        "Investment return" => (@contract.investment_return_rate ? "#{return_rate}%" : "Not set"),
        "Cost of capital" => (@contract.cost_of_capital_rate ? "#{cost_rate}%" : "Not set"),
        "Spread" => (@contract.investment_return_rate && @contract.cost_of_capital_rate ? "#{(return_rate - cost_rate).round(2)}%" : "—")
      }) %>
<% end %>

<%= render Console::CardComponent.new(title: "Servicing") do %>
  <%= render Console::DescriptionListComponent.new(columns: 3, rows: {
        "Income paid to date" => number_to_currency(@income_paid, precision: 2),
        "Failed payments" => @failed_distributions,
        "Last payment" => (@distributions.first ? "#{number_to_currency(@distributions.first.amount, precision: 2)} on #{@distributions.first.distribution_date&.strftime('%-d %b %Y')}" : "None yet")
      }) %>

  <% if @available_transitions.any? %>
    <% @available_transitions.each do |kind, spec| %>
      <%= form_with url: transition_console_contract_path(@contract, kind: kind), method: :patch, class: "console-ticket-form" do %>
        <div class="console-field">
          <label class="console-field-label" for="reason"><%= spec[:label] %> — reason</label>
          <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
        </div>
        <%= submit_tag spec[:label], class: "console-btn #{kind == 'complete' ? 'console-btn-danger' : (kind == 'flag_at_risk' ? 'console-btn-danger' : 'console-btn-secondary')}",
              data: { turbo_confirm: "#{spec[:label]} for contract ##{@contract.id}? This is audit-logged." } %>
      <% end %>
    <% end %>
  <% else %>
    <p class="console-muted">No servicing transitions available from <%= @contract.status_display %>.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Income payments") do %>
  <% if @distributions.any? %>
    <ul class="console-doc-list">
      <% @distributions.each do |distribution| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= number_to_currency(distribution.amount, precision: 2) %></strong>
            <span class="console-cell-sub">
              <%= distribution.distribution_date&.strftime("%-d %b %Y") %>
              <% if distribution.payment_period_month %> · period <%= distribution.payment_period_year %>-<%= format("%02d", distribution.payment_period_month) %><% end %>
              <% if distribution.payment_method.present? %> · <%= distribution.payment_method.humanize %><% end %>
            </span>
            <% if distribution.status == "failed" && distribution.notes.present? %>
              <span class="console-field-error"><%= distribution.notes %></span>
            <% end %>
          </div>
          <%= render Console::BadgeComponent.new(status: distribution.status) %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No income payments recorded for this contract yet.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Send a message") do %>
  <%= form_with model: @new_message, url: create_message_console_contract_path(@contract),
        scope: :contract_message, class: "console-message-form" do |form| %>
    <div class="console-field">
      <%= form.label :ai_agent_id, "Send as", class: "console-field-label" %>
      <%= form.collection_select :ai_agent_id, @ai_agents, :id, :name,
            { selected: @suggested_agent&.id, prompt: "Select agent…" },
            { class: "console-select", required: true } %>
    </div>
    <div class="console-field">
      <%= form.label :subject, class: "console-field-label" %>
      <%= form.text_field :subject, class: "console-input", required: true %>
    </div>
    <div class="console-field">
      <%= form.label :content, "Message", class: "console-field-label" %>
      <%= form.text_area :content, rows: 5, class: "console-textarea", required: true %>
    </div>
    <div class="console-message-actions">
      <%= form.submit "Save draft", class: "console-btn console-btn-secondary" %>
      <%= form.submit "Send now", name: "send_now", value: "true", class: "console-btn console-btn-primary" %>
    </div>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Conversation") do %>
  <div id="console-contract-messages">
    <% if @messages.any? %>
      <div class="console-thread-list">
        <% @messages.each do |message| %>
          <div class="console-message <%= message.from_customer? ? 'console-message-customer' : 'console-message-admin' %>">
            <div class="console-message-meta">
              <strong><%= message.sender_name %></strong>
              <%= render Console::BadgeComponent.new(status: message.status) %>
              <time class="console-history-time"><%= message.created_at.strftime("%-d %b %Y %H:%M") %></time>
              <% if message.draft? %>
                <%= button_to "Send", send_message_console_contract_path(@contract, message_id: message.id),
                      method: :patch, class: "console-btn console-btn-sm console-btn-primary", form_class: "console-inline-form" %>
              <% end %>
            </div>
            <div class="console-message-subject"><%= message.processed_subject %></div>
            <div class="console-message-body"><%= sanitize message.content_html, tags: %w[p br strong em ul li], attributes: [] %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="console-muted">No messages yet.</p>
    <% end %>
  </div>
<% end %>

<%= render Console::CardComponent.new(title: "Danger zone") do %>
  <p class="console-muted">Deleting a contract deallocates its pool capital. For mistakes only — completed contracts should use the Complete transition instead.</p>
  <%= form_with url: console_contract_path(@contract), method: :delete, class: "console-ticket-form" do %>
    <div class="console-field">
      <label class="console-field-label" for="reason">Reason</label>
      <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
    </div>
    <%= submit_tag "Delete contract", class: "console-btn console-btn-danger",
          data: { turbo_confirm: "Delete contract ##{@contract.id} and deallocate #{@contract.formatted_allocated_amount}? This cannot be undone." } %>
  <% end %>
<% end %>

<%= render Console::CardComponent.new do %>
  <%= render Console::ChangeHistoryComponent.new(versions: @versions) %>
<% end %>
