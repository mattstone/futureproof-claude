<% content_for :title, "Contracts — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Contracts",
      subtitle: "The live portfolio — funding, investment and holiday status per contract.") do |header| %>
  <% header.with_action do %>
    <%= link_to "New contract", new_console_contract_path, class: "console-btn console-btn-primary" %>
  <% end %>
<% end %>

<% agents_for_function("backoffice").each do |agent| %>
  <%= render "console/shared/agent_operations", agent: agent %>
<% end %>

<%= render Console::FilterBarComponent.new(url: console_contracts_path,
      search_value: params[:search], search_placeholder: "Contract/application ID, name, email, address…",
      clear_url: console_contracts_path) do |bar| %>
  <% bar.with_select(:status, options: Contract.statuses.keys.map { |k| [ k.humanize, k ] }, selected: params[:status]) %>
<% end %>

<%# Triage emphasis: at-risk contracts read red, holidays amber, so the
    portfolio's trouble spots surface without scanning every status badge. %>
<%= render Console::DataTableComponent.new(records: @records, id: "contracts",
      csv_path: console_contracts_path(format: :csv, search: params[:search], status: params[:status]),
      row_class: ->(c) {
        case c.status
        when "investment_at_risk" then "console-row-error"
        when "in_holiday" then "console-row-warning"
        end
      },
      empty_message: "No contracts match those filters.") do |table| %>
  <%# Lead with the human identifier — the customer, not the #ID. %>
  <% table.with_column "Customer" do |contract| %>
    <%= link_to contract.application.user.display_name, console_contract_path(contract) %>
    <div class="console-cell-sub"><%= contract.application.address&.truncate(50) %></div>
  <% end %>
  <% table.with_column "Ref" do |contract| %>
    <%= link_to "##{contract.id}", console_contract_path(contract) %>
  <% end %>
  <% table.with_column "Status", sort: "status" do |contract| %>
    <%= render Console::BadgeComponent.new(status: contract.status) %>
  <% end %>
  <% table.with_column "Allocated", sort: "allocated", numeric: true do |contract| %>
    <%= contract.formatted_allocated_amount %>
  <% end %>
  <% table.with_column "End", sort: "end" do |contract| %>
    <%= contract.end_date&.strftime("%-d %b %Y") || "—" %>
  <% end %>
  <% table.with_column "Messages" do |contract| %>
    <% unread = (@unread_counts ||= unread_message_counts(@records))[contract.id].to_i %>
    <% if unread.positive? %>
      <%= render Console::BadgeComponent.new(status: "needs_attention", label: "#{unread} unread") %>
    <% else %>
      <span class="console-muted">—</span>
    <% end %>
  <% end %>
  <% table.with_column "Start", sort: "start" do |contract| %>
    <%= contract.start_date&.strftime("%-d %b %Y") %>
  <% end %>
<% end %>
