<% content_for :title, "#{@wholesale_funder.name} — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: @wholesale_funder.name,
      subtitle: "#{@wholesale_funder.funding_type.humanize} facility · #{@wholesale_funder.country} · #{@wholesale_funder.currency}") do |header| %>
  <% header.with_action do %>
    <%= link_to "Edit", edit_console_wholesale_funder_path(@wholesale_funder), class: "console-btn console-btn-secondary" %>
  <% end %>
  <% header.with_action do %>
    <%= link_to "New pool", new_console_wholesale_funder_funder_pool_path(@wholesale_funder), class: "console-btn console-btn-primary" %>
  <% end %>
<% end %>

<%= render "console/shared/partner_onboarding", onboarding: @onboarding, links: {
      contact: edit_console_wholesale_funder_path(@wholesale_funder),
      agreement: new_console_agreement_path(party_type: "WholesaleFunder", agreeable_id: @wholesale_funder.id),
      documents: new_console_wholesale_funder_funding_document_path(@wholesale_funder),
      capital: edit_console_wholesale_funder_path(@wholesale_funder),
      pools: new_console_wholesale_funder_funder_pool_path(@wholesale_funder),
      lender_access: console_lenders_path
    } %>

<%= render "console/shared/partner_agreements", partner: @wholesale_funder, party_type: "WholesaleFunder" %>

<%= render Console::CardComponent.new(title: "Details") do %>
  <%= render Console::DescriptionListComponent.new(columns: 3, rows: {
        "Facility type" => @wholesale_funder.funding_type.humanize,
        "Country" => @wholesale_funder.country,
        "Currency" => @wholesale_funder.currency,
        "Contact" => @wholesale_funder.contact_name,
        "Email" => @wholesale_funder.contact_email,
        "Phone" => @wholesale_funder.contact_phone
      }) %>
  <% if @wholesale_funder.terms.present? %>
    <div class="console-field">
      <span class="console-field-label">Facility terms</span>
      <p class="console-muted"><%= simple_format(@wholesale_funder.terms) %></p>
    </div>
  <% end %>
<% end %>

<div class="console-stat-grid">
  <%= render Console::StatCardComponent.new(value: @wholesale_funder.formatted_total_capital, label: "Total capital") %>
  <%= render Console::StatCardComponent.new(value: number_to_currency(@wholesale_funder.committed_amount, precision: 0), label: "Committed") %>
  <%= render Console::StatCardComponent.new(value: number_to_currency(@wholesale_funder.available_amount, precision: 0), label: "Available") %>
  <%= render Console::StatCardComponent.new(value: "#{@wholesale_funder.utilization_percentage}%", label: "Utilisation") %>
</div>

<%= render Console::CardComponent.new(title: "Facility") do %>
  <% pool_capacity = @pools.sum { |pool| pool.amount.to_f } %>
  <% facility = @wholesale_funder.total_allocated_amount.to_f %>
  <%= render Console::DescriptionListComponent.new(columns: 3, strong: true, rows: {
        "Facility size" => number_to_currency(facility, precision: 0),
        "In pools" => number_to_currency(pool_capacity, precision: 0),
        "Unpooled headroom" => number_to_currency(facility - pool_capacity, precision: 0),
        "Committed to contracts" => number_to_currency(@wholesale_funder.committed_amount, precision: 0),
        "Avg monthly deployment" => (@monthly_deployment.positive? ? number_to_currency(@monthly_deployment, precision: 0) : "—"),
        "Runway (months)" => (@wholesale_funder.runway_months >= 999 ? "—" : @wholesale_funder.runway_months)
      }) %>
  <div class="console-checklist-progress">
    <progress class="console-progress" value="<%= @wholesale_funder.utilization_percentage %>" max="100"></progress>
    <span class="console-cell-sub"><%= @wholesale_funder.utilization_percentage %>% utilised</span>
  </div>
  <% if pool_capacity > facility %>
    <div class="console-flash console-flash-warning">
      Pools total <%= number_to_currency(pool_capacity - facility, precision: 0) %> MORE than the recorded facility —
      either top up the facility size or reduce pool capacity.
    </div>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Pools") do %>
  <% if @pools.any? %>
    <ul class="console-doc-list">
      <% @pools.each do |pool| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to pool.name, console_wholesale_funder_funder_pool_path(@wholesale_funder, pool) %></strong>
            <span class="console-cell-sub">
              <%= pool.formatted_allocated %> allocated of <%= pool.formatted_amount %> ·
              <%= pool.formatted_available %> available · rate <%= pool.formatted_total_rate %>
            </span>
            <div class="console-checklist-progress">
              <progress class="console-progress" value="<%= pool.allocation_percentage %>" max="100"></progress>
              <span class="console-cell-sub"><%= pool.allocation_percentage %>%</span>
            </div>
          </div>
          <div class="console-doc-actions">
            <%= link_to "Edit", edit_console_wholesale_funder_funder_pool_path(@wholesale_funder, pool), class: "console-btn console-btn-sm console-btn-secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No pools yet — create one to start allocating capital.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Contract documents") do |card| %>
  <% card.with_header_action do %>
    <%= link_to "New document", new_console_wholesale_funder_funding_document_path(@wholesale_funder), class: "console-btn console-btn-sm console-btn-primary" %>
  <% end %>
  <% documents = @wholesale_funder.wholesale_funder_contracts.order(:jurisdiction, version: :desc) %>
  <% if documents.any? %>
    <ul class="console-doc-list">
      <% documents.each do |document| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to "#{document.party_type.presence || 'Document'} (#{document.jurisdiction}) v#{document.version}", console_wholesale_funder_funding_document_path(@wholesale_funder, document) %></strong>
            <span class="console-cell-sub">updated <%= document.updated_at.strftime("%-d %b %Y") %></span>
          </div>
          <div class="console-doc-actions">
            <%= link_to "Edit", edit_console_wholesale_funder_funding_document_path(@wholesale_funder, document), class: "console-btn console-btn-sm console-btn-secondary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No contract documents on file — add the master agreement per jurisdiction.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Lenders drawing on this funder") do %>
  <% if @lender_relationships.any? %>
    <ul class="console-doc-list">
      <% @lender_relationships.each do |relationship| %>
        <% lender = relationship.lender %>
        <% lender_pools = lender.lender_funder_pools.select { |lfp| lfp.funder_pool&.wholesale_funder_id == @wholesale_funder.id } %>
        <% capacity = lender_pools.sum { |lfp| lfp.funder_pool&.amount.to_f } %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to lender.name, console_lender_path(lender) %></strong>
            <span class="console-cell-sub">
              <%= lender_pools.size %> pool<%= "s" unless lender_pools.size == 1 %> ·
              capacity <%= number_to_currency(capacity, precision: 0) %>
              <% active_pools = lender_pools.count(&:active) %>
              · <%= active_pools %> active
            </span>
          </div>
          <%= render Console::BadgeComponent.new(status: relationship.active? ? "active" : "inactive") %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="console-muted">No lenders draw on this funder yet — link one from the lender's page.</p>
  <% end %>
<% end %>

<%= render Console::CardComponent.new do %>
  <%= render Console::ChangeHistoryComponent.new(versions: @versions, limit: 30) %>
<% end %>

<%= render Console::CardComponent.new(title: "Lifecycle") do %>
  <% if @wholesale_funder.status_suspended? %>
    <div class="console-flash console-flash-error">Suspended — hidden from lender funding pickers.</div>
    <%= form_with url: reactivate_console_wholesale_funder_path(@wholesale_funder), method: :patch, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="reason">Reason</label>
        <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
      </div>
      <%= submit_tag "Reactivate", class: "console-btn console-btn-success",
            data: { turbo_confirm: "Reactivate #{@wholesale_funder.name}?" } %>
    <% end %>
  <% else %>
    <%= form_with url: suspend_console_wholesale_funder_path(@wholesale_funder), method: :patch, class: "console-ticket-form" do %>
      <div class="console-field">
        <label class="console-field-label" for="reason">Reason</label>
        <%= text_field_tag :reason, nil, class: "console-input", required: true, placeholder: "Recorded in the audit log" %>
      </div>
      <%= submit_tag "Suspend partner", class: "console-btn console-btn-danger",
            data: { turbo_confirm: "Suspend #{@wholesale_funder.name}? Existing pools keep operating; they are hidden from new funding pickers." } %>
    <% end %>
  <% end %>
<% end %>
