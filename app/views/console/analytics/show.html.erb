<% content_for :title, "Analytics — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Analytics",
      subtitle: "Portfolio, acquisition, service and risk — #{current_jurisdiction == 'Summary' ? 'all regions' : current_jurisdiction}. Demo data excluded.") %>

<section class="console-gauges">
  <% @data[:gauges].each do |gauge| %>
    <div class="console-gauge">
      <div data-controller="radial-gauge"
           data-radial-gauge-value-value="<%= gauge[:value] %>"
           data-radial-gauge-max-value="<%= gauge[:max] %>"
           data-radial-gauge-unit-value="<%= gauge[:unit] %>"
           data-radial-gauge-label-value="<%= gauge[:label] %>"
           data-radial-gauge-detail-value="<%= gauge[:detail] %>"
           data-radial-gauge-higher-is-better-value="<%= gauge[:higher_is_better] %>"
           data-radial-gauge-warning-at-value="<%= gauge[:warning_at] %>"
           data-radial-gauge-critical-at-value="<%= gauge[:critical_at] %>"></div>
      <div class="console-gauge-label"><%= gauge[:label] %></div>
      <div class="console-cell-sub"><%= gauge[:detail] %></div>
    </div>
  <% end %>
</section>

<%= render Console::CardComponent.new(title: "Application funnel") do %>
  <p class="console-muted"><%= number_with_delimiter(@data[:funnel][:total_started]) %> applications started</p>
  <div class="console-chart console-chart-tall"
       data-controller="application-funnel"
       data-application-funnel-nodes-value="<%= @data[:funnel][:nodes].to_json %>"
       data-application-funnel-links-value="<%= @data[:funnel][:links].to_json %>"
       data-application-funnel-total-started-value="<%= @data[:funnel][:total_started] %>"></div>
<% end %>

<%= render Console::CardComponent.new(title: "Application volume — last 12 months") do %>
  <p class="console-muted"><%= number_with_delimiter(@data[:calendar][:total]) %> applications across <%= @data[:calendar][:days].size %> days</p>
  <div class="console-chart"
       data-controller="calendar-heatmap"
       data-calendar-heatmap-days-value="<%= @data[:calendar][:days].to_json %>"
       data-calendar-heatmap-max-value="<%= @data[:calendar][:max] %>"
       data-calendar-heatmap-total-value="<%= @data[:calendar][:total] %>"></div>
<% end %>

<%= render Console::CardComponent.new(title: "Geographic distribution") do %>
  <div class="console-chart"
       data-controller="regional-choropleth"
       data-regional-choropleth-regions-value="<%= @data[:geo].to_json %>"
       data-regional-choropleth-atlas-url-value="/data/world-110m.json"></div>
<% end %>

<div class="console-analytics-grid">
  <%= render Console::CardComponent.new(title: "Financial") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Total raised" => number_to_currency(@data[:financial_overview][:total_aum], precision: 0),
          "Capital deployed" => number_to_currency(@data[:financial_overview][:capital_deployed], precision: 0),
          "Available" => number_to_currency(@data[:financial_overview][:capital_available], precision: 0),
          "WACC" => "#{@data[:financial_overview][:wacc]}%",
          "Portfolio P&L" => number_to_currency(@data[:financial_overview][:portfolio_pl], precision: 0),
          "Net margin (annual)" => number_to_currency(@data[:financial_overview][:net_margin_annual], precision: 0)
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Customer acquisition") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "This month" => "#{number_with_delimiter(@data[:acquisition_overview][:applications_this_month])} apps",
          "Last month" => "#{number_with_delimiter(@data[:acquisition_overview][:applications_last_month])} apps",
          "Month-over-month" => "#{@data[:acquisition_overview][:delta_pct] >= 0 ? '+' : ''}#{@data[:acquisition_overview][:delta_pct]}%",
          "Conversion rate" => "#{@data[:acquisition_overview][:conversion_rate]}%"
        }) %>
    <% if @data[:acquisition_overview][:top_brokers].any? %>
      <p class="console-cell-sub">
        Top brokers (90d):
        <%= @data[:acquisition_overview][:top_brokers].map { |name, count| "#{name} (#{count})" }.join(" · ") %>
      </p>
    <% end %>
    <% if @data[:acquisition_overview][:regional_split].any? %>
      <p class="console-cell-sub">
        By region:
        <%= @data[:acquisition_overview][:regional_split].map { |region, count| "#{region} #{count}" }.join(" · ") %>
      </p>
    <% end %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Customer service") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Open conversations" => number_with_delimiter(@data[:service_overview][:open_conversations]),
          "Awaiting reply > 24h" => @data[:service_overview][:awaiting_reply_count],
          "% awaiting (30d)" => "#{@data[:service_overview][:awaiting_reply_pct]}%",
          "Escalations this week" => @data[:service_overview][:escalations_this_week],
          "Stalled applications" => @data[:service_overview][:stalled_applications]
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Risk & investment health") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Health score" => "#{@data[:risk_overview][:health_score]}%",
          "Rating" => @data[:risk_overview][:health_rating],
          "Investment health" => "#{@data[:risk_overview][:investment_health_pct]}%",
          "Performing" => "#{@data[:risk_overview][:performing_contracts]} / #{@data[:risk_overview][:total_contracts]}",
          "On payment holiday" => "#{@data[:risk_overview][:holiday_pct]}%",
          "Active alerts" => @data[:risk_overview][:alert_count]
        }) %>
  <% end %>
</div>

<div class="console-analytics-grid">
  <%= render Console::CardComponent.new(title: "Portfolio") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Applications" => number_with_delimiter(@data[:portfolio_summary][:total_applications]),
          "Capital deployed" => number_to_currency(@data[:portfolio_summary][:total_capital_deployed], precision: 0),
          "Active investments" => @data[:portfolio_summary][:active_investments],
          "Pending" => @data[:portfolio_summary][:pending_applications],
          "Approved" => @data[:portfolio_summary][:approved_applications],
          "Rejected" => @data[:portfolio_summary][:rejected_applications],
          "Distributions to date" => number_to_currency(@data[:portfolio_summary][:total_distributions], precision: 0)
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Capital & pools") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Deployed" => number_to_currency(@data[:capital_deployment][:capital_deployed], precision: 0),
          "Awaiting funding" => number_to_currency(@data[:capital_deployment][:capital_awaiting], precision: 0),
          "Pool capacity" => number_to_currency(@data[:capital_deployment][:total_pool_capacity], precision: 0),
          "Pool utilisation" => "#{@data[:capital_deployment][:pool_utilisation]}%",
          "Investment accounts" => number_to_currency(@data[:account_balances][:total_investment], precision: 0),
          "Offset balances" => number_to_currency(@data[:account_balances][:total_offset], precision: 0),
          "Avg investment return" => "#{@data[:account_balances][:avg_investment_return]}%"
        }) %>
    <% if @data[:capital_deployment][:top_pools].present? %>
      <p class="console-cell-sub">Top pools: <%= @data[:capital_deployment][:top_pools].first(3).map { |p| p[:name] }.join(" · ") %></p>
    <% end %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Contract status") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Total contracts" => @data[:contract_status][:total_contracts],
          "Active" => @data[:contract_status][:active_contracts],
          "On investment holiday" => @data[:contract_status][:in_holiday_contracts],
          "Awaiting funding" => @data[:contract_status][:awaiting_funding_contracts],
          "Monthly income out" => number_to_currency(@data[:contract_status][:total_monthly_outflows], precision: 0)
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Distributions") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Total paid" => number_to_currency(@data[:distributions][:total], precision: 0),
          "This month" => number_to_currency(@data[:distributions][:this_month], precision: 0)
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "Concentration risk") do %>
    <% top_lender = @data[:concentration][:by_lender].first %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "By region" => @data[:concentration][:by_region].map { |r, d| "#{r} #{d[:pct]}%" }.join(" · "),
          "Top lender" => (top_lender ? "#{top_lender[0]} (#{number_to_currency(top_lender[1], precision: 0)})" : "—"),
          "Value bands" => @data[:concentration][:by_value_band].map { |b, n| "#{b}: #{n}" }.join(" · "),
          "Terms" => @data[:concentration][:by_term].map { |t, n| "#{t}yr: #{n}" }.join(" · ")
        }) %>
  <% end %>

  <%= render Console::CardComponent.new(title: "EPM model") do %>
    <%= render Console::DescriptionListComponent.new(rows: {
          "Model version" => @data[:model_context][:version],
          "PoD (30yr)" => "#{@data[:model_context][:pod_yr30]}%",
          "Reinsurance PoC" => "#{@data[:model_context][:reinsurance_poc]}%",
          "Portfolio PoC (steady state)" => "#{@data[:model_context][:portfolio_poc_steady_state]}%"
        }) %>
  <% end %>
</div>

<%= render Console::CardComponent.new(title: "Maturity watch & at-risk") do %>
  <%= render Console::DescriptionListComponent.new(columns: 4, rows: {
        "Maturing within 12 months" => @data[:monitoring][:maturing_count],
        "Maturing value" => number_to_currency(@data[:monitoring][:maturing_value], precision: 0),
        "Avg return rate" => "#{@data[:monitoring][:avg_return_rate]}%",
        "Return range" => "#{@data[:monitoring][:min_return_rate]}%–#{@data[:monitoring][:max_return_rate]}%"
      }) %>

  <% if @data[:monitoring][:maturing_soon].any? %>
    <h3 class="console-card-subtitle">Maturing soonest</h3>
    <ul class="console-doc-list">
      <% @data[:monitoring][:maturing_soon].each do |contract| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to "Contract ##{contract.id}", console_contract_path(contract) %></strong>
            <span class="console-cell-sub">
              <%= contract.application&.user&.display_name %> ·
              <%= number_to_currency(contract.allocated_amount, precision: 0) %> ·
              ends <%= contract.end_date&.strftime("%-d %b %Y") %>
            </span>
          </div>
          <%= render Console::BadgeComponent.new(status: contract.status) %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @data[:monitoring][:at_risk_detail].any? %>
    <h3 class="console-card-subtitle">Investment at risk</h3>
    <ul class="console-doc-list">
      <% @data[:monitoring][:at_risk_detail].each do |contract| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= link_to "Contract ##{contract.id}", console_contract_path(contract) %></strong>
            <span class="console-cell-sub"><%= contract.application&.user&.display_name %> · <%= number_to_currency(contract.allocated_amount, precision: 0) %></span>
          </div>
          <%= render Console::BadgeComponent.new(status: contract.status) %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<%= render Console::CardComponent.new(title: "Trends — last 12 months") do %>
  <div class="console-trends-grid">
    <div>
      <h4 class="console-chart-title">Applications per month</h4>
      <div class="console-chart"
           data-controller="time-series-chart"
           data-time-series-chart-type-value="bar"
           data-time-series-chart-value-format-value="integer"
           data-time-series-chart-color-value="#2563eb"
           data-time-series-chart-series-value="<%= @data[:trends][:applications_monthly].map { |label, value| { label: label, value: value } }.to_json %>"></div>
    </div>
    <div>
      <h4 class="console-chart-title">Funds under management</h4>
      <div class="console-chart"
           data-controller="time-series-chart"
           data-time-series-chart-type-value="area"
           data-time-series-chart-value-format-value="currency"
           data-time-series-chart-color-value="#0ea5e9"
           data-time-series-chart-series-value="<%= @data[:trends][:fum_monthly].map { |label, value| { label: label, value: value } }.to_json %>"></div>
    </div>
    <div>
      <h4 class="console-chart-title">Monthly P&amp;L (bars) + cumulative (line)</h4>
      <div class="console-chart"
           data-controller="time-series-chart"
           data-time-series-chart-type-value="combo"
           data-time-series-chart-value-format-value="currency"
           data-time-series-chart-color-value="#16a34a"
           data-time-series-chart-secondary-color-value="#0f172a"
           data-time-series-chart-series-value="<%= @data[:trends][:pl_monthly].map { |label, vals| { label: label, monthly: vals[:monthly], cumulative: vals[:cumulative] } }.to_json %>"></div>
    </div>
  </div>
<% end %>
