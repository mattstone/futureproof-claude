<% content_for :title, "Agent action timeline — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Agent action timeline",
      subtitle: "Every agent decision across the roster, newest first.") do |header| %>
  <% header.with_action do %>
    <%= link_to "All agents", console_ai_agents_path, class: "console-btn console-btn-secondary" %>
  <% end %>
<% end %>

<%= render Console::FilterBarComponent.new(url: timeline_console_ai_agents_path,
      clear_url: timeline_console_ai_agents_path) do |bar| %>
  <% bar.with_select(:agent_id, options: @agents.map { |a| [ a.name, a.id ] }, selected: params[:agent_id], label: "Agent") %>
  <% bar.with_select(:action_type, options: AgentAction::ACTION_TYPES.map { |t| [ t.humanize, t ] }, selected: params[:action_type], label: "Type") %>
  <% bar.with_select(:decision, options: AgentAction::DECISIONS.map { |d| [ d.humanize, d ] }, selected: params[:decision], label: "Decision") %>
<% end %>

<%= render Console::CardComponent.new do %>
  <% if @actions.any? %>
    <ul class="console-doc-list">
      <% @actions.each do |action| %>
        <li class="console-doc-item">
          <div class="console-doc-name">
            <strong><%= action.ai_agent&.name %> — <%= action.action_type.humanize %><% if action.decision.present? %>: <%= action.decision.humanize %><% end %></strong>
            <span class="console-cell-sub">
              <% if action.actionable %>
                <% if (path = entity_path_for(action)) %>
                  <%= link_to "#{action.actionable_type.underscore.humanize} ##{action.actionable_id}", path, class: "console-link" %> ·
                <% else %>
                  <%= action.actionable_type.underscore.humanize %> #<%= action.actionable_id %> ·
                <% end %>
              <% end %>
              <% if action.confidence.present? %>confidence <%= (action.confidence * 100).round %>% · <% end %>
              <%= action.created_at.strftime("%-d %b %Y %H:%M") %>
              <% if action.reasoning.present? %><br><%= truncate(action.reasoning, length: 140) %><% end %>
            </span>
          </div>
          <%= render Console::BadgeComponent.new(status: action.status) %>
        </li>
      <% end %>
    </ul>
    <p class="console-muted">Showing the most recent <%= @actions.size %> actions.</p>
  <% else %>
    <p class="console-muted">No agent actions match those filters.</p>
  <% end %>
<% end %>
