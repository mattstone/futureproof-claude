<% content_for :title, "Lifecycle stage — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(
      title: @stage_index ? "Edit stage" : "New lifecycle stage",
      subtitle: @agent.name) %>

<%= render Console::CardComponent.new do %>
  <%= form_with url: update_stage_console_ai_agent_path(@agent), method: :patch, class: "console-form" do %>
    <%= hidden_field_tag :stage_index, @stage_index %>

    <div class="console-field">
      <label class="console-field-label" for="stage_label">Stage label</label>
      <%= text_field_tag :stage_label, @stage["stage_label"], class: "console-input", required: true %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="stage_name">Stage key (machine name)</label>
      <%= text_field_tag :stage_name, @stage["stage_name"], class: "console-input", required: true, placeholder: "e.g. welcome_call" %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="stage_description">Description</label>
      <%= text_area_tag :stage_description, @stage["stage_description"], rows: 3, class: "console-textarea" %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="entry_trigger">Entry trigger</label>
      <%= text_field_tag :entry_trigger, @stage["entry_trigger"], class: "console-input", placeholder: "e.g. application_submitted" %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="stage_color">Stage colour</label>
      <%= select_tag :stage_color,
            options_for_select(@stage_colors.map { |c| [ c.humanize, c ] }, @stage["stage_color"].presence || "blue"),
            class: "console-select" %>
    </div>
    <div class="console-field">
      <label class="console-field-label" for="handoff_to">Hands off to (optional)</label>
      <%= select_tag :handoff_to,
            options_from_collection_for_select(@handoff_agents, :name, :name, @stage.dig("handoff_rules", "handoff_to")),
            include_blank: "No handoff", class: "console-select" %>
    </div>

    <span class="console-field-label">Automated actions (optional)</span>
    <p class="console-muted">Each row runs in order when the stage is entered. Leave Type as "None" to drop a row; fill the blank row at the bottom to add another.</p>
    <% existing = Array(@stage["automated_actions"]) %>
    <% (existing + [ {} ]).each do |action| %>
      <div class="console-ticket-form console-action-row">
        <div class="console-field">
          <label class="console-field-label">Type</label>
          <%= select_tag "automated_actions[][action_type]",
                options_for_select([ [ "None", "" ], [ "Send email", "send_email" ], [ "Create task", "create_task" ], [ "Update status", "update_status" ], [ "Send message", "send_message" ] ], action["action_type"]),
                class: "console-select" %>
        </div>
        <div class="console-field">
          <label class="console-field-label">Email template</label>
          <%= select_tag "automated_actions[][email_template_id]",
                options_from_collection_for_select(@email_templates, :id, :name, action["email_template_id"]),
                include_blank: "—", class: "console-select" %>
        </div>
        <div class="console-field">
          <label class="console-field-label">Task type</label>
          <%= text_field_tag "automated_actions[][task_type]", action["task_type"], class: "console-input", placeholder: "e.g. document_verify" %>
        </div>
        <div class="console-field">
          <label class="console-field-label">New status</label>
          <%= text_field_tag "automated_actions[][new_status]", action["new_status"], class: "console-input" %>
        </div>
        <div class="console-field">
          <label class="console-field-label">Delay</label>
          <%= number_field_tag "automated_actions[][delay][duration]", action.dig("delay", "duration"), min: 0, class: "console-input" %>
        </div>
        <div class="console-field">
          <label class="console-field-label">Unit</label>
          <%= select_tag "automated_actions[][delay][unit]",
                options_for_select(%w[minutes hours days], action.dig("delay", "unit")),
                class: "console-select" %>
        </div>
      </div>
    <% end %>

    <div class="console-message-actions">
      <%= submit_tag "Save stage", class: "console-btn console-btn-primary" %>
      <%= link_to "Cancel", console_ai_agent_path(@agent), class: "console-btn console-btn-secondary" %>
    </div>
  <% end %>
<% end %>
