<% content_for :title, "Today — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Today", subtitle: "Your work queue — what needs attention right now.") %>

<div class="console-stat-grid">
  <%# hrefs point at pre-filtered indexes and light up as each phase ships. %>
  <%= render Console::StatCardComponent.new(value: @stats[:decisions], label: "Applications awaiting decision",
        href: console_applications_path, variant: @stats[:decisions].positive? ? :warning : nil) %>
  <%= render Console::StatCardComponent.new(value: @stats[:documents], label: "Documents awaiting verification") %>
  <%= render Console::StatCardComponent.new(value: @stats[:messages], label: "Unread customer messages",
        variant: @stats[:messages].positive? ? :warning : nil) %>
  <% if @stats.key?(:tickets) %>
    <%= render Console::StatCardComponent.new(value: @stats[:tickets], label: "Open support tickets",
          href: console_support_tickets_path(status: "open")) %>
  <% end %>
  <% if @stats.key?(:change_requests) %>
    <%= render Console::StatCardComponent.new(value: @stats[:change_requests], label: "Open change requests") %>
  <% end %>
</div>

<% if @signals %>
  <%= render Console::CardComponent.new(title: "Needs attention") do %>
    <%= render Console::AttentionListComponent.new(signals: @signals) %>
  <% end %>
<% end %>
