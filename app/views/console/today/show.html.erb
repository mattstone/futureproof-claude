<% content_for :title, "Today — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Today", subtitle: "Your work queue — what needs attention right now.") %>

<div class="console-stat-grid">
  <%= render Console::StatCardComponent.new(value: attention_counts[:applications], label: "Applications awaiting decision") %>
  <%= render Console::StatCardComponent.new(value: attention_counts[:tickets], label: "Open support tickets") %>
  <%= render Console::StatCardComponent.new(value: attention_counts[:change_requests], label: "Open change requests") %>
</div>

<%= render Console::CardComponent.new do %>
  <p class="console-muted">
    The Console is being rebuilt in phases. The full Today work queue — attention
    signals with one-click drill-down — arrives in Phase&nbsp;1. Until then, use the
    legacy admin link in the sidebar for day-to-day operations.
  </p>
<% end %>
