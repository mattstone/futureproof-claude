<% if policy.futureproof? %>
  <%= form_with url: console_set_jurisdiction_path, method: :post,
        class: "console-region", data: { controller: "auto-submit" } do |f| %>
    <span class="console-region-label">Region</span>
    <div class="console-region-options" role="radiogroup" aria-label="Region">
      <% Console::BaseController::JURISDICTIONS.each do |jurisdiction| %>
        <label class="console-region-option <%= "is-active" if current_jurisdiction == jurisdiction %>">
          <%= f.radio_button :jurisdiction, jurisdiction,
                checked: current_jurisdiction == jurisdiction,
                class: "console-region-radio",
                data: { action: "change->auto-submit#filterChanged" } %>
          <span><%= jurisdiction %></span>
        </label>
      <% end %>
    </div>
  <% end %>
<% else %>
  <span class="console-jurisdiction-pinned"><%= current_jurisdiction %></span>
<% end %>
