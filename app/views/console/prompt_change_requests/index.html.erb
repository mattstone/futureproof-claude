<% content_for :title, "Change requests — FutureProof Console" %>

<%= render Console::PageHeaderComponent.new(title: "Change requests",
      subtitle: "Proposals become GitHub PRs/issues. Nothing reaches production until the CTO merges — the merge is the deploy.") do |header| %>
  <% header.with_action do %>
    <%= link_to "New request", new_console_prompt_change_request_path, class: "console-btn console-btn-primary" %>
  <% end %>
<% end %>

<%= render Console::DataTableComponent.new(records: @records, id: "change_requests",
      empty_message: "No change requests yet.") do |table| %>
  <% table.with_column "Title" do |request| %>
    <%= link_to request.title, console_prompt_change_request_path(request) %>
    <% if request.target_slot.present? %>
      <div class="console-cell-sub"><%= request.target_slot %></div>
    <% end %>
  <% end %>
  <% table.with_column "Kind" do |request| %>
    <%= render Console::BadgeComponent.new(status: "info", label: request.kind.humanize) %>
  <% end %>
  <% table.with_column "Impact" do |request| %>
    <%= request.impact_answer&.humanize %>
  <% end %>
  <% table.with_column "GitHub" do |request| %>
    <% if request.github_url %>
      <%= link_to request.github_ref, request.github_url, target: "_blank", rel: "noopener" %>
    <% end %>
  <% end %>
  <% table.with_column "Status" do |request| %>
    <%= render Console::BadgeComponent.new(status: request.state_cache.presence || "pending") %>
  <% end %>
  <% table.with_column "By" do |request| %>
    <%= request.user&.email %>
    <div class="console-cell-sub"><%= request.created_at.strftime("%-d %b %Y") %></div>
  <% end %>
<% end %>
